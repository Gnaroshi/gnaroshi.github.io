---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImplementationCard from "../../components/implementations/ImplementationCard.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import { getImplementationTags, getPublishedImplementationAttempts } from "../../utils/implementations";

const attempts = await getPublishedImplementationAttempts();
const activeAttempts = attempts.filter((attempt) => ["planned", "in-progress"].includes(attempt.data.status));
const reproducedAttempts = attempts.filter((attempt) => ["reproduced", "partially-reproduced", "shipped"].includes(attempt.data.status));
const failedAttempts = attempts.filter((attempt) => ["failed", "abandoned"].includes(attempt.data.status));
const tags = getImplementationTags(attempts);
---

<BaseLayout
  title="Implementation Attempts"
  description="Research implementation attempts connected to papers, projects, and follow-up notes."
  width="wide"
  mode="application"
>
  <header class="page-header">
    <p class="eyebrow">Implementations</p>
    <h1>Paper-to-code attempts</h1>
    <p class="lede">
      A record of reproductions, partial reproductions, failed attempts, and shipped research tools.
    </p>
  </header>

  {attempts.length > 0 ? <section class="paper-stats" aria-label="Implementation stats">
    <article class="paper-stat-card">
      <strong>{attempts.length}</strong>
      <span>Total attempts</span>
    </article>
    <article class="paper-stat-card">
      <strong>{activeAttempts.length}</strong>
      <span>Active</span>
    </article>
    <article class="paper-stat-card">
      <strong>{reproducedAttempts.length}</strong>
      <span>Reproduced or shipped</span>
    </article>
    <article class="paper-stat-card">
      <strong>{failedAttempts.length}</strong>
      <span>Failed or abandoned</span>
    </article>
  </section> : (
    <section class="app-empty-state" aria-labelledby="implementation-empty-heading">
      <p class="eyebrow">Build state</p>
      <h2 id="implementation-empty-heading">No public implementation attempt yet</h2>
      <p>Start from a paper question, test one concrete claim in code, and record the result even when it fails.</p>
      <a class="button button--primary" href="/papers#new-paper-template">Start with a paper note</a>
    </section>
  )}

  {attempts.length > 0 && <section class="section" aria-labelledby="implementation-list-heading">
    <SectionHeader
      id="implementation-list-heading"
      title="Attempt log"
      description="Failures stay visible because they preserve the constraints, missing assumptions, and next experiments."
    >
      <a slot="action" href="/graph">Research graph</a>
    </SectionHeader>

    {attempts.length > 0 ? (
      <div class="implementation-grid">
        {attempts.map((attempt) => <ImplementationCard attempt={attempt} />)}
      </div>
    ) : (
      <p class="empty-state">No public implementation logs yet. When a paper becomes code, the attempt will appear here.</p>
    )}
  </section>}

  {tags.length > 0 && (
    <section class="section" aria-labelledby="implementation-tags-heading">
      <SectionHeader id="implementation-tags-heading" title="Tags" />
      <div class="badge-row">
        {tags.map((tag) => <span class="paper-tag">{tag}</span>)}
      </div>
    </section>
  )}
</BaseLayout>

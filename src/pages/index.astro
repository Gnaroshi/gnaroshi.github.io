---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvidenceGate from "../components/growth/EvidenceGate.astro";
import Hero from "../components/home/Hero.astro";
import ExternalLink from "../components/common/ExternalLink.astro";
import { homeCopy } from "../data/homeCopy";
import { now } from "../data/now";
import { profile } from "../data/profile";
import { projects } from "../data/projects";
import { getPublishedBlogPosts } from "../utils/content";
import { formatDate } from "../utils/date";
import { getEvidenceEligibility } from "../utils/evidenceEligibility";
import { getMomentumInput } from "../utils/momentumData";
import { getPublishedPapers } from "../utils/papers";
import "../styles/home.css";

const [papers, posts, momentumInput] = await Promise.all([
  getPublishedPapers(),
  getPublishedBlogPosts(),
  getMomentumInput()
]);
const eligibility = getEvidenceEligibility(momentumInput);
const recentPosts = posts.slice(0, 3);
const recentPapers = papers.slice(0, 2);
const selectedProject = projects.find((project) => project.featured) ?? projects[0];
const publicLinks = [
  { label: "GitHub", href: profile.links.github },
  profile.links.scholar ? { label: "Google Scholar", href: profile.links.scholar } : null,
  profile.links.cv ? { label: "CV", href: profile.links.cv } : null,
  profile.links.email ? { label: "Email", href: `mailto:${profile.links.email}` } : null
].filter(Boolean) as Array<{ label: string; href: string }>;
---

<BaseLayout
  title={homeCopy.seo.title}
  description={homeCopy.seo.description}
  ogTitle={homeCopy.seo.title}
  ogDescription={homeCopy.seo.openGraphDescription}
  absoluteTitle
  canonical="/"
  width="wide"
>
  <div class="home-editorial">
    <Hero />

    <section class="home-band home-focus" aria-labelledby="current-focus-heading">
      <header>
        <p class="eyebrow">Current focus</p>
        <h2 id="current-focus-heading">Questions before claims</h2>
      </header>
      <div class="home-focus__content">
        <div>
          <h3>Reading</h3>
          <p>{now.currentlyReading[0]}</p>
        </div>
        <div>
          <h3>Building</h3>
          <p>{now.currentlyBuilding[0]}</p>
        </div>
        <div>
          <h3>Selected work</h3>
          <p>{selectedProject.summary}</p>
          <a href={`/projects/${selectedProject.slug}/`}>Open project case study</a>
        </div>
      </div>
    </section>

    <section class="home-band home-activity" aria-labelledby="latest-work-heading">
      <header>
        <p class="eyebrow">Latest work</p>
        <h2 id="latest-work-heading">Writing and paper activity</h2>
      </header>
      <div class="home-activity__columns">
        <div>
          <div class="home-list-heading"><h3>Writing</h3><a href="/blog">All writing</a></div>
          <ol class="editorial-record-list">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              </li>
            ))}
          </ol>
        </div>
        <div>
          <div class="home-list-heading"><h3>Paper notes</h3><a href="/papers">Paper Lab</a></div>
          {recentPapers.length > 0 ? (
            <ol class="editorial-record-list">
              {recentPapers.map((paper) => (
                <li><a href={`/papers/${paper.id}/`}>{paper.data.title}</a><span>{paper.data.status}</span></li>
              ))}
            </ol>
          ) : (
            <div class="home-onboarding">
              <p>The public paper record starts with one honest relevance pass.</p>
              <a href="/papers#new-paper-template">Add the first paper note</a>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="home-band home-cockpit-preview" aria-labelledby="cockpit-preview-heading">
      <header>
        <p class="eyebrow">Research cockpit</p>
        <h2 id="cockpit-preview-heading">Evidence before metrics</h2>
        <p>Reading, retrieval, revisits, and implementation become useful as a connected record, not as isolated counters.</p>
      </header>
      <EvidenceGate eligibility={eligibility} compact />
      <a class="button button--primary" href="/papers#new-paper-template">Add the first paper note</a>
    </section>

    <section class="home-band home-collaboration" aria-labelledby="collaboration-heading">
      <div>
        <p class="eyebrow">Collaboration</p>
        <h2 id="collaboration-heading">Research, tools, and clear technical work</h2>
        <p>I am interested in AI systems, research workflows, and software that helps people read and reason more carefully.</p>
      </div>
      <div class="home-collaboration__links">
        {publicLinks.map((link) => <ExternalLink href={link.href}>{link.label}</ExternalLink>)}
        <a href="/about">About</a>
        <a href="/contact">Public links</a>
      </div>
    </section>
  </div>
</BaseLayout>

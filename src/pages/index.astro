---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Hero from "../components/home/Hero.astro";
import InterestGrid from "../components/home/InterestGrid.astro";
import RecentPapers from "../components/home/RecentPapers.astro";
import RecentPosts from "../components/home/RecentPosts.astro";
import Card from "../components/common/Card.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import { profile } from "../data/profile";
import { now } from "../data/now";
import { researchQuestions } from "../data/research";
---

<BaseLayout title={profile.siteName} description={profile.shortBio} width="wide">
  <Hero />

  <section class="section" aria-labelledby="focus-heading">
    <SectionHeader
      id="focus-heading"
      eyebrow="Current focus"
      title="What I am working on now"
      description={`Last updated ${now.lastUpdated}. A short snapshot of current reading, building, and research questions.`}
    >
      <a slot="action" href="/now">Now page</a>
    </SectionHeader>
    <div class="grid">
      <Card title="Reading" description={now.currentlyReading[0]} />
      <Card title="Building" description={now.currentlyBuilding[0]} />
      <Card title="Question" description={researchQuestions[0].summary} />
    </div>
  </section>

  <InterestGrid />
  <FeaturedProjects />
  <RecentPosts />
  <RecentPapers />

  <section class="section" aria-labelledby="contact-cta-heading">
    <SectionHeader
      id="contact-cta-heading"
      eyebrow="Contact"
      title="For research, software, and collaboration"
      description="GitHub is the best public entry point for code, notes, and project context."
    >
      <a slot="action" href="/contact">Contact links</a>
    </SectionHeader>
  </section>
</BaseLayout>

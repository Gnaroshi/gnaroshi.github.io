---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import FeatureStyles from "../../../components/FeatureStyles.astro";
import RedirectPage from "../../../components/RedirectPage.astro";
import StructuredData from "../../../components/StructuredData.astro";
import PaperDetailHeader from "../../../components/papers/PaperDetailHeader.astro";
import { getBuildablePapers, type PaperEntry } from "../../../utils/papers";
import { getTranslationEntry } from "../../../utils/localizedContent";
import { profile } from "../../../data/profile";
import { hasMathSyntax } from "../../../utils/math";
import "../../../styles/application.css";
import "../../../styles/code.css";
import "../../../styles/papers.css";
import "../../../styles/prose.css";

export async function getStaticPaths() {
  const koreanPapers = await getBuildablePapers("ko");
  const allPapers = [...koreanPapers, ...await getBuildablePapers("en")];
  return koreanPapers.flatMap((paper) => {
    const english = getTranslationEntry(allPapers, paper, "en");
    const props = { paper, english };
    return [{ params: { slug: paper.data.canonicalSlug }, props }, ...paper.data.aliases.map((alias) => ({ params: { slug: alias }, props: { ...props, redirectTo: `/ko/papers/${paper.data.canonicalSlug}/` } }))];
  });
}

interface Props { paper: PaperEntry; english?: PaperEntry; redirectTo?: string }
const { paper, english, redirectTo } = Astro.props as Props;
const { Content } = await render(paper);
const slug = paper.data.canonicalSlug;
const alternateUrls = { en: english ? `/papers/${english.data.canonicalSlug}/` : "/papers/", ko: `/ko/papers/${slug}/`, xDefault: english ? `/papers/${english.data.canonicalSlug}/` : "/papers/", translationAvailable: Boolean(english) } as const;
const futureMe = paper.data.futureMe;
const structuredItems = [
  ["한 줄 요약", paper.data.oneLineSummary], ["핵심 질문", paper.data.coreQuestion], ["핵심 아이디어", paper.data.coreIdea],
  ["핵심 수식", paper.data.mainFormula], ["수식 해석", paper.data.formulaInterpretation], ["실험에서 얻은 결론", paper.data.experimentTakeaway]
].filter((item): item is [string, string] => Boolean(item[1]));
const critiqueItems = [["내 연구와의 연결", paper.data.myConnection], ["다음 행동", paper.data.nextAction]].filter((item): item is [string, string] => Boolean(item[1]));
const hasBody = Boolean(paper.body?.trim());
const hasMath = hasMathSyntax(paper.body) || hasMathSyntax(paper.data.mainFormula);
const canonicalPath = `/ko/papers/${slug}/`;
const techArticle = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: paper.data.title,
  ...(paper.data.oneLineSummary ? { description: paper.data.oneLineSummary } : {}),
  url: new URL(canonicalPath, profile.domain).toString(),
  inLanguage: "ko-KR",
  author: { "@type": "Person", name: profile.publicAlias, url: profile.domain },
  keywords: [...paper.data.tags, ...paper.data.relatedTopics],
  ...(paper.data.readDate ? { datePublished: paper.data.readDate.toISOString() } : {}),
  ...(paper.data.lastReviewed ? { dateModified: paper.data.lastReviewed.toISOString() } : {}),
  citation: {
    "@type": "ScholarlyArticle",
    name: paper.data.title,
    author: paper.data.authors.map((name) => ({ "@type": "Person", name })),
    ...(paper.data.paperUrl ? { url: paper.data.paperUrl } : {}),
    ...(paper.data.venue ? { isPartOf: paper.data.venue } : {}),
    datePublished: String(paper.data.year)
  }
};
---

{redirectTo ? <RedirectPage target={redirectTo} /> : <BaseLayout locale="ko" title={paper.data.title} description={paper.data.oneLineSummary} canonical={canonicalPath} alternateUrls={alternateUrls} type="article" paperLab robots={paper.data.visibility === "unlisted" ? "noindex, follow" : "index, follow"} publishedTime={paper.data.readDate} modifiedTime={paper.data.lastReviewed ?? paper.data.readDate} articleTags={paper.data.tags}>
  <FeatureStyles slot="head" styles={hasMath ? ["katex"] : []} />
  <article class="paper-detail">
    <Breadcrumbs label="현재 위치" items={[
      { name: "홈", href: "/ko/" },
      { name: "논문 읽기", href: "/ko/papers/" },
      { name: paper.data.title, href: canonicalPath }
    ]} />
    <StructuredData data={techArticle} />
    {!english && <p class="content-language-badge"><span class="paper-badge paper-badge--muted">한국어 콘텐츠</span> 영어 번역 없음</p>}
    <PaperDetailHeader paper={paper} locale="ko" />

    {paper.data.lastReviewed && <section class="section" aria-labelledby="ko-review-heading"><h2 id="ko-review-heading">노트 검토</h2><p>이 결과는 읽기 기록에 남긴 내용만 바탕으로 다시 볼 부분을 정리합니다.</p><p>{paper.data.reviewHistory?.[0]?.note}</p><p class="metadata">{paper.data.lastReviewed.toISOString().slice(0, 10)}</p></section>}

    {futureMe && Object.values(futureMe).some(Boolean) && <section class="learning-panel learning-panel--accent" aria-labelledby="ko-future-me"><div><p class="eyebrow">미래의 나에게</p><h2 id="ko-future-me">나중에도 기억할 것</h2></div><div class="paper-detail-grid">{futureMe.oneThingToRemember && <div><h3>기억할 한 가지</h3><p>{futureMe.oneThingToRemember}</p></div>}{futureMe.whyItMatters && <div><h3>중요한 이유</h3><p>{futureMe.whyItMatters}</p></div>}{futureMe.whenToUseThis && <div><h3>활용할 때</h3><p>{futureMe.whenToUseThis}</p></div>}{futureMe.whatToRevisit && <div><h3>다시 볼 것</h3><p>{futureMe.whatToRevisit}</p></div>}{futureMe.warning && <div><h3>주의할 점</h3><p>{futureMe.warning}</p></div>}</div></section>}

    {structuredItems.length > 0 && <section class="section" aria-labelledby="ko-structured-note"><h2 id="ko-structured-note">구조화된 읽기 노트</h2><div class="paper-detail-grid">{structuredItems.map(([title, value]) => <div><h3>{title}</h3><p>{value}</p></div>)}</div></section>}
    {((paper.data.strengths?.length ?? 0) > 0 || (paper.data.weaknesses?.length ?? 0) > 0 || critiqueItems.length > 0) && <section class="section" aria-labelledby="ko-critique"><h2 id="ko-critique">비판과 후속 작업</h2><div class="paper-detail-grid">{(paper.data.strengths?.length ?? 0) > 0 && <div><h3>강점</h3><ul>{paper.data.strengths?.map((item) => <li>{item}</li>)}</ul></div>}{(paper.data.weaknesses?.length ?? 0) > 0 && <div><h3>약점</h3><ul>{paper.data.weaknesses?.map((item) => <li>{item}</li>)}</ul></div>}{critiqueItems.map(([title, value]) => <div><h3>{title}</h3><p>{value}</p></div>)}</div></section>}
    {(paper.data.tags.length > 0 || paper.data.relatedTopics.length > 0) && <section class="section" aria-labelledby="ko-paper-tags"><h2 id="ko-paper-tags">태그와 주제</h2><div class="badge-row">{paper.data.tags.map((tag) => <span class="paper-tag">{tag}</span>)}{paper.data.relatedTopics.map((topic) => <span class="paper-tag paper-tag--topic">{topic}</span>)}</div></section>}
    {hasBody && <section class="section" aria-labelledby="ko-full-note"><h2 id="ko-full-note">전체 노트</h2><div class="prose"><Content /></div></section>}
  </article>
</BaseLayout>}

---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExternalLink from "../../components/common/ExternalLink.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import { getPublishedQueueItems, toQueueDateKey, type QueueEntry } from "../../utils/queue";

export async function getStaticPaths() {
  const items = await getPublishedQueueItems();
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

interface Props {
  item: QueueEntry;
}

const { item } = Astro.props as Props;
const { Content } = await render(item);
const convertCommand = `npm run paper:from-queue -- --slug ${item.id}`;
---

<BaseLayout title={item.data.title} description={item.data.reasonToRead} canonical={`/queue/${item.id}/`} type="article">
  <article class="paper-detail">
    <header class="paper-detail-header">
      <a class="paper-detail-header__back" href="/queue">Back to queue</a>
      <div class="paper-detail-header__title">
        <p class="eyebrow">Queued paper</p>
        <h1>{item.data.title}</h1>
        <p class="lede">{item.data.reasonToRead}</p>
      </div>
      <p class="paper-detail-header__meta">
        {item.data.authors.join(", ")} · {item.data.venue} · {item.data.year} · added {toQueueDateKey(item.data.addedDate)}
      </p>
      <div class="paper-detail-header__badges">
        <span class="paper-badge paper-badge--featured">{item.data.priority}</span>
        <span class="paper-badge paper-badge--muted">{item.data.status}</span>
        <span class="paper-badge paper-badge--muted">{item.data.source}</span>
      </div>
      <div class="paper-detail-header__links">
        {item.data.paperUrl && <ExternalLink href={item.data.paperUrl}>Paper</ExternalLink>}
        {item.data.codeUrl && <ExternalLink href={item.data.codeUrl}>Code</ExternalLink>}
      </div>
    </header>

    <section class="section" aria-labelledby="queue-metadata-heading">
      <SectionHeader id="queue-metadata-heading" title="Triage notes" description="Why this paper is worth tracking before a full reading pass." />
      <div class="paper-detail-grid">
        <div>
          <h2>Reason to read</h2>
          <p>{item.data.reasonToRead}</p>
        </div>
        <div>
          <h2>Estimated effort</h2>
          <p>{item.data.estimatedReadingTimeMinutes} min · difficulty {item.data.estimatedDifficulty}/5</p>
        </div>
        <div>
          <h2>Target date</h2>
          <p>{toQueueDateKey(item.data.targetDate) ?? "Not scheduled yet."}</p>
        </div>
        <div>
          <h2>Convert to paper log</h2>
          <pre><code>{convertCommand}</code></pre>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="queue-tags-heading">
      <SectionHeader id="queue-tags-heading" title="Topics and tags" />
      <div class="paper-topic-group">
        <div class="badge-row">
          {item.data.tags.map((tag) => <span class="paper-tag">{tag}</span>)}
        </div>
        {item.data.relatedTopics.length > 0 && (
          <div class="badge-row">
            {item.data.relatedTopics.map((topic) => <span class="paper-tag paper-tag--topic">{topic}</span>)}
          </div>
        )}
      </div>
    </section>

    <section class="section" aria-labelledby="queue-body-heading">
      <SectionHeader id="queue-body-heading" title="Notes" />
      <div class="prose">
        <Content />
      </div>
    </section>
  </article>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import ImplementationCard from "../components/implementations/ImplementationCard.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import { projects } from "../data/projects";
import { getImplementationAttemptsForProject, getPublishedImplementationAttempts } from "../utils/implementations";

const sortedProjects = [...projects].sort((a, b) => Number(b.featured) - Number(a.featured));
const implementationAttempts = await getPublishedImplementationAttempts();
---

<BaseLayout title="Projects" description="Project cards and technical writeups." width="wide">
  <header class="page-header">
    <p class="eyebrow">Projects</p>
    <h1>Software and research systems</h1>
    <p class="lede">
      A compact view of software, writing, and research systems that support the notes on this site.
    </p>
  </header>

  <section class="section" aria-labelledby="projects-heading">
    <SectionHeader
      id="projects-heading"
      title="Selected project"
      description="A maintained system connecting technical writing, paper reading, and public research workflow."
    />
    <div class="project-grid">
      {sortedProjects.map((project) => (
        <article id={project.slug} class="project-entry">
          <div class="project-entry__meta">
            <span>{project.status}</span>
            <span>Updated {project.updatedAt}</span>
          </div>
          <h2><a href={`/projects/${project.slug}/`}>{project.title}</a></h2>
          <p>{project.summary}</p>
          <ul class="tag-row" aria-label={`${project.title} technologies`}>
            {project.tags.map((tag) => <li>{tag}</li>)}
          </ul>
          <a class="text-link" href={`/projects/${project.slug}/`}>Read project case study</a>
          {getImplementationAttemptsForProject(implementationAttempts, project.slug).length > 0 && (
            <div class="implementation-card__related">
              <h3>Implementation attempts</h3>
              <ul>
                {getImplementationAttemptsForProject(implementationAttempts, project.slug).map((attempt) => (
                  <li><a href={`/implementations/${attempt.id}/`}>{attempt.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  {implementationAttempts.length > 0 && (
    <section class="section" aria-labelledby="project-implementation-heading">
      <SectionHeader
        id="project-implementation-heading"
        title="Recent implementation attempts"
        description="Experiments that connect papers to code and project work."
      />
      <div class="implementation-grid">
        {implementationAttempts.slice(0, 4).map((attempt) => <ImplementationCard attempt={attempt} />)}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .project-entry {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-border);
  }

  .project-entry__meta {
    display: flex;
    gap: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-transform: capitalize;
  }

  .project-entry h2,
  .project-entry p {
    margin: 0;
  }

  .project-entry h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-entry p {
    max-width: 68ch;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    list-style: none;
  }

  .text-link {
    width: fit-content;
    font-weight: 700;
  }
</style>

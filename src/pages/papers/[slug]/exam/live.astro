---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getBuildablePapers, type PaperEntry } from "../../../../utils/papers";
import { getContentSlug } from "../../../../utils/localizedContent";

export async function getStaticPaths() {
  const papers = await getBuildablePapers();
  return papers.map((paper) => ({ params: { slug: getContentSlug(paper.id) }, props: { paper } }));
}

interface Props { paper: PaperEntry }
const { paper } = Astro.props as Props;
const slug = getContentSlug(paper.id);
const exams = paper.data.oralExams;
const alternateUrls = { en: `/papers/${slug}/exam/live/`, ko: "/ko/papers/", xDefault: `/papers/${slug}/exam/live/`, translationAvailable: false } as const;
---

<BaseLayout title={`Oral exam record · ${paper.data.title}`} description={`Published oral exam evidence for ${paper.data.title}.`} canonical={`/papers/${slug}/exam/live/`} alternateUrls={alternateUrls} width="dashboard" mode="application">
  <p class="content-language-badge"><span class="paper-badge paper-badge--muted">English content</span> Translation unavailable</p>
  <header class="page-header">
    <a class="paper-detail-header__back" href={`/papers/${slug}/`}>Back to paper note</a>
    <p class="eyebrow">Oral exam record</p>
    <h1>{paper.data.title}</h1>
    <p class="lede">Published retrieval-practice summaries associated with this paper.</p>
  </header>
  {exams.length > 0 ? (
    <section class="section" aria-labelledby="oral-exam-history-heading">
      <h2 id="oral-exam-history-heading">Exam history</h2>
      <div class="paper-note-list">{exams.map((exam) => <article><h3>{exam.date}</h3><p>{exam.questionsAnswered} of {exam.totalQuestions} questions answered · {exam.confidence} confidence{exam.overallScore === null ? "" : ` · score ${exam.overallScore}`}</p>{exam.followUpQuestion && <p>{exam.followUpQuestion}</p>}</article>)}</div>
    </section>
  ) : (
    <section class="app-empty-state" aria-labelledby="oral-exam-empty-heading"><h2 id="oral-exam-empty-heading">No public oral exam record</h2><p>This paper does not currently include a published oral exam summary.</p><a class="button button--primary" href={`/papers/${slug}/`}>Return to paper note</a></section>
  )}
</BaseLayout>

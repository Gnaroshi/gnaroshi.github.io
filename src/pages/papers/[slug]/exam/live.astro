---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../../components/Breadcrumbs.astro";
import "../../../../styles/application.css";
import "../../../../styles/papers.css";
import { getBuildablePapers, type PaperEntry } from "../../../../utils/papers";

export async function getStaticPaths() {
  const papers = await getBuildablePapers();
  return papers.filter((paper) => (paper.data.oralExams?.length ?? 0) > 0).map((paper) => ({ params: { slug: paper.data.canonicalSlug }, props: { paper } }));
}

interface Props { paper: PaperEntry }
const { paper } = Astro.props as Props;
const slug = paper.data.canonicalSlug;
const exams = paper.data.oralExams ?? [];
const alternateUrls = { en: `/papers/${slug}/exam/live/`, ko: "/ko/papers/", xDefault: `/papers/${slug}/exam/live/`, translationAvailable: false } as const;
---

<BaseLayout title={`Oral exam record · ${paper.data.title}`} description={`Published oral exam summaries for ${paper.data.title}.`} canonical={`/papers/${slug}/exam/live/`} alternateUrls={alternateUrls} width="dashboard" mode="application" robots="noindex, follow">
  <Breadcrumbs items={[{ name: "Home", href: "/" }, { name: "Papers", href: "/papers/" }, { name: paper.data.title, href: `/papers/${slug}/` }, { name: "Oral exam", href: `/papers/${slug}/exam/live/` }]} />
  <p class="content-language-badge"><span class="paper-badge paper-badge--muted">English content</span> Translation unavailable</p>
  <header class="page-header">
    <a class="paper-detail-header__back" href={`/papers/${slug}/`}>Back to paper note</a>
    <p class="eyebrow">Oral exam record</p>
    <h1>{paper.data.title}</h1>
    <p class="lede">Published retrieval-practice summaries associated with this paper.</p>
  </header>
  <section class="section" aria-labelledby="oral-exam-history-heading">
      <h2 id="oral-exam-history-heading">Exam history</h2>
      <div class="paper-note-list">{exams.map((exam) => <article><h3>{exam.date}</h3><p>{exam.questionsAnswered} of {exam.totalQuestions} questions answered · {exam.confidence} confidence{exam.overallScore == null ? "" : ` · score ${exam.overallScore}`}</p>{exam.summary && <p>{exam.summary}</p>}</article>)}</div>
    </section>
</BaseLayout>

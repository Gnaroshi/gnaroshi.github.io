---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import "../../../styles/application.css";
import "../../../styles/code.css";
import "../../../styles/papers.css";
import { getPublishedPapers, type PaperEntry } from "../../../utils/papers";
import { hasFormulaRecallMaterial } from "../../../utils/formulaRecall";

export async function getStaticPaths() {
  return (await getPublishedPapers()).filter(hasFormulaRecallMaterial).map((paper) => ({ params: { slug: paper.data.canonicalSlug }, props: { paper } }));
}

interface Props { paper: PaperEntry }
const { paper } = Astro.props as Props;
const slug = paper.data.canonicalSlug;
const alternateUrls = { en: `/papers/${slug}/formula/`, ko: "/ko/formula/", xDefault: `/papers/${slug}/formula/`, translationAvailable: false } as const;
---
<BaseLayout title={`${paper.data.title} Formula`} description={`Published formula note for ${paper.data.title}.`} canonical={`/papers/${slug}/formula/`} alternateUrls={alternateUrls} width="dashboard" mode="application" robots="noindex, follow">
  <Breadcrumbs items={[{ name: "Home", href: "/" }, { name: "Papers", href: "/papers/" }, { name: paper.data.title, href: `/papers/${slug}/` }, { name: "Formula", href: `/papers/${slug}/formula/` }]} />
  <div class="paper-dashboard"><p class="content-language-badge"><span class="paper-badge paper-badge--muted">English content</span> Translation unavailable</p><header class="paper-hero"><div class="paper-hero__copy"><p class="eyebrow">Formula note</p><h1>{paper.data.title}</h1><p class="lede">The formula and interpretation published with this paper note.</p></div><nav class="paper-hero__actions" aria-label="Paper formula navigation"><a href={`/papers/${slug}/`}>Paper note</a><a href="/formula/">All formulas</a></nav></header>{paper.data.mainFormula && <section class="section" aria-labelledby="saved-formula-heading"><h2 id="saved-formula-heading">Main formula</h2><pre><code>{paper.data.mainFormula}</code></pre>{paper.data.formulaInterpretation && <p>{paper.data.formulaInterpretation}</p>}</section>}</div>
</BaseLayout>

---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FeatureStyles from "../../components/FeatureStyles.astro";
import RedirectPage from "../../components/RedirectPage.astro";
import StructuredData from "../../components/StructuredData.astro";
import ImplementationCard from "../../components/implementations/ImplementationCard.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import PaperDetailHeader from "../../components/papers/PaperDetailHeader.astro";
import PaperReviewCard from "../../components/papers/PaperReviewCard.astro";
import { getBuildablePapers, getPublishedPapers, type PaperEntry } from "../../utils/papers";
import { getImplementationAttemptsForPaper, getPublishedImplementationAttempts } from "../../utils/implementations";
import { getVisiblePaperReviewForPaper } from "../../utils/paperReviews";
import { getIslandMessages } from "../../i18n/islands";
import { getTranslationEntry } from "../../utils/localizedContent";
import { profile } from "../../data/profile";
import { hasMathSyntax } from "../../utils/math";
import "../../styles/application.css";
import "../../styles/code.css";
import "../../styles/papers.css";
import "../../styles/prose.css";

export async function getStaticPaths() {
  const papers = await getBuildablePapers("en");
  const publicPapers = await getPublishedPapers("en");
  const allPapers = [...papers, ...await getBuildablePapers("ko")];

  return papers.flatMap((paper) => {
    const publicIndex = publicPapers.findIndex((item) => item.id === paper.id);
    const korean = getTranslationEntry(allPapers, paper, "ko");
    const props = {
      paper, korean,
      newerPaper: publicIndex > 0 ? publicPapers[publicIndex - 1] : undefined,
      olderPaper: publicIndex >= 0 ? publicPapers[publicIndex + 1] : undefined
    };
    return [{
      params: { slug: paper.data.canonicalSlug },
      props: {
        ...props
      }
    }, ...paper.data.aliases.map((alias) => ({ params: { slug: alias }, props: { ...props, redirectTo: `/papers/${paper.data.canonicalSlug}/` } }))];
  });
}

interface Props {
  paper: PaperEntry;
  newerPaper?: PaperEntry;
  olderPaper?: PaperEntry;
  korean?: PaperEntry;
  redirectTo?: string;
}

const { paper, newerPaper, olderPaper, korean, redirectTo } = Astro.props as Props;
const { Content } = await render(paper);
const review = getVisiblePaperReviewForPaper(paper);
const slug = paper.data.canonicalSlug;
const implementationAttempts = getImplementationAttemptsForPaper(await getPublishedImplementationAttempts(), slug);
const islandMessages = getIslandMessages("en");
const implementationMessages = islandMessages.implementation;
const alternateUrls = { en: `/papers/${slug}/`, ko: korean ? `/ko/papers/${korean.data.canonicalSlug}/` : "/ko/papers/", xDefault: `/papers/${slug}/`, translationAvailable: Boolean(korean) } as const;
const futureMe = paper.data.futureMe;
const hasFutureMe = Boolean(futureMe && (futureMe.oneThingToRemember || futureMe.whyItMatters || futureMe.whenToUseThis || futureMe.whatToRevisit || futureMe.warning));
const structuredItems = [
  ["One-line summary", paper.data.oneLineSummary], ["Core question", paper.data.coreQuestion], ["Core idea", paper.data.coreIdea],
  ["Main formula", paper.data.mainFormula], ["Formula interpretation", paper.data.formulaInterpretation], ["Experiment takeaway", paper.data.experimentTakeaway]
].filter((item): item is [string, string] => Boolean(item[1]));
const critiqueItems = [["My connection", paper.data.myConnection], ["Next action", paper.data.nextAction]].filter((item): item is [string, string] => Boolean(item[1]));
const hasBody = Boolean(paper.body?.trim());
const hasMath = hasMathSyntax(paper.body) || hasMathSyntax(paper.data.mainFormula);
const canonicalPath = `/papers/${slug}/`;
const techArticle = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: paper.data.title,
  ...(paper.data.oneLineSummary ? { description: paper.data.oneLineSummary } : {}),
  url: new URL(canonicalPath, profile.domain).toString(),
  inLanguage: "en-US",
  author: { "@type": "Person", name: profile.publicAlias, url: profile.domain },
  keywords: [...paper.data.tags, ...paper.data.relatedTopics],
  ...(paper.data.readDate ? { datePublished: paper.data.readDate.toISOString() } : {}),
  ...(paper.data.lastReviewed ? { dateModified: paper.data.lastReviewed.toISOString() } : {}),
  citation: {
    "@type": "ScholarlyArticle",
    name: paper.data.title,
    author: paper.data.authors.map((name) => ({ "@type": "Person", name })),
    ...(paper.data.paperUrl ? { url: paper.data.paperUrl } : {}),
    ...(paper.data.venue ? { isPartOf: paper.data.venue } : {}),
    datePublished: String(paper.data.year)
  }
};
---

{redirectTo ? <RedirectPage target={redirectTo} /> : <BaseLayout title={paper.data.title} description={paper.data.oneLineSummary} canonical={canonicalPath} alternateUrls={alternateUrls} type="article" paperLab robots={paper.data.visibility === "unlisted" ? "noindex, follow" : "index, follow"} publishedTime={paper.data.readDate} modifiedTime={paper.data.lastReviewed ?? paper.data.readDate} articleTags={paper.data.tags}>
  <FeatureStyles slot="head" styles={hasMath ? ["katex"] : []} />
  <article class="paper-detail">
    <Breadcrumbs items={[
      { name: "Home", href: "/" },
      { name: "Paper Lab", href: "/papers/" },
      { name: paper.data.title, href: canonicalPath }
    ]} />
    <StructuredData data={techArticle} />
    {!korean && <p class="content-language-badge"><span class="paper-badge paper-badge--muted">English content</span> Korean translation unavailable</p>}
    <PaperDetailHeader paper={paper} />

    {(paper.data.oralExams?.length ?? 0) > 0 && <section class="learning-panel learning-panel--accent" aria-labelledby="oral-exam-heading">
      <div>
        <p class="eyebrow">Retrieval practice</p>
        <h2 id="oral-exam-heading">Explain this paper aloud</h2>
        <p>Use live voice when the optional API is available, or continue with text and manual practice.</p>
      </div>
      <div class="paper-card__links">
        <a href={`/papers/${slug}/exam/live/`}>View oral exam record</a>
      </div>
    </section>}

    {review && <PaperReviewCard review={review} />}

    {hasFutureMe && futureMe && (
      <section class="learning-panel learning-panel--accent" aria-labelledby="future-me-heading">
        <div>
          <p class="eyebrow">For Future Me</p>
          <h2 id="future-me-heading">What should still matter later</h2>
        </div>
        <div class="paper-detail-grid">
          {futureMe.oneThingToRemember && (
            <div>
              <h3>One thing to remember</h3>
              <p>{futureMe.oneThingToRemember}</p>
            </div>
          )}
          {futureMe.whyItMatters && (
            <div>
              <h3>Why it matters</h3>
              <p>{futureMe.whyItMatters}</p>
            </div>
          )}
          {futureMe.whenToUseThis && (
            <div>
              <h3>When to use this</h3>
              <p>{futureMe.whenToUseThis}</p>
            </div>
          )}
          {futureMe.whatToRevisit && (
            <div>
              <h3>Revisit action</h3>
              <p>{futureMe.whatToRevisit}</p>
            </div>
          )}
          {futureMe.warning && (
            <div>
              <h3>Warning</h3>
              <p>{futureMe.warning}</p>
            </div>
          )}
        </div>
      </section>
    )}

    {structuredItems.length > 0 && <section class="section" aria-labelledby="paper-summary-heading">
      <SectionHeader id="paper-summary-heading" title="Structured reading note" description="The central ideas, evidence, and interpretation captured during reading." />
      <div class="paper-detail-grid">
        {structuredItems.map(([title, value]) => <div><h3>{title}</h3><p>{value}</p></div>)}
      </div>
    </section>}

    {((paper.data.strengths?.length ?? 0) > 0 || (paper.data.weaknesses?.length ?? 0) > 0 || critiqueItems.length > 0) && <section class="section" aria-labelledby="paper-critique-heading">
      <SectionHeader id="paper-critique-heading" title="Critique and follow-up" />
      <div class="paper-detail-grid">
        {(paper.data.strengths?.length ?? 0) > 0 && <div>
          <h3>Strengths</h3>
          <ul>{paper.data.strengths?.map((item) => <li>{item}</li>)}</ul>
        </div>}
        {(paper.data.weaknesses?.length ?? 0) > 0 && <div>
          <h3>Weaknesses</h3>
          <ul>{paper.data.weaknesses?.map((item) => <li>{item}</li>)}</ul>
        </div>}
        {critiqueItems.map(([title, value]) => <div><h3>{title}</h3><p>{value}</p></div>)}
      </div>
    </section>}

    {(paper.data.tags.length > 0 || paper.data.relatedTopics.length > 0) && <section class="section" aria-labelledby="paper-tags-heading">
      <SectionHeader id="paper-tags-heading" title="Tags and topics" />
      <div class="paper-topic-group">
        <div class="badge-row">
          {paper.data.tags.map((tag) => <span class="paper-tag">{tag}</span>)}
        </div>
        {paper.data.relatedTopics.length > 0 && (
          <div class="badge-row">
            {paper.data.relatedTopics.map((topic) => <span class="paper-tag paper-tag--topic">{topic}</span>)}
          </div>
        )}
      </div>
    </section>}

    {implementationAttempts.length > 0 && (
      <section class="section" aria-labelledby="paper-implementations-heading">
        <SectionHeader
          id="paper-implementations-heading"
          title="Implementation attempts"
          description="Code attempts connected to this paper, including partial and failed reproductions."
        />
        <div class="implementation-grid">
          {implementationAttempts.map((attempt) => <ImplementationCard attempt={attempt} locale="en" messages={implementationMessages} />)}
        </div>
      </section>
    )}

    {hasBody && <section class="section" aria-labelledby="paper-body-heading">
      <SectionHeader id="paper-body-heading" title="Full note" description="Pass-by-pass observations, questions, and implementation notes." />
      <div class="prose">
        <Content />
      </div>
    </section>}

    <nav class="paper-nav" aria-label="Paper note navigation">
      <div>
        {olderPaper ? (
          <a href={`/papers/${olderPaper.data.canonicalSlug}/`}>
            <span>Older paper</span>
            {olderPaper.data.title}
          </a>
        ) : (
          <span class="paper-nav__empty">No older paper</span>
        )}
      </div>
      <div>
        {newerPaper ? (
          <a href={`/papers/${newerPaper.data.canonicalSlug}/`}>
            <span>Newer paper</span>
            {newerPaper.data.title}
          </a>
        ) : (
          <span class="paper-nav__empty">No newer paper</span>
        )}
      </div>
    </nav>
  </article>
</BaseLayout>}

---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import PaperDetailHeader from "../../components/papers/PaperDetailHeader.astro";
import PaperReviewCard from "../../components/papers/PaperReviewCard.astro";
import ReviewPromptFallback from "../../components/papers/ReviewPromptFallback.astro";
import ManualReviewPrompt from "../../components/papers/ManualReviewPrompt";
import { getPublishedPapers, type PaperEntry } from "../../utils/papers";
import { getPublicPaperReviewForPaper } from "../../utils/paperReviews";
import { buildManualReviewPromptForPaper } from "../../../scripts/lib/paper-review-prompt.mjs";

export async function getStaticPaths() {
  const papers = await getPublishedPapers();

  return papers.map((paper, index) => ({
    params: { slug: paper.id },
    props: {
      paper,
      newerPaper: papers[index - 1],
      olderPaper: papers[index + 1]
    }
  }));
}

interface Props {
  paper: PaperEntry;
  newerPaper?: PaperEntry;
  olderPaper?: PaperEntry;
}

const { paper, newerPaper, olderPaper } = Astro.props as Props;
const { Content } = await render(paper);
const review = getPublicPaperReviewForPaper(paper);
const manualPrompt = buildManualReviewPromptForPaper({
  slug: paper.id,
  frontmatter: paper.data,
  body: paper.body
});
const reviewCommand = `npm run paper:review -- --slug ${paper.id}`;

const fallback = "Not recorded yet.";
const futureMe = paper.data.futureMe;
const hasFutureMe =
  futureMe.oneThingToRemember || futureMe.whyItMatters || futureMe.whenToUseThis || futureMe.whatToRevisit || futureMe.warning;
---

<BaseLayout title={paper.data.title} description={paper.data.oneLineSummary} canonical={`/papers/${paper.id}/`} type="article">
  <article class="paper-detail">
    <PaperDetailHeader paper={paper} />

    {review ? (
      <>
        <PaperReviewCard review={review} />
        <section class="section" aria-labelledby="manual-rereview-heading">
          <div>
            <p class="eyebrow">Manual review</p>
            <h2 id="manual-rereview-heading">Re-review manually</h2>
          </div>
          <ManualReviewPrompt client:load prompt={manualPrompt} command={reviewCommand} triggerLabel="Re-review manually" />
        </section>
      </>
    ) : (
      <ReviewPromptFallback paper={paper} />
    )}

    {hasFutureMe && (
      <section class="learning-panel learning-panel--accent" aria-labelledby="future-me-heading">
        <div>
          <p class="eyebrow">For Future Me</p>
          <h2 id="future-me-heading">What should still matter later</h2>
        </div>
        <div class="paper-detail-grid">
          {futureMe.oneThingToRemember && (
            <div>
              <h2>One thing to remember</h2>
              <p>{futureMe.oneThingToRemember}</p>
            </div>
          )}
          {futureMe.whyItMatters && (
            <div>
              <h2>Why it matters</h2>
              <p>{futureMe.whyItMatters}</p>
            </div>
          )}
          {futureMe.whenToUseThis && (
            <div>
              <h2>When to use this</h2>
              <p>{futureMe.whenToUseThis}</p>
            </div>
          )}
          {futureMe.whatToRevisit && (
            <div>
              <h2>Revisit action</h2>
              <p>{futureMe.whatToRevisit}</p>
            </div>
          )}
          {futureMe.warning && (
            <div>
              <h2>Warning</h2>
              <p>{futureMe.warning}</p>
            </div>
          )}
        </div>
      </section>
    )}

    <section class="section" aria-labelledby="paper-summary-heading">
      <SectionHeader id="paper-summary-heading" title="Structured reading note" description="Frontmatter fields that keep the paper searchable and comparable." />
      <div class="paper-detail-grid">
        <div>
          <h2>One-line summary</h2>
          <p>{paper.data.oneLineSummary || fallback}</p>
        </div>
        <div>
          <h2>Core question</h2>
          <p>{paper.data.coreQuestion || fallback}</p>
        </div>
        <div>
          <h2>Core idea</h2>
          <p>{paper.data.coreIdea || fallback}</p>
        </div>
        <div>
          <h2>Main formula</h2>
          <p>{paper.data.mainFormula || fallback}</p>
        </div>
        <div>
          <h2>Formula interpretation</h2>
          <p>{paper.data.formulaInterpretation || fallback}</p>
        </div>
        <div>
          <h2>Experiment takeaway</h2>
          <p>{paper.data.experimentTakeaway || fallback}</p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="paper-critique-heading">
      <SectionHeader id="paper-critique-heading" title="Critique and follow-up" />
      <div class="paper-detail-grid">
        <div>
          <h2>Strengths</h2>
          {paper.data.strengths.length > 0 ? (
            <ul>
              {paper.data.strengths.map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{fallback}</p>
          )}
        </div>
        <div>
          <h2>Weaknesses</h2>
          {paper.data.weaknesses.length > 0 ? (
            <ul>
              {paper.data.weaknesses.map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{fallback}</p>
          )}
        </div>
        <div>
          <h2>My connection</h2>
          <p>{paper.data.myConnection || fallback}</p>
        </div>
        <div>
          <h2>Next action</h2>
          <p>{paper.data.nextAction || fallback}</p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="paper-tags-heading">
      <SectionHeader id="paper-tags-heading" title="Tags and topics" />
      <div class="paper-topic-group">
        <div class="badge-row">
          {paper.data.tags.map((tag) => <span class="paper-tag">{tag}</span>)}
        </div>
        {paper.data.relatedTopics.length > 0 && (
          <div class="badge-row">
            {paper.data.relatedTopics.map((topic) => <span class="paper-tag paper-tag--topic">{topic}</span>)}
          </div>
        )}
      </div>
    </section>

    <section class="section" aria-labelledby="paper-body-heading">
      <SectionHeader id="paper-body-heading" title="Full note" description="MDX body from the paper log file." />
      <div class="prose">
        <Content />
      </div>
    </section>

    <nav class="paper-nav" aria-label="Paper note navigation">
      <div>
        {olderPaper ? (
          <a href={`/papers/${olderPaper.id}/`}>
            <span>Older paper</span>
            {olderPaper.data.title}
          </a>
        ) : (
          <span class="paper-nav__empty">No older paper</span>
        )}
      </div>
      <div>
        {newerPaper ? (
          <a href={`/papers/${newerPaper.id}/`}>
            <span>Newer paper</span>
            {newerPaper.data.title}
          </a>
        ) : (
          <span class="paper-nav__empty">No newer paper</span>
        )}
      </div>
    </nav>
  </article>
</BaseLayout>

---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImplementationCard from "../../components/implementations/ImplementationCard.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import PaperDetailHeader from "../../components/papers/PaperDetailHeader.astro";
import PaperReviewCard from "../../components/papers/PaperReviewCard.astro";
import ReviewPromptFallback from "../../components/papers/ReviewPromptFallback.astro";
import ManualReviewPrompt from "../../components/papers/ManualReviewPrompt";
import { getBuildablePapers, getPublishedPapers, type PaperEntry } from "../../utils/papers";
import { getImplementationAttemptsForPaper, getPublishedImplementationAttempts } from "../../utils/implementations";
import { getVisiblePaperReviewForPaper } from "../../utils/paperReviews";
import { buildManualReviewPromptForPaper } from "../../../scripts/lib/paper-review-prompt.mjs";
import { getIslandMessages } from "../../i18n/islands";

export async function getStaticPaths() {
  const papers = await getBuildablePapers();
  const publicPapers = await getPublishedPapers();

  return papers.map((paper) => {
    const publicIndex = publicPapers.findIndex((item) => item.id === paper.id);

    return {
      params: { slug: paper.id },
      props: {
        paper,
        newerPaper: publicIndex > 0 ? publicPapers[publicIndex - 1] : undefined,
        olderPaper: publicIndex >= 0 ? publicPapers[publicIndex + 1] : undefined
      }
    };
  });
}

interface Props {
  paper: PaperEntry;
  newerPaper?: PaperEntry;
  olderPaper?: PaperEntry;
}

const { paper, newerPaper, olderPaper } = Astro.props as Props;
const { Content } = await render(paper);
const review = getVisiblePaperReviewForPaper(paper);
const manualPrompt = buildManualReviewPromptForPaper({
  slug: paper.id,
  frontmatter: paper.data,
  body: paper.body
});
const reviewCommand = `npm run paper:review -- --slug ${paper.id}`;
const promoteCommand = `npm run paper:promote -- --slug ${paper.id}`;
const showAuthorTools = import.meta.env.DEV;
const implementationAttempts = getImplementationAttemptsForPaper(await getPublishedImplementationAttempts(), paper.id);
const manualReviewMessages = getIslandMessages("en").manualReview;
const alternateUrls = { en: `/papers/${paper.id}/`, ko: "/ko/papers/", xDefault: `/papers/${paper.id}/`, translationAvailable: false } as const;

const fallback = "Not recorded yet.";
const futureMe = paper.data.futureMe;
const hasFutureMe =
  futureMe.oneThingToRemember || futureMe.whyItMatters || futureMe.whenToUseThis || futureMe.whatToRevisit || futureMe.warning;
---

<BaseLayout title={paper.data.title} description={paper.data.oneLineSummary} canonical={`/papers/${paper.id}/`} alternateUrls={alternateUrls} type="article" paperLab>
  <article class="paper-detail">
    <p class="content-language-badge"><span class="paper-badge paper-badge--muted">English content</span> Translation unavailable</p>
    <PaperDetailHeader paper={paper} />

    <section class="learning-panel learning-panel--accent" aria-labelledby="oral-exam-heading">
      <div>
        <p class="eyebrow">Retrieval practice</p>
        <h2 id="oral-exam-heading">Explain this paper aloud</h2>
        <p>Use live voice when the optional API is available, or continue with text and manual practice.</p>
      </div>
      <div class="paper-card__links">
        <a href={`/papers/${paper.id}/exam/live/`}>Open oral exam</a>
      </div>
    </section>

    {review ? (
      <>
        <PaperReviewCard review={review} />
        <section class="section" aria-labelledby="manual-rereview-heading">
          <div>
            <p class="eyebrow">Manual review</p>
            <h2 id="manual-rereview-heading">Re-review manually</h2>
          </div>
          <ManualReviewPrompt client:load prompt={manualPrompt} command={reviewCommand} locale="en" messages={manualReviewMessages} />
        </section>
      </>
    ) : (
      <ReviewPromptFallback paper={paper} />
    )}

    {hasFutureMe && (
      <section class="learning-panel learning-panel--accent" aria-labelledby="future-me-heading">
        <div>
          <p class="eyebrow">For Future Me</p>
          <h2 id="future-me-heading">What should still matter later</h2>
        </div>
        <div class="paper-detail-grid">
          {futureMe.oneThingToRemember && (
            <div>
              <h3>One thing to remember</h3>
              <p>{futureMe.oneThingToRemember}</p>
            </div>
          )}
          {futureMe.whyItMatters && (
            <div>
              <h3>Why it matters</h3>
              <p>{futureMe.whyItMatters}</p>
            </div>
          )}
          {futureMe.whenToUseThis && (
            <div>
              <h3>When to use this</h3>
              <p>{futureMe.whenToUseThis}</p>
            </div>
          )}
          {futureMe.whatToRevisit && (
            <div>
              <h3>Revisit action</h3>
              <p>{futureMe.whatToRevisit}</p>
            </div>
          )}
          {futureMe.warning && (
            <div>
              <h3>Warning</h3>
              <p>{futureMe.warning}</p>
            </div>
          )}
        </div>
      </section>
    )}

    <section class="section" aria-labelledby="paper-summary-heading">
      <SectionHeader id="paper-summary-heading" title="Structured reading note" description="The central ideas, evidence, and interpretation captured during reading." />
      <div class="paper-detail-grid">
        <div>
          <h3>One-line summary</h3>
          <p>{paper.data.oneLineSummary || fallback}</p>
        </div>
        <div>
          <h3>Core question</h3>
          <p>{paper.data.coreQuestion || fallback}</p>
        </div>
        <div>
          <h3>Core idea</h3>
          <p>{paper.data.coreIdea || fallback}</p>
        </div>
        <div>
          <h3>Main formula</h3>
          <p>{paper.data.mainFormula || fallback}</p>
        </div>
        <div>
          <h3>Formula interpretation</h3>
          <p>{paper.data.formulaInterpretation || fallback}</p>
        </div>
        <div>
          <h3>Experiment takeaway</h3>
          <p>{paper.data.experimentTakeaway || fallback}</p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="paper-critique-heading">
      <SectionHeader id="paper-critique-heading" title="Critique and follow-up" />
      <div class="paper-detail-grid">
        <div>
          <h3>Strengths</h3>
          {paper.data.strengths.length > 0 ? (
            <ul>
              {paper.data.strengths.map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{fallback}</p>
          )}
        </div>
        <div>
          <h3>Weaknesses</h3>
          {paper.data.weaknesses.length > 0 ? (
            <ul>
              {paper.data.weaknesses.map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{fallback}</p>
          )}
        </div>
        <div>
          <h3>My connection</h3>
          <p>{paper.data.myConnection || fallback}</p>
        </div>
        <div>
          <h3>Next action</h3>
          <p>{paper.data.nextAction || fallback}</p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="paper-tags-heading">
      <SectionHeader id="paper-tags-heading" title="Tags and topics" />
      <div class="paper-topic-group">
        <div class="badge-row">
          {paper.data.tags.map((tag) => <span class="paper-tag">{tag}</span>)}
        </div>
        {paper.data.relatedTopics.length > 0 && (
          <div class="badge-row">
            {paper.data.relatedTopics.map((topic) => <span class="paper-tag paper-tag--topic">{topic}</span>)}
          </div>
        )}
      </div>
    </section>

    {implementationAttempts.length > 0 && (
      <section class="section" aria-labelledby="paper-implementations-heading">
        <SectionHeader
          id="paper-implementations-heading"
          title="Implementation attempts"
          description="Code attempts connected to this paper, including partial and failed reproductions."
        />
        <div class="implementation-grid">
          {implementationAttempts.map((attempt) => <ImplementationCard attempt={attempt} />)}
        </div>
      </section>
    )}

    {showAuthorTools && (
      <section class="section" aria-labelledby="paper-promotion-heading">
        <SectionHeader
          id="paper-promotion-heading"
          title="Promote to blog"
          description="Turn this structured paper note into a private draft essay."
        />
        <pre><code>{promoteCommand}</code></pre>
      </section>
    )}

    <section class="section" aria-labelledby="paper-body-heading">
      <SectionHeader id="paper-body-heading" title="Full note" description="Pass-by-pass observations, questions, and implementation notes." />
      <div class="prose">
        <Content />
      </div>
    </section>

    <nav class="paper-nav" aria-label="Paper note navigation">
      <div>
        {olderPaper ? (
          <a href={`/papers/${olderPaper.id}/`}>
            <span>Older paper</span>
            {olderPaper.data.title}
          </a>
        ) : (
          <span class="paper-nav__empty">No older paper</span>
        )}
      </div>
      <div>
        {newerPaper ? (
          <a href={`/papers/${newerPaper.id}/`}>
            <span>Newer paper</span>
            {newerPaper.data.title}
          </a>
        ) : (
          <span class="paper-nav__empty">No newer paper</span>
        )}
      </div>
    </nav>
  </article>
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const papers = (await getCollection("papers")).sort(
  (a, b) => b.data.lastReadAt.getTime() - a.data.lastReadAt.getTime()
);

const deepReads = papers.filter((paper) => paper.data.depth >= 3).length;
const implementedOrReproduced = papers.filter((paper) => paper.data.implemented || paper.data.reproduced).length;
const totalMinutes = papers.reduce((sum, paper) => sum + paper.data.readingMinutes, 0);
const cells = Array.from({ length: 104 });
---

<BaseLayout title="Papers" description="Paper reading dashboard, activity, and three-pass notes." width="dashboard">
  <header class="page-header">
    <p class="eyebrow">Papers</p>
    <h1>Paper reading tracker</h1>
    <p class="lede">
      Daily reading activity, paper notes, questions, and implementation attempts organized around a three-pass method.
    </p>
  </header>

  <section class="section" aria-labelledby="stats-heading">
    <h2 id="stats-heading">Reading Activity</h2>
    <div class="stats-grid">
      <div class="stat"><strong>{papers.length}</strong><span>Total papers</span></div>
      <div class="stat"><strong>{deepReads}</strong><span>Deep reads</span></div>
      <div class="stat"><strong>{implementedOrReproduced}</strong><span>Implemented or reproduced</span></div>
      <div class="stat"><strong>{totalMinutes}</strong><span>Reading minutes</span></div>
    </div>
    <div class="heatmap-placeholder" aria-label="Paper reading heatmap placeholder">
      {cells.map(() => <span></span>)}
    </div>
  </section>

  <section class="section" aria-labelledby="papers-heading">
    <h2 id="papers-heading">Paper Notes</h2>
    {papers.length > 0 ? (
      <ul class="list">
        {papers.map((paper) => (
          <li class="list-item">
            <h3><a href={`/papers/${paper.id}/`}>{paper.data.title}</a></h3>
            <p>{paper.data.summary}</p>
            <p class="metadata">
              {paper.data.authors.join(", ")} · {paper.data.year} · depth {paper.data.depth} · {paper.data.tags.join(", ")}
            </p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">No public paper logs yet.</p>
    )}
  </section>
</BaseLayout>

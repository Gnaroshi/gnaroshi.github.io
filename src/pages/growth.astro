---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import MomentumComponentBreakdown from "../components/growth/MomentumComponentBreakdown.astro";
import MomentumMethodology from "../components/growth/MomentumMethodology.astro";
import MomentumNextActions from "../components/growth/MomentumNextActions.astro";
import MomentumScoreV2 from "../components/growth/MomentumScoreV2.astro";
import EvidenceGate from "../components/growth/EvidenceGate.astro";
import { getEvidenceEligibility } from "../utils/evidenceEligibility";
import { getMomentumInput } from "../utils/momentumData";
import { computeResearchMomentum } from "../utils/momentumScore";

const input = await getMomentumInput();
const result = computeResearchMomentum(input);
const eligibility = getEvidenceEligibility(input);
---

<BaseLayout
  title="Research Growth"
  description="Evidence-based research momentum across reading, understanding, retrieval, output, and revisits."
  width="dashboard"
  mode="application"
>
  <div class="momentum-page">
    <header class="momentum-hero">
      <div>
        <p class="eyebrow">Growth</p>
        <h1>Research momentum</h1>
        <p class="lede">
          A long-term view of consistency, understanding, retrieval, output, and revisit discipline from public research evidence.
        </p>
      </div>
    </header>

    {eligibility.eligible ? <MomentumScoreV2 result={result} /> : <EvidenceGate eligibility={eligibility} />}

    {eligibility.eligible ? (
      <section class="section" aria-labelledby="momentum-components-heading">
        <SectionHeader
          id="momentum-components-heading"
          title="Component breakdown"
          description="Scores use only eligible evidence. Confidence shows how much weight to place on each number."
        />
        <MomentumComponentBreakdown components={result.components} />
      </section>
    ) : (
      <section class="section" aria-labelledby="research-loop-heading">
        <SectionHeader
          id="research-loop-heading"
          title="Build a balanced research loop"
          description="The first public score should reflect more than one kind of activity."
        />
        <div class="research-loop-grid">
          <article><h3>Read</h3><p>Record one paper question and the next reading decision.</p><a href="/papers">Open Paper Log</a></article>
          <article><h3>Recall</h3><p>Explain a saved paper without looking before scoring confidence.</p><a href="/reviews">Review workflow</a></article>
          <article><h3>Build</h3><p>Connect an idea to code, a reproduction, or a failed attempt.</p><a href="/implementations">Implementation log</a></article>
          <article><h3>Write</h3><p>Develop a substantive note after evidence exists.</p><a href="/blog">Read current writing</a></article>
        </div>
      </section>
    )}

    <section class="section" aria-labelledby="momentum-actions-heading">
      <SectionHeader
        id="momentum-actions-heading"
        title="Next actions"
        description="Small actions chosen from the weakest or least-evidenced parts of the research loop."
      />
      <MomentumNextActions actions={result.nextActions} />
    </section>

    {eligibility.eligible && (result.antiGamingFlags.length > 0 || result.missingEvidence.length > 0) && (
      <section class="section momentum-evidence-grid" aria-label="Score evidence notes">
        {result.antiGamingFlags.length > 0 && (
          <article class="momentum-notice momentum-notice--flag">
            <h2>Integrity checks</h2>
            <p>These patterns were capped or discounted before the score was calculated.</p>
            <ul>{result.antiGamingFlags.map((flag) => <li>{flag}</li>)}</ul>
          </article>
        )}
        {result.missingEvidence.length > 0 && (
          <article class="momentum-notice">
            <h2>Missing evidence</h2>
            <p>These gaps lower confidence. They do not become silent zeroes.</p>
            <ul>{result.missingEvidence.map((item) => <li>{item}</li>)}</ul>
          </article>
        )}
      </section>
    )}

    <MomentumMethodology />
  </div>
</BaseLayout>

<style>
  .research-loop-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .research-loop-grid article {
    display: grid;
    gap: var(--space-3);
    align-content: start;
    padding-top: var(--space-4);
    border-top: 2px solid var(--color-border-strong);
  }

  .research-loop-grid p {
    color: var(--color-text-secondary);
  }

  .research-loop-grid a {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .research-loop-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 460px) {
    .research-loop-grid { grid-template-columns: 1fr; }
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/common/Card.astro";
import ExternalLink from "../components/common/ExternalLink.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import { profile } from "../data/profile";

const contactLinks = [
  { label: "GitHub", href: profile.links.github, note: "Best public place to see code and repository activity." },
  { label: "Website", href: profile.links.website, note: "Canonical home for notes, projects, and paper logs." },
  profile.links.email
    ? { label: "Email", href: `mailto:${profile.links.email}`, note: "Direct contact." }
    : null,
  profile.links.scholar ? { label: "Google Scholar", href: profile.links.scholar, note: "Research profile." } : null,
  profile.links.linkedin ? { label: "LinkedIn", href: profile.links.linkedin, note: "Professional profile." } : null,
  profile.links.cv ? { label: "CV", href: profile.links.cv, note: "Public CV." } : null
].filter(Boolean) as Array<{ label: string; href: string; note: string }>;
---

<BaseLayout title="Contact" description="Public contact links for Gnaroshi.">
  <header class="page-header">
    <p class="eyebrow">Contact</p>
    <h1>Public links and collaboration</h1>
    <p class="lede">
      I am interested in research workflows, AI systems, paper reading tools, and software that helps people think clearly.
    </p>
  </header>

  <section class="section" aria-labelledby="collaboration-heading">
    <SectionHeader
      id="collaboration-heading"
      title="Collaboration note"
      description="The public contact surface is intentionally small for now. GitHub is the best place to start."
    />
  </section>

  <section class="section" aria-labelledby="links-heading">
    <SectionHeader id="links-heading" title="Links" description="Public places to follow the work." />
    <div class="timeline-list">
      {contactLinks.map((link) => (
        <Card title={link.label} description={link.note}>
          <ExternalLink href={link.href}>{link.label}</ExternalLink>
        </Card>
      ))}
    </div>
  </section>
</BaseLayout>

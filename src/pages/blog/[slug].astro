---
import { render } from "astro:content";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import {
  getAdjacentPosts,
  getBuildableBlogPosts,
  getPublishedBlogPosts,
  getSeriesPosts,
  type BlogPost
} from "../../utils/content";

export async function getStaticPaths() {
  const posts = await getBuildableBlogPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const posts = await getPublishedBlogPosts();
const { Content, headings } = await render(post);
const seriesPosts = getSeriesPosts(posts, post.data.series);
const { previous, next } = getAdjacentPosts(posts, post);
---

<BlogPostLayout post={post} headings={headings} seriesPosts={seriesPosts} previous={previous} next={next}>
  <Content />
</BlogPostLayout>

---
import BlogPostView from "../../views/BlogPostView.astro";
import { getBuildableBlogPosts, getBlogPostSlug, type BlogPost } from "../../utils/content";
export async function getStaticPaths() { return (await getBuildableBlogPosts("en")).map((post) => ({ params: { slug: getBlogPostSlug(post) }, props: { post } })); }
interface Props { post: BlogPost }
const { post } = Astro.props;
---
<BlogPostView locale="en" post={post} />

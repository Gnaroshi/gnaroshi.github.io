---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import { formatMetricLabel, getAllWeeklyReviews } from "../../utils/weeklyReviews";

const reviews = getAllWeeklyReviews();
const latestReview = reviews[0];
const meaningfulReviews = reviews.filter((review) => (review.meaningfulEventCount ?? 0) >= 2);
const latestMeaningfulReview = meaningfulReviews[0];
---

<BaseLayout title="Weekly Research Reviews" description="Weekly summaries of papers, writing, reviews, and implementation progress." width="wide" mode="application">
  <header class="page-header">
    <p class="eyebrow">Weekly review</p>
    <h1>Research weeks</h1>
    <p class="lede">
      A compact weekly loop for seeing what moved, what stayed open, and what should get attention next.
    </p>
  </header>

  {latestReview?.status === "in-progress" && (
    <section class="weekly-progress-state" aria-labelledby="current-week-heading">
      <p class="eyebrow">{latestReview.weekId}</p>
      <h2 id="current-week-heading">In progress</h2>
      <p>{latestReview.summary}</p>
      <a href="/papers#new-paper-template">Record a meaningful event</a>
    </section>
  )}

  {latestMeaningfulReview && (
    <section class="section" aria-labelledby="latest-week-heading">
      <SectionHeader id="latest-week-heading" title="Latest completed week" description={`${latestMeaningfulReview.startDate} to ${latestMeaningfulReview.endDate}`} />
      <article class="weekly-review-card weekly-review-card--featured">
        <div>
          <p class="eyebrow">{latestMeaningfulReview.weekId}</p>
          <h2><a href={`/week/${latestMeaningfulReview.weekId}/`}>{latestMeaningfulReview.summary}</a></h2>
        </div>
        <div class="weekly-review-metrics">
          {Object.entries(latestMeaningfulReview.metrics).map(([key, value]) => (
            <span><strong>{value}</strong>{formatMetricLabel(key)}</span>
          ))}
        </div>
        <p><strong>Next focus:</strong> {latestMeaningfulReview.nextWeekFocus}</p>
      </article>
    </section>
  )}

  <section class="section" aria-labelledby="weekly-list-heading">
    <SectionHeader
      id="weekly-list-heading"
      title="Review archive"
      description="A record of weekly research loops across reading, writing, review, and implementation."
    >
      <a slot="action" href="/graph">Research graph</a>
    </SectionHeader>
    {meaningfulReviews.length > 0 ? (
      <div class="weekly-review-list">
        {meaningfulReviews.map((review) => (
          <article class="weekly-review-card">
            <div>
              <p class="eyebrow">{review.weekId}</p>
              <h2><a href={`/week/${review.weekId}/`}>{review.summary}</a></h2>
              <p class="metadata">{review.startDate} to {review.endDate}</p>
            </div>
            {review.weakestDimension && <p><strong>Weak loop:</strong> {review.weakestDimension}</p>}
          </article>
        ))}
      </div>
    ) : (
      <div class="app-empty-state">
        <h2>No completed weekly review yet</h2>
        <p>A completed week needs at least two meaningful reading, retrieval, revisit, implementation, or substantive writing events.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .weekly-progress-state {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    border-left: 3px solid var(--color-review-due);
    background: var(--color-surface-quiet);
  }
  .weekly-progress-state p { color: var(--color-text-secondary); }
</style>

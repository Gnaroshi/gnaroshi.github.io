---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import { formatMetricLabel, getAllWeeklyReviews, type WeeklyReview } from "../../utils/weeklyReviews";

export async function getStaticPaths() {
  return getAllWeeklyReviews().map((review) => ({
    params: { weekId: review.weekId },
    props: { review }
  }));
}

interface Props {
  review: WeeklyReview;
}

const { review } = Astro.props as Props;
---

<BaseLayout title={review.weekId} description={review.summary} canonical={`/week/${review.weekId}/`} mode="application">
  <article class="paper-detail">
    <header class="paper-detail-header">
      <a class="paper-detail-header__back" href="/week/">Back to weekly reviews</a>
      <div class="paper-detail-header__title">
        <p class="eyebrow">Weekly review</p>
        <h1>{review.weekId}</h1>
        <p class="lede">{review.summary}</p>
        {review.status === "in-progress" && <span class="paper-badge paper-badge--review-due">In progress</span>}
      </div>
      <p class="paper-detail-header__meta">{review.startDate} to {review.endDate}</p>
    </header>

    {(review.meaningfulEventCount ?? 0) >= 2 && <section class="paper-stats" aria-label="Weekly metrics">
      {Object.entries(review.metrics).map(([key, value]) => (
        <article class="paper-stat-card">
          <strong>{value}</strong>
          <span>{formatMetricLabel(key)}</span>
        </article>
      ))}
    </section>}

    {(review.meaningfulEventCount ?? 0) >= 2 ? <section class="section" aria-labelledby="weekly-progress-heading">
      <SectionHeader id="weekly-progress-heading" title="Progress summary" />
      <div class="paper-detail-grid">
        <div>
          <h2>Strongest loop</h2>
          <p>{review.strongestDimension}</p>
        </div>
        <div>
          <h2>Weakest loop</h2>
          <p>{review.weakestDimension}</p>
        </div>
        <div>
          <h2>Next week focus</h2>
          <p>{review.nextWeekFocus}</p>
        </div>
      </div>
    </section> : (
      <section class="app-empty-state" aria-labelledby="weekly-progress-heading">
        <h2 id="weekly-progress-heading">This review is still collecting evidence</h2>
        <p>Strongest and weakest dimensions remain hidden until at least two meaningful events support the comparison.</p>
        <a href="/papers#new-paper-template">Record the next event</a>
      </section>
    )}

    {review.wins.length > 0 && <section class="section" aria-labelledby="weekly-wins-heading">
      <SectionHeader id="weekly-wins-heading" title="Recent wins" />
      <ul class="list">
        {review.wins.map((win) => <li class="list-item"><p>{win}</p></li>)}
      </ul>
    </section>}

    {review.openLoops.length > 0 && <section class="section" aria-labelledby="weekly-open-loops-heading">
      <SectionHeader id="weekly-open-loops-heading" title="Open loops" />
      <ul class="list">
        {review.openLoops.map((loop) => <li class="list-item"><p>{loop}</p></li>)}
      </ul>
    </section>}

    {review.featuredItems.length > 0 && (
      <section class="section" aria-labelledby="weekly-featured-heading">
        <SectionHeader id="weekly-featured-heading" title="Featured items" />
        <div class="card-list">
          {review.featuredItems.map((item) => (
            <article class="weekly-featured-item">
              <span class="paper-badge paper-badge--muted">{item.type}</span>
              <a href={item.href}>{item.title}</a>
            </article>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

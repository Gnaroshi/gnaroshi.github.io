---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import ResearchGraphExplorer from "../../components/graph/ResearchGraphExplorer";
import { researchGraph } from "../../utils/researchGraph";
import { evidenceGates } from "../../config/evidenceGates";

const generatedAt = new Date(researchGraph.generatedAt).toLocaleString("en", {
  dateStyle: "medium",
  timeStyle: "short"
});
const graphReady = Boolean(
  researchGraph.eligible ??
  ((researchGraph.stats.meaningfulNodeCount ?? 0) >= evidenceGates.researchGraph.minimumMeaningfulNodes &&
    (researchGraph.stats.nonTagEdgeCount ?? 0) >= evidenceGates.researchGraph.minimumNonTagEdges)
);
---

<BaseLayout
  title="Research Graph"
  description="A static graph connecting papers, posts, projects, implementations, questions, topics, formulas, and weekly reviews."
  width="dashboard"
  mode="application"
>
  <div class="paper-dashboard">
    <header class="paper-hero">
      <div class="paper-hero__copy">
        <p class="eyebrow">Research graph</p>
        <h1>Connected research outputs</h1>
        <p class="lede">
          A map of how reading notes, blog posts, implementation attempts, projects, questions, formulas, and weekly reviews relate.
        </p>
      </div>
      <a class="button button--primary" href={graphReady ? "#graph-explorer" : "/papers#new-paper-template"}>
        {graphReady ? "Explore connections" : "Add meaningful evidence"}
      </a>
    </header>

    {graphReady ? <>
    <section class="paper-stats" aria-label="Graph stats">
      <article class="paper-stat-card">
        <strong>{researchGraph.stats.nodeCount}</strong>
        <span>Nodes</span>
      </article>
      <article class="paper-stat-card">
        <strong>{researchGraph.stats.edgeCount}</strong>
        <span>Relations</span>
      </article>
      <article class="paper-stat-card">
        <strong>{Object.keys(researchGraph.stats.nodesByType).length}</strong>
        <span>Node types</span>
      </article>
      <article class="paper-stat-card">
        <strong>{generatedAt}</strong>
        <span>Updated</span>
      </article>
    </section>

    <section class="section" aria-labelledby="graph-model-heading">
      <SectionHeader
        id="graph-model-heading"
        title="Graph model"
        description="A connected view of papers, notes, projects, implementation attempts, questions, and weekly reviews."
      />
      <div class="graph-type-grid">
        {Object.entries(researchGraph.stats.nodesByType).map(([type, count]) => (
          <article class="graph-type-card">
            <strong>{type.replaceAll("-", " ")}</strong>
            <span>{count}</span>
          </article>
        ))}
      </div>
    </section>

    <div id="graph-explorer"><ResearchGraphExplorer client:visible graph={researchGraph} /></div>
    <noscript>
      <section class="section" aria-labelledby="graph-fallback-heading">
        <SectionHeader
          id="graph-fallback-heading"
          title="Research graph index"
          description="Open any node directly when interactive filtering is unavailable."
        />
        <ul class="list">
          {researchGraph.nodes.map((node) => (
            <li class="list-item">
              <a href={`/graph/${node.type}/${node.slug}/`}>{node.label}</a>
            </li>
          ))}
        </ul>
      </section>
    </noscript>
    </> : (
      <section class="app-empty-state" aria-labelledby="graph-onboarding-heading">
        <p class="eyebrow">Graph state</p>
        <h2 id="graph-onboarding-heading">The research graph is not ready yet</h2>
        <p>
          A public graph will appear after at least {evidenceGates.researchGraph.minimumMeaningfulNodes} meaningful items
          form {evidenceGates.researchGraph.minimumNonTagEdges} direct research connections. Seed posts and isolated tags do not count.
        </p>
        <a class="button button--primary" href="/papers#new-paper-template">Add meaningful evidence</a>
      </section>
    )}
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { researchAreas } from "../data/research";
---

<BaseLayout title="Research" description="Current research questions, hypotheses, reading directions, and open uncertainty." width="wide">
  <header class="editorial-page-header">
    <p class="eyebrow">Research</p>
    <h1>Questions under active investigation</h1>
    <p class="lede">
      My current work sits around {profile.interests.slice(0, 3).join(", ").toLowerCase()}, with an emphasis on questions that can connect reading to software and evidence.
    </p>
  </header>

  <div class="research-area-list">
    {researchAreas.map((area, index) => (
      <article id={area.slug} class="research-area">
        <header>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h2>{area.question}</h2>
          <p>{area.motivation}</p>
        </header>
        <dl>
          <div><dt>Current hypothesis</dt><dd>{area.hypothesis}</dd></div>
          <div><dt>Current reading</dt><dd>{area.currentReading}</dd></div>
          <div><dt>Current build</dt><dd>{area.currentBuild}</dd></div>
          <div><dt>Open uncertainty</dt><dd>{area.uncertainty}</dd></div>
        </dl>
        <div class="research-area__links" aria-label={`Related work for ${area.question}`}>
          {area.related.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .editorial-page-header {
    display: grid;
    max-width: 52rem;
    gap: var(--space-4);
    padding: var(--space-7) 0 var(--space-8);
  }

  .research-area-list { display: grid; }
  .research-area { display: grid; grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1.25fr); gap: var(--space-7); padding: var(--space-7) 0; border-top: 1px solid var(--color-border); }
  .research-area header { display: grid; gap: var(--space-3); align-content: start; }
  .research-area header > span { color: var(--color-text-muted); font-family: var(--font-mono); font-size: var(--text-xs); }
  .research-area header p { color: var(--color-text-secondary); line-height: 1.75; }
  .research-area dl { display: grid; margin: 0; }
  .research-area dl > div { display: grid; grid-template-columns: 10rem minmax(0, 1fr); gap: var(--space-4); padding: var(--space-4) 0; border-top: 1px solid var(--color-border); }
  .research-area dt { color: var(--color-text-muted); font-size: var(--text-sm); font-weight: 700; }
  .research-area dd { margin: 0; color: var(--color-text-secondary); }
  .research-area__links { grid-column: 2; display: flex; flex-wrap: wrap; gap: var(--space-4); }

  @media (max-width: 760px) {
    .research-area { grid-template-columns: 1fr; gap: var(--space-5); }
    .research-area__links { grid-column: auto; }
  }
  @media (max-width: 520px) {
    .research-area dl > div { grid-template-columns: 1fr; gap: var(--space-2); }
  }
</style>

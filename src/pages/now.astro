---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import { now } from "../data/now";
---

<BaseLayout title="Now" description="Current focus, current reading, and current projects.">
  <header class="page-header">
    <p class="eyebrow">Now</p>
    <h1>Current focus</h1>
    <p class="lede">What I am reading, building, and trying to clarify. Last updated {now.lastUpdated}.</p>
  </header>

  <section class="section" aria-labelledby="reading-heading">
    <SectionHeader id="reading-heading" title="Currently reading" description="Reading topics and paper-log setup work." />
    <ul class="list">{now.currentlyReading.map((item) => <li class="list-item"><p>{item}</p></li>)}</ul>
  </section>

  <section class="section" aria-labelledby="building-heading">
    <SectionHeader id="building-heading" title="Currently building" description="Active project and infrastructure work." />
    <ul class="list">{now.currentlyBuilding.map((item) => <li class="list-item"><p>{item}</p></li>)}</ul>
  </section>

  <section class="section" aria-labelledby="questions-heading">
    <SectionHeader id="questions-heading" title="Current research questions" description="Questions that should influence future notes and project writeups." />
    <ul class="list">
      {now.currentQuestions.map((question) => (
        <li class="list-item">
          <p>{question}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

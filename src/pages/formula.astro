---
import BaseLayout from "../layouts/BaseLayout.astro";
import FormulaRecallTrainer from "../components/formula/FormulaRecallTrainer";
import { getPublishedPapers, getTodayKey } from "../utils/papers";
import { hasFormulaRecallMaterial, toFormulaRecallRecord } from "../utils/formulaRecall";

const papers = (await getPublishedPapers()).filter(hasFormulaRecallMaterial).map(toFormulaRecallRecord);
const today = getTodayKey();
---

<BaseLayout title="Formula Recall" description="Reconstruct paper formulas from memory before revealing the saved note." width="dashboard" mode="application">
  <div class="paper-dashboard">
    <header class="paper-hero">
      <div class="paper-hero__copy">
        <p class="eyebrow">Recall trainer</p>
        <h1>Formula Recall Trainer</h1>
        <p class="lede">Practice reconstructing formulas and interpretations from memory instead of only recognizing them.</p>
      </div>
      <a class="button button--primary" href={papers.length > 0 ? "#formula-session" : "/papers#new-paper-template"}>
        {papers.length > 0 ? "Start recall" : "Add a formula note"}
      </a>
    </header>
    {papers.length > 0 ? (
      <div id="formula-session"><FormulaRecallTrainer client:visible papers={papers} today={today} /></div>
    ) : (
      <section class="app-empty-state" aria-labelledby="formula-empty-heading">
        <p class="eyebrow">Recall state</p>
        <h2 id="formula-empty-heading">No saved formula to reconstruct</h2>
        <p>Add a main formula or recall prompt to a paper note. The trainer will hide the answer until you choose to reveal it.</p>
        <a class="button button--primary" href="/papers#new-paper-template">Add a formula note</a>
      </section>
    )}
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getActiveQuestions } from "../utils/questionBank";
import "../styles/application.css";
import "../styles/papers.css";
interface Props { locale: Locale }
const { locale } = Astro.props;
const questions = getActiveQuestions().filter((question) => (question as { locale?: Locale }).locale ? (question as { locale?: Locale }).locale === locale : locale === "en");
---
<BaseLayout locale={locale} title={translate(locale, "paperLab.questionBank")} description={translate(locale, "questions.subtitle")} width="dashboard" mode="application">
  <div class="paper-dashboard"><header class="paper-hero"><div class="paper-hero__copy"><p class="eyebrow">{translate(locale, "paperLab.questionBank")}</p><h1>{translate(locale, "questions.title")}</h1><p class="lede">{translate(locale, "questions.subtitle")}</p></div></header>
    {questions.length > 0 ? <section class="paper-note-list" aria-label={translate(locale, "paperLab.questionBank")}>{questions.map((question) => <article><p class="eyebrow">{question.type}</p><h2><a href={getLocalePath(locale, `/questions/${question.id}/`)}>{question.question}</a></h2><p class="metadata">{locale === "ko" ? "난이도" : "Difficulty"} {question.difficulty}/5</p></article>)}</section> : <section class="app-empty-state" aria-labelledby="questions-empty"><h2 id="questions-empty">{translate(locale, "questions.empty")}</h2><p>{translate(locale, "questions.emptyBody")}</p><a class="button button--primary" href={getLocalePath(locale, "/papers/")}>{translate(locale, "questions.action")}</a></section>}
  </div>
</BaseLayout>

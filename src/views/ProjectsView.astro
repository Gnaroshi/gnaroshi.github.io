---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import PageShell from "../components/layout/PageShell.astro";
import { getLocalizedData } from "../data/locales";
import { mediaManifest } from "../data/mediaManifest";
import { formatLocalizedDate } from "../i18n/date";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
---

<BaseLayout locale={locale} title={translate(locale, "nav.projects")} description={translate(locale, "projects.intro")} width="wide">
  <PageShell class="projects-page">
    <PageHeader title={translate(locale, "projects.title")} description={translate(locale, "projects.intro")} />
    <section class="project-showcase" aria-labelledby="projects-heading">
      <h2 id="projects-heading" class="sr-only">{translate(locale, "projects.selected")}</h2>
      {data.projects.map((project) => <article id={project.slug} class="project-feature">
        <a class="project-feature__media media-frame" href={getLocalePath(locale, `/projects/${project.slug}/`)} aria-label={`${project.title}: ${translate(locale, "projects.caseStudy")}`}><img src={mediaManifest[project.artworkId].light} alt={mediaManifest[project.artworkId].alt[locale]} width="960" height="600" loading="lazy" decoding="async" /></a>
        <div class="project-feature__copy"><p class="eyebrow">{project.statusLabel} · {formatLocalizedDate(project.updatedAt, locale)}</p><h2><a href={getLocalePath(locale, `/projects/${project.slug}/`)}>{project.title}</a></h2><p>{project.summary}</p><ul class="tag-row" aria-label={project.title}>{project.tags.map((tag) => <li>{tag}</li>)}</ul><a class="text-link" href={getLocalePath(locale, `/projects/${project.slug}/`)}>{translate(locale, "projects.caseStudy")}</a></div>
      </article>)}
    </section>
  </PageShell>
</BaseLayout>

<style>
  .project-showcase { border-top: 1px solid var(--color-border); }
  .project-feature { display: grid; gap: var(--space-6); padding: var(--space-8) 0; }
  .project-feature__media { aspect-ratio: 16 / 10; }
  .project-feature__copy { display: grid; gap: var(--space-4); align-content: center; }
  .project-feature h2 a { color: var(--color-text); text-decoration: none; }
  .project-feature__copy > p:not(.eyebrow) { color: var(--color-text-secondary); font-size: var(--editorial-body); line-height: 1.7; }
  @media (min-width: 768px) { .project-feature { grid-template-columns: minmax(0, 1.2fr) minmax(260px, .8fr); gap: var(--space-8); } }
  @media (min-width: 1024px) { .project-feature { gap: var(--space-9); padding-block: var(--space-9); } }
</style>

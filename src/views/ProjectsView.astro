---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import PageShell from "../components/layout/PageShell.astro";
import ResponsiveImage from "../components/media/ResponsiveImage.astro";
import ApplicationRoleIcon from "../components/projects/ApplicationRoleIcon.astro";
import TechStackStrip from "../components/projects/TechStackStrip.astro";
import { getProjectMedia } from "../data/approvedMedia";
import { getApprovedProjectShowcase } from "../data/approvedProjectShowcases";
import { platformLabels } from "../data/facts/techCatalog";
import { projectFacts } from "../data/facts/projects";
import { getProjectStory, productStatusLabels } from "../data/projectStories";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";

interface Props { locale: Locale }
const { locale } = Astro.props;
const selected = projectFacts.filter((project) => project.portfolio === "selected-projects");
type ApplicationProject = Extract<(typeof projectFacts)[number], { kind: "application" }>;
const applications = projectFacts.filter((project): project is ApplicationProject => project.kind === "application");
const featured = applications.filter((project) => project.applicationFeatured);
const supporting = applications.filter((project) => !project.applicationFeatured);
type ApplicationGroup = ApplicationProject["applicationGroup"];
const applicationGroups: readonly ApplicationGroup[] = ["research-workflow", "system-utilities", "learning-tools"];
const labels = locale === "ko" ? {
  selected:"선정 작업", featured:"대표 애플리케이션", featuredIntro:"연구 자료를 찾고 정리하고 발행하는 과정에서 직접 사용하는 도구입니다.", supporting:"보조 애플리케이션", supportingIntro:"실험 확인, 컴퓨팅 상태, 반복 학습을 각각 맡는 독립 도구입니다.", details:"자세히 보기", stack:"기술 구성", platforms:"지원 환경", role:"애플리케이션 역할",
  groups:{"research-workflow":"연구 작업 흐름","system-utilities":"시스템 도구","learning-tools":"학습 도구"}
} : {
  selected:"Selected projects", featured:"Featured applications", featuredIntro:"Tools I use to find, organize, and publish research material.", supporting:"Supporting applications", supportingIntro:"Focused tools for inspecting experiments, compute state, and repeated practice.", details:"View details", stack:"Tech stack", platforms:"Platforms", role:"Application role",
  groups:{"research-workflow":"Research workflow","system-utilities":"System utilities","learning-tools":"Learning tools"}
};
---

<BaseLayout locale={locale} title={translate(locale, "nav.projects")} description={translate(locale, "projects.intro")} width="wide">
  <PageShell class="projects-page">
    <PageHeader title={translate(locale, "projects.title")} description={translate(locale, "projects.intro")} />

    <section class="project-section" aria-labelledby="selected-projects-heading">
      <header class="section-heading"><p class="eyebrow">{labels.selected}</p><h2 id="selected-projects-heading">{locale === "ko" ? "연구와 공개 시스템" : "Research and public systems"}</h2></header>
      <div class="selected-list">
        {selected.map((project) => { const story = getProjectStory(locale, project.id); const media = getProjectMedia(project.id)!; return <article class="selected-project" data-project-id={project.id}>
          <a class="selected-project__media" href={getLocalePath(locale, `/projects/${project.slug}/`)} tabindex="-1" aria-hidden="true" style={`aspect-ratio:${media.width}/${media.height}`}><ResponsiveImage asset={media} locale={locale} sizes="(min-width: 1024px) 58vw, 100vw"/></a>
          <div class="selected-project__copy"><p class="project-meta">{productStatusLabels[locale][project.productStatus]}</p><h3><a href={getLocalePath(locale, `/projects/${project.slug}/`)}>{story.title}</a></h3><p data-card-summary>{story.cardSummary}</p><TechStackStrip ids={project.techStack} max={4} label={labels.stack}/><a class="text-link" href={getLocalePath(locale, `/projects/${project.slug}/`)}>{labels.details}</a></div>
        </article>})}
      </div>
    </section>

    <section class="project-section" aria-labelledby="featured-applications-heading">
      <header class="section-heading"><p class="eyebrow">{labels.featured}</p><h2 id="featured-applications-heading">{locale === "ko" ? "연구 작업 공간" : "Research workspaces"}</h2><p>{labels.featuredIntro}</p></header>
      <div class="featured-apps" data-application-group="research-workflow">
        {featured.map((project) => { const story = getProjectStory(locale, project.id); const media = getApprovedProjectShowcase(project.primaryShowcaseId)!; return <article class="featured-app" data-project-id={project.id}>
          <a class="featured-app__media" href={getLocalePath(locale, `/projects/${project.slug}/`)} tabindex="-1" aria-hidden="true" style={`aspect-ratio:${media.width}/${media.height}`}><ResponsiveImage asset={media} locale={locale} sizes="(min-width: 1100px) 42vw, 100vw"/></a>
          <div class="featured-app__copy"><div class="app-title"><ApplicationRoleIcon role={project.applicationGroup} projectId={project.id} label={`${story.title} ${labels.role}`}/><div><p class="project-meta">{productStatusLabels[locale][project.productStatus]} · {project.platforms.map((id) => platformLabels[id][locale]).join(" · ")}</p><h3><a href={getLocalePath(locale, `/projects/${project.slug}/`)}>{story.title}</a></h3></div></div><p data-card-summary>{story.cardSummary}</p><TechStackStrip ids={project.techStack} max={4} label={labels.stack}/><a class="text-link" href={getLocalePath(locale, `/projects/${project.slug}/`)}>{labels.details}</a></div>
        </article>})}
      </div>
    </section>

    <section class="project-section" aria-labelledby="supporting-applications-heading">
      <header class="section-heading"><p class="eyebrow">{labels.supporting}</p><h2 id="supporting-applications-heading">{locale === "ko" ? "집중 도구" : "Focused utilities"}</h2><p>{labels.supportingIntro}</p></header>
      <div class="supporting-apps">
        {applicationGroups.map((group) => {
          const groupedProjects = supporting.filter((project) => project.applicationGroup === group);
          if (groupedProjects.length === 0) return null;
          return <section class="supporting-app-group" data-application-group={group} aria-labelledby={`supporting-${group}-heading`}>
            <h3 id={`supporting-${group}-heading`} class="purpose-label">{labels.groups[group]}</h3>
            {groupedProjects.map((project) => { const story = getProjectStory(locale, project.id); return <article class="supporting-app" data-project-id={project.id}><div class="app-title"><ApplicationRoleIcon role={project.applicationGroup} projectId={project.id} label={`${story.title} ${labels.role}`}/><div><p class="project-meta">{productStatusLabels[locale][project.productStatus]}</p><h4><a href={getLocalePath(locale, `/projects/${project.slug}/`)}>{story.title}</a></h4></div></div><p data-card-summary>{story.cardSummary}</p><p class="platform-list"><span>{labels.platforms}</span> {project.platforms.map((id) => platformLabels[id][locale]).join(" · ")}</p><TechStackStrip ids={project.techStack} max={3} label={labels.stack}/><a class="text-link" href={getLocalePath(locale, `/projects/${project.slug}/`)}>{labels.details}</a></article>})}
          </section>;
        })}
      </div>
    </section>
  </PageShell>
</BaseLayout>

<style>
  .projects-page{display:grid;gap:var(--space-10)} .project-section{display:grid;gap:var(--space-6);padding-top:var(--space-8);border-top:1px solid var(--color-border)}
  .section-heading{display:grid;gap:var(--space-3);max-width:72ch}.section-heading>p:not(.eyebrow){color:var(--color-text-secondary);line-height:1.7}
  .selected-list,.featured-apps{display:grid;gap:var(--space-8)} .selected-project,.featured-app{display:grid;gap:var(--space-6);align-items:center}
  .selected-project__media,.featured-app__media{display:block;min-width:0;overflow:hidden;border:var(--pixel-border) solid var(--color-border);background:var(--color-surface);box-shadow:var(--shadow-sm)}
  .selected-project__media :global(.responsive-media),.featured-app__media :global(.responsive-media){width:100%;height:100%}.selected-project__media :global(img),.featured-app__media :global(img){object-fit:contain}
  .selected-project__copy,.featured-app__copy,.supporting-app{display:grid;gap:var(--space-4);align-content:start;min-width:0}.featured-app__copy,.supporting-app{border-top:var(--pixel-border) solid var(--app-key,var(--color-border));padding-top:var(--space-4)}.selected-project__copy>p:not(.project-meta),.featured-app__copy>p,.supporting-app>p{color:var(--color-text-secondary);line-height:1.68}
  h3 a,h4 a{color:var(--color-text);text-decoration:none}.project-meta{color:var(--color-text-secondary);font-size:var(--step--1);font-weight:650;text-transform:uppercase;letter-spacing:.05em}
  .app-title{display:flex;gap:var(--space-3);align-items:center;min-width:0}.app-title>div{min-width:0}.app-title h3,.app-title h4{margin-top:.2rem}
  .supporting-apps{display:grid;gap:var(--space-6)}.supporting-app-group{display:grid;gap:var(--space-3);min-width:0}.purpose-label{color:var(--color-accent);font-size:var(--step--1);font-weight:700}.supporting-app{display:grid;gap:var(--space-4);align-content:start;min-width:0;padding-block:var(--space-5);border-top:1px solid var(--color-border)}.platform-list{font-size:var(--step--1)}.platform-list span{color:var(--color-text);font-weight:650}
  @media(min-width:768px){.selected-project,.featured-app{grid-template-columns:minmax(0,1.15fr) minmax(17rem,.85fr);gap:var(--space-8)}.selected-project:nth-child(even)>:first-child{order:2}.supporting-apps{grid-template-columns:repeat(3,minmax(0,1fr));gap:var(--space-6)}}
  @media(min-width:1100px){.featured-apps{grid-template-columns:repeat(2,minmax(0,1fr));gap:var(--space-7)}.featured-app{grid-template-columns:1fr}.featured-app:first-child{grid-column:1/-1;grid-template-columns:minmax(0,1.25fr) minmax(20rem,.75fr)}}
</style>

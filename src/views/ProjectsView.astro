---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import PageShell from "../components/layout/PageShell.astro";
import ResponsiveImage from "../components/media/ResponsiveImage.astro";
import FeaturedApplicationCard from "../components/projects/FeaturedApplicationCard.astro";
import ProjectCardHeader from "../components/projects/ProjectCardHeader.astro";
import SupportingApplicationCard from "../components/projects/SupportingApplicationCard.astro";
import TechStackStrip from "../components/projects/TechStackStrip.astro";
import { getProjectMedia } from "../data/approvedMedia";
import { getApprovedProjectShowcase } from "../data/approvedProjectShowcases";
import { platformLabels } from "../data/facts/techCatalog";
import { projectFacts } from "../data/facts/projects";
import { getProjectStory, productStatusLabels } from "../data/projectStories";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import "../styles/projects.css";

interface Props { locale: Locale }
const { locale } = Astro.props;
const selected = projectFacts.filter((project) => project.portfolio === "selected-projects");
type ApplicationProject = Extract<(typeof projectFacts)[number], { kind: "application" }>;
const applications = projectFacts.filter((project): project is ApplicationProject => project.kind === "application");
const featured = applications.filter((project) => project.applicationFeatured);
const featuredLead = featured[0];
const featuredPair = featured.slice(1);
const supporting = applications.filter((project) => !project.applicationFeatured);
type ApplicationGroup = ApplicationProject["applicationGroup"];
const applicationGroups: readonly ApplicationGroup[] = ["research-workflow", "system-utilities", "learning-tools"];
const labels = locale === "ko" ? {
  selected:"선정 작업", featured:"대표 애플리케이션", featuredIntro:"연구 자료를 찾고 정리하고 발행하는 과정에서 직접 사용하는 도구입니다.", supporting:"보조 애플리케이션", supportingIntro:"실험 확인, 컴퓨팅 상태, 반복 학습을 각각 맡는 독립 도구입니다.", details:"자세히 보기", stack:"기술 구성", platforms:"지원 환경",
  sections:"프로젝트 구역", evidence:"검증된 프로젝트 자료",
  groups:{"research-workflow":"연구 작업 흐름","system-utilities":"시스템 도구","learning-tools":"학습 도구"}
} : {
  selected:"Selected projects", featured:"Featured applications", featuredIntro:"Tools I use to find, organize, and publish research material.", supporting:"Supporting applications", supportingIntro:"Focused tools for inspecting experiments, compute state, and repeated practice.", details:"View details", stack:"Tech stack", platforms:"Platforms",
  sections:"Project sections", evidence:"Verified project evidence",
  groups:{"research-workflow":"Research workflow","system-utilities":"System utilities","learning-tools":"Learning tools"}
};
---

<BaseLayout locale={locale} title={translate(locale, "nav.projects")} description={translate(locale, "projects.intro")} width="wide" pageProgress>
  <PageShell class="projects-page">
    <PageHeader title={translate(locale, "projects.title")} description={translate(locale, "projects.intro")} />

    <nav class="projects-overview" aria-label={labels.sections} data-in-page-navigation data-scroll-spy>
      <ol data-in-page-scroller>
        {[
          ["selected-projects", labels.selected],
          ["featured-applications", labels.featured],
          ["supporting-applications", labels.supporting]
        ].map(([id, label], index) => (
          <li>
            <a href={getLocalePath(locale, `/projects/#${id}`)} data-in-page-link data-motion-surface>
              <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>{label}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <section id="selected-projects" class="project-section project-section--selected" aria-labelledby="selected-projects-heading" tabindex="-1" data-in-page-section>
      <header class="section-heading"><p class="eyebrow">{labels.selected}</p><h2 id="selected-projects-heading">{locale === "ko" ? "연구와 공개 시스템" : "Research and public systems"}</h2></header>
      <div class="selected-list">
        {selected.map((project) => { const story = getProjectStory(locale, project.id); const media = getProjectMedia(project.id)!; const href = getLocalePath(locale, `/projects/${project.slug}/`); return <article class="selected-project" data-project-id={project.id} data-project-kind={project.kind} style={`--source-media-ratio:${media.width}/${media.height}`}>
          <figure class="selected-project__figure">
            <a class="selected-project__media" data-card-part="media" data-motion-media href={href}><ResponsiveImage asset={media} locale={locale} sizes="(min-width: 1024px) 58vw, 100vw"/></a>
            <figcaption><strong>{labels.evidence}</strong><span>{story.scenario.demoDisclosure}</span></figcaption>
          </figure>
          <div class="selected-project__copy"><ProjectCardHeader project={project} locale={locale} title={story.title} href={href}/><p class="project-meta" data-card-part="meta">{productStatusLabels[locale][project.productStatus]} · {project.platforms.map((id) => platformLabels[id][locale]).join(" · ")}</p><p data-card-part="summary" data-card-summary>{story.cardSummary}</p><TechStackStrip ids={project.techStack} max={4} label={labels.stack}/></div>
        </article>})}
      </div>
    </section>

    <section id="featured-applications" class="project-section project-section--featured" aria-labelledby="featured-applications-heading" tabindex="-1" data-in-page-section>
      <header class="section-heading"><p class="eyebrow">{labels.featured}</p><h2 id="featured-applications-heading">{locale === "ko" ? "연구 작업 공간" : "Research workspaces"}</h2><p>{labels.featuredIntro}</p></header>
      <div class="featured-apps" data-application-group="research-workflow">
        {featuredLead && <FeaturedApplicationCard project={featuredLead} story={getProjectStory(locale, featuredLead.id)} media={getApprovedProjectShowcase(featuredLead.primaryShowcaseId)!} locale={locale} href={getLocalePath(locale, `/projects/${featuredLead.slug}/`)} stackLabel={labels.stack} lead/>}
        <div class="featured-app-pair">
          {featuredPair.map((project) => <FeaturedApplicationCard project={project} story={getProjectStory(locale, project.id)} media={getApprovedProjectShowcase(project.primaryShowcaseId)!} locale={locale} href={getLocalePath(locale, `/projects/${project.slug}/`)} stackLabel={labels.stack}/>)}
        </div>
      </div>
    </section>

    <section id="supporting-applications" class="project-section project-section--supporting" aria-labelledby="supporting-applications-heading" tabindex="-1" data-in-page-section>
      <header class="section-heading"><p class="eyebrow">{labels.supporting}</p><h2 id="supporting-applications-heading">{locale === "ko" ? "집중 도구" : "Focused utilities"}</h2><p>{labels.supportingIntro}</p></header>
      <div class="supporting-apps">
        {applicationGroups.flatMap((group) => supporting.filter((project) => project.applicationGroup === group).map((project) => <SupportingApplicationCard project={project} story={getProjectStory(locale, project.id)} locale={locale} href={getLocalePath(locale, `/projects/${project.slug}/`)} groupLabel={labels.groups[group]} stackLabel={labels.stack} platformsLabel={labels.platforms}/>))}
      </div>
    </section>
  </PageShell>
</BaseLayout>

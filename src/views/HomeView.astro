---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvidenceGate from "../components/growth/EvidenceGate.astro";
import Hero from "../components/home/Hero.astro";
import ExternalLink from "../components/common/ExternalLink.astro";
import { getLocalizedData } from "../data/locales";
import { profile } from "../data/profile";
import { formatLocalizedDate } from "../i18n/date";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getBlogPostHref, getPublishedBlogPosts } from "../utils/content";
import { getEvidenceEligibility } from "../utils/evidenceEligibility";
import { getMomentumInput } from "../utils/momentumData";
import { getPublishedPapers } from "../utils/papers";
import "../styles/home.css";

interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
const [papers, posts, momentumInput] = await Promise.all([
  getPublishedPapers(locale),
  getPublishedBlogPosts(locale),
  getMomentumInput()
]);
const eligibility = getEvidenceEligibility(momentumInput);
const recentPosts = posts.slice(0, 3);
const recentPapers = papers.slice(0, 2);
const selectedProject = data.projects.find((project) => project.featured) ?? data.projects[0];
const publicLinks = [
  { label: "GitHub", href: profile.links.github },
  profile.links.scholar ? { label: "Google Scholar", href: profile.links.scholar } : null,
  profile.links.cv ? { label: "CV", href: profile.links.cv } : null,
  profile.links.email ? { label: "Email", href: `mailto:${profile.links.email}` } : null
].filter(Boolean) as Array<{ label: string; href: string }>;
---

<BaseLayout locale={locale} title={translate(locale, "home.seoTitle")} description={translate(locale, "home.seoDescription")} absoluteTitle canonical={getLocalePath(locale, "/")} width="wide">
  <div class="home-editorial">
    <Hero locale={locale} />

    <section class="home-band home-focus" aria-labelledby="current-focus-heading">
      <header><p class="eyebrow">{translate(locale, "home.currentFocus")}</p><h2 id="current-focus-heading">{translate(locale, "home.questionsBeforeClaims")}</h2></header>
      <div class="home-focus__content">
        <div><h3>{translate(locale, "home.reading")}</h3><p>{data.now.currentlyReading[0]}</p></div>
        <div><h3>{translate(locale, "home.building")}</h3><p>{data.now.currentlyBuilding[0]}</p></div>
        <div><h3>{translate(locale, "home.selectedWork")}</h3><p>{selectedProject.summary}</p><a href={getLocalePath(locale, `/projects/${selectedProject.slug}/`)}>{translate(locale, "home.openCaseStudy")}</a></div>
      </div>
    </section>

    <section class="home-band home-activity" aria-labelledby="latest-work-heading">
      <header><p class="eyebrow">{translate(locale, "home.latestWork")}</p><h2 id="latest-work-heading">{translate(locale, "home.writingAndPapers")}</h2></header>
      <div class="home-activity__columns">
        <div>
          <div class="home-list-heading"><h3>{translate(locale, "nav.writing")}</h3><a href={getLocalePath(locale, "/blog/")}>{translate(locale, "home.allWriting")}</a></div>
          <ol class="editorial-record-list">{recentPosts.map((post) => <li><a href={getBlogPostHref(post)}>{post.data.title}</a><time datetime={post.data.pubDate.toISOString()}>{formatLocalizedDate(post.data.pubDate, locale)}</time></li>)}</ol>
        </div>
        <div>
          <div class="home-list-heading"><h3>{translate(locale, "home.paperNotes")}</h3><a href={getLocalePath(locale, "/papers/")}>{translate(locale, "nav.paperLab")}</a></div>
          {recentPapers.length > 0 ? <ol class="editorial-record-list">{recentPapers.map((paper) => <li><a href={getLocalePath(locale, `/papers/${paper.id}/`)}>{paper.data.title}</a><span>{translate(locale, `status.${paper.data.status}`)}</span></li>)}</ol> : <div class="home-onboarding"><p>{translate(locale, "home.firstPaperMessage")}</p><a href={getLocalePath(locale, "/papers/#new-paper-template")}>{translate(locale, "home.addFirstPaper")}</a></div>}
        </div>
      </div>
    </section>

    <section class="home-band home-cockpit-preview" aria-labelledby="cockpit-preview-heading">
      <header><p class="eyebrow">{translate(locale, "home.researchWorkspace")}</p><h2 id="cockpit-preview-heading">{translate(locale, "home.evidenceBeforeMetrics")}</h2><p>{translate(locale, "home.evidenceDescription")}</p></header>
      <EvidenceGate eligibility={eligibility} compact locale={locale} />
      <a class="button button--primary" href={getLocalePath(locale, "/papers/#new-paper-template")}>{translate(locale, "home.addFirstPaper")}</a>
    </section>

    <section class="home-band home-collaboration" aria-labelledby="collaboration-heading">
      <div><p class="eyebrow">{translate(locale, "home.collaboration")}</p><h2 id="collaboration-heading">{translate(locale, "home.collaborationTitle")}</h2><p>{translate(locale, "home.collaborationBody")}</p></div>
      <div class="home-collaboration__links">{publicLinks.map((link) => <ExternalLink href={link.href}>{link.label}</ExternalLink>)}<a href={getLocalePath(locale, "/about/")}>{translate(locale, "nav.about")}</a><a href={getLocalePath(locale, "/contact/")}>{translate(locale, "links.title")}</a></div>
    </section>
  </div>
</BaseLayout>

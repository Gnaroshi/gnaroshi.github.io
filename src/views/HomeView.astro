---
import BaseLayout from "../layouts/BaseLayout.astro";
import StructuredData from "../components/StructuredData.astro";
import Hero from "../components/home/Hero.astro";
import Section from "../components/layout/Section.astro";
import { getLocalizedData } from "../data/locales";
import { mediaManifest } from "../data/mediaManifest";
import { formatLocalizedDate } from "../i18n/date";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getBlogPostHref, getPublishedBlogPosts } from "../utils/content";
import { getPublishedPapers } from "../utils/papers";
import { profile } from "../data/profile";
import "../styles/home.css";

interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
const [papers, posts] = await Promise.all([getPublishedPapers(locale), getPublishedBlogPosts(locale)]);
const recentPosts = posts.slice(0, 3);
const recentPapers = papers.slice(0, 3);
const selectedProject = data.projects.find((project) => project.featured) ?? data.projects[0];
const projectArtwork = mediaManifest.projectGnaroshiDev;
const loopArtwork = mediaManifest.paperLabCycle;
---

<BaseLayout locale={locale} title={translate(locale, "home.seoTitle")} description={translate(locale, "home.seoDescription")} absoluteTitle canonical={getLocalePath(locale, "/")} width="wide" flush preloadHero>
  <StructuredData data={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": `${profile.domain}/#person`,
        name: profile.publicAlias,
        url: profile.domain,
        description: locale === "ko" ? data.profile.shortBio : profile.shortBio,
        jobTitle: locale === "ko" ? data.profile.currentRole : profile.currentRole,
        homeLocation: { "@type": "Country", name: profile.location },
        sameAs: [profile.links.github]
      },
      {
        "@type": "WebSite",
        "@id": `${profile.domain}/#website`,
        name: profile.siteName,
        url: profile.domain,
        inLanguage: ["en-US", "ko-KR"],
        publisher: { "@id": `${profile.domain}/#person` }
      },
      {
        "@type": "ProfilePage",
        "@id": `${new URL(getLocalePath(locale, "/"), profile.domain)}#profile`,
        url: new URL(getLocalePath(locale, "/"), profile.domain).toString(),
        mainEntity: { "@id": `${profile.domain}/#person` },
        isPartOf: { "@id": `${profile.domain}/#website` },
        inLanguage: locale === "ko" ? "ko-KR" : "en-US"
      }
    ]
  }} />
  <div class="home-editorial">
    <Hero locale={locale} />

    <Section class="home-selected" labelledby="selected-work-heading">
      <div class="home-section-heading"><p class="eyebrow">{translate(locale, "home.selectedWork")}</p><h2 id="selected-work-heading">{selectedProject.title}</h2></div>
      <article class="home-featured-project">
        <div class="home-featured-project__media media-frame"><img src={projectArtwork.light} alt={projectArtwork.alt[locale]} width="960" height="600" loading="lazy" decoding="async" /></div>
        <div class="home-featured-project__copy"><p>{selectedProject.summary}</p><ul class="tag-row" aria-label={selectedProject.title}>{selectedProject.tags.map((tag) => <li>{tag}</li>)}</ul><a class="text-link" href={getLocalePath(locale, `/projects/${selectedProject.slug}/`)}>{translate(locale, "home.openCaseStudy")}</a></div>
      </article>
    </Section>

    <Section class="home-notes" labelledby="latest-notes-heading">
      <div class="home-section-heading"><p class="eyebrow">{translate(locale, "home.latestWork")}</p><h2 id="latest-notes-heading">{translate(locale, "home.writingAndPapers")}</h2></div>
      <div class="home-notes__columns">
        <div><div class="home-list-heading"><h3>{translate(locale, "nav.writing")}</h3><a href={getLocalePath(locale, "/blog/")}>{translate(locale, "home.allWriting")}</a></div>{recentPosts.length > 0 ? <ol class="editorial-record-list">{recentPosts.map((post) => <li><a href={getBlogPostHref(post)}>{post.data.title}</a><time datetime={post.data.pubDate.toISOString()}>{formatLocalizedDate(post.data.pubDate, locale)}</time></li>)}</ol> : <p class="home-empty-note">{translate(locale, "writing.noPosts")}</p>}</div>
        <div><div class="home-list-heading"><h3>{translate(locale, "home.paperNotes")}</h3><a href={getLocalePath(locale, "/papers/")}>{translate(locale, "nav.paperLab")}</a></div>{recentPapers.length > 0 ? <ol class="editorial-record-list">{recentPapers.map((paper) => <li><a href={getLocalePath(locale, `/papers/${paper.data.canonicalSlug}/`)}>{paper.data.title}</a><span>{translate(locale, `status.${paper.data.status}`)}</span></li>)}</ol> : <p class="home-empty-note">{translate(locale, "home.noPaperNotes")}</p>}</div>
      </div>
    </Section>

    <Section class="home-loop" labelledby="research-loop-heading">
      <div class="home-loop__copy"><p class="eyebrow">{translate(locale, "home.researchWorkspace")}</p><h2 id="research-loop-heading">{translate(locale, "home.researchLoopTitle")}</h2><p>{translate(locale, "home.researchLoopBody")}</p><a class="button button--primary" href={getLocalePath(locale, "/papers/")}>{translate(locale, "nav.paperLab")}</a></div>
      <div class="home-loop__media media-frame"><img src={loopArtwork.light} alt={loopArtwork.alt[locale]} width="960" height="600" loading="lazy" decoding="async" /></div>
    </Section>
  </div>
</BaseLayout>

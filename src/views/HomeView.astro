---
import BaseLayout from "../layouts/BaseLayout.astro";
import StructuredData from "../components/StructuredData.astro";
import Hero from "../components/home/Hero.astro";
import Section from "../components/layout/Section.astro";
import SystemWorkflow from "../components/system/SystemWorkflow.astro";
import ResponsiveImage from "../components/media/ResponsiveImage.astro";
import { getProjectMedia } from "../data/approvedMedia";
import { getLocalizedData } from "../data/locales";
import { formatLocalizedDate } from "../i18n/date";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getBlogPostHref, getPublishedBlogPosts } from "../utils/content";
import { getPublishedPapers } from "../utils/papers";
import { currentFocusAgeDays, isCurrentFocusFresh } from "../utils/currentFocus";
import { profile } from "../data/profile";
import "../styles/home.css";

interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
const [papers, posts] = await Promise.all([getPublishedPapers(locale), getPublishedBlogPosts(locale)]);
const recentPosts = posts.filter((post) => post.data.contentStage === "substantive" && post.data.category !== "build-note").slice(0, 3);
const recentPapers = papers.filter((paper) => paper.data.contentStage === "substantive").slice(0, 3);
const selectedProject = data.projects.find((project) => project.portfolio === "selected-projects") ?? data.projects[0];
const selectedProjectMedia = getProjectMedia(selectedProject.id);
if (!selectedProjectMedia) throw new Error(`Featured project is missing approved media: ${selectedProject.id}`);
const focusIsFresh = isCurrentFocusFresh(data.now.lastUpdated);
if (!focusIsFresh && import.meta.env.DEV) {
  console.warn(`[current-focus] Hidden from Home because ${data.now.lastUpdated} is ${currentFocusAgeDays(data.now.lastUpdated)} days old.`);
}
---

<BaseLayout locale={locale} title={translate(locale, "home.seoTitle")} description={translate(locale, "home.seoDescription")} absoluteTitle canonical={getLocalePath(locale, "/")} width="wide" flush>
  <StructuredData data={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": `${profile.domain}/#person`,
        name: profile.publicAlias,
        url: profile.domain,
        description: data.profile.shortBio,
        sameAs: [profile.links.github]
      },
      {
        "@type": "WebSite",
        "@id": `${profile.domain}/#website`,
        name: profile.siteName,
        url: profile.domain,
        inLanguage: ["en-US", "ko-KR"],
        publisher: { "@id": `${profile.domain}/#person` }
      },
      {
        "@type": "ProfilePage",
        "@id": `${new URL(getLocalePath(locale, "/"), profile.domain)}#profile`,
        url: new URL(getLocalePath(locale, "/"), profile.domain).toString(),
        mainEntity: { "@id": `${profile.domain}/#person` },
        isPartOf: { "@id": `${profile.domain}/#website` },
        inLanguage: locale === "ko" ? "ko-KR" : "en-US"
      }
    ]
  }} />
  <div class="home-editorial">
    <Hero locale={locale} currentFocus={focusIsFresh ? data.now.currentlyBuilding[0] : undefined} />

    <Section class="home-research" labelledby="research-questions-heading">
      <div class="home-section-heading"><p class="eyebrow">{translate(locale, "home.researchQuestions")}</p><h2 id="research-questions-heading">{translate(locale, "home.researchQuestionsTitle")}</h2></div>
      <ol class="home-research-list">{data.researchAreas.map((area) => <li><a href={getLocalePath(locale, `/research/#${area.slug}`)}>{area.question}</a></li>)}</ol>
      <a class="text-link" href={getLocalePath(locale, "/research/")}>{translate(locale, "home.viewAllResearch")}</a>
    </Section>

    <Section class="home-selected" labelledby="selected-work-heading">
      <div class="home-section-heading"><p class="eyebrow">{translate(locale, "home.selectedWork")}</p><h2 id="selected-work-heading">{selectedProject.title}</h2></div>
      <article class="home-featured-project">
        <a class="home-featured-project__media" href={getLocalePath(locale, `/projects/${selectedProject.slug}/`)} tabindex="-1" aria-hidden="true">
          <ResponsiveImage asset={selectedProjectMedia} locale={locale} sizes="(min-width: 768px) 50vw, 100vw" />
        </a>
        <div class="home-featured-project__copy"><p>{selectedProject.summary}</p><ul class="tag-row" aria-label={selectedProject.title}>{selectedProject.tags.map((tag) => <li>{tag}</li>)}</ul><a class="text-link" href={getLocalePath(locale, `/projects/${selectedProject.slug}/`)}>{translate(locale, "home.openCaseStudy")}</a></div>
      </article>
    </Section>

    {(recentPosts.length > 0 || recentPapers.length > 0) && <Section class="home-notes" labelledby="latest-notes-heading">
      <div class="home-section-heading"><p class="eyebrow">{translate(locale, "home.latestWork")}</p><h2 id="latest-notes-heading">{translate(locale, "home.writingAndPapers")}</h2></div>
      <div class="home-notes__columns">
        {recentPosts.length > 0 && <div><div class="home-list-heading"><h3>{translate(locale, "nav.writing")}</h3><a href={getLocalePath(locale, "/blog/")}>{translate(locale, "home.allWriting")}</a></div><ol class="editorial-record-list">{recentPosts.map((post) => <li><a href={getBlogPostHref(post)}>{post.data.title}</a><time datetime={post.data.pubDate.toISOString()}>{formatLocalizedDate(post.data.pubDate, locale)}</time></li>)}</ol></div>}
        {recentPapers.length > 0 && <div><div class="home-list-heading"><h3>{translate(locale, "home.paperNotes")}</h3><a href={getLocalePath(locale, "/papers/")}>{translate(locale, "nav.paperLab")}</a></div><ol class="editorial-record-list">{recentPapers.map((paper) => <li><a href={getLocalePath(locale, `/papers/${paper.data.canonicalSlug}/`)}>{paper.data.title}</a><span>{translate(locale, `status.${paper.data.status}`)}</span></li>)}</ol></div>}
      </div>
    </Section>}

    <SystemWorkflow locale={locale} variant="compact" />
  </div>
</BaseLayout>

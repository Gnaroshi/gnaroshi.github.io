---
import BaseLayout from "../layouts/BaseLayout.astro";
import PaperDashboard from "../components/papers/PaperDashboard.astro";
import type { Locale } from "../i18n/types";
import { translate } from "../i18n/utils";
import { countPapersByDate, getPaperStats, getPublishedPapers, getTodayKey, normalizePaperTags } from "../utils/papers";
import { getPaperReviewStats, getPublicPaperReviewMap } from "../utils/paperReviews";
interface Props { locale: Locale }
const { locale } = Astro.props;
const papers = await getPublishedPapers(locale);
const today = getTodayKey();
const stats = getPaperStats(papers, today);
const countsByDate = countPapersByDate(papers, { includeDrafts: !import.meta.env.PROD });
const tags = normalizePaperTags(papers);
const reviewsBySlug = getPublicPaperReviewMap(papers);
const reviewStats = getPaperReviewStats(papers, reviewsBySlug, today);
---
<BaseLayout locale={locale} title={translate(locale, "papers.title")} description={translate(locale, "papers.subtitle")} width="dashboard" mode="application"><PaperDashboard papers={papers} stats={stats} countsByDate={countsByDate} tags={tags} today={today} reviewStats={reviewStats} reviewsBySlug={reviewsBySlug} locale={locale} /></BaseLayout>

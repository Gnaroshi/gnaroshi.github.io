---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocalizedData } from "../data/locales";
import { formatLocalizedDate } from "../i18n/date";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getCurrentFocusFreshness } from "../utils/currentFocus";
interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
const freshness = getCurrentFocusFreshness(data.now.lastUpdated);
const pageTitle = freshness.isFresh ? translate(locale, "now.title") : translate(locale, "now.staleTitle");
const description = freshness.isFresh ? data.now.currentlyBuilding[0] : translate(locale, "now.staleNotice");
---
<BaseLayout locale={locale} title={pageTitle} description={description}>
  <header class="page-header" data-current-focus-state={freshness.status}>
    <p class="eyebrow">{translate(locale, freshness.isFresh ? "now.eyebrow" : "now.staleEyebrow")}</p>
    <h1>{pageTitle}</h1>
    <p class="metadata">{translate(locale, "now.updated")} {formatLocalizedDate(data.now.lastUpdated, locale)}</p>
  </header>
  {!freshness.isFresh && (
    <aside class="now-freshness-notice" aria-labelledby="now-freshness-heading">
      <h2 id="now-freshness-heading">{translate(locale, "now.staleStatus")}</h2>
      <p>{translate(locale, "now.staleNotice")}</p>
      <a class="text-link" href={getLocalePath(locale, "/research/")}>{translate(locale, "now.staleNext")}</a>
    </aside>
  )}
  <section class="section"><h2>{translate(locale, freshness.isFresh ? "now.reading" : "now.staleReading")}</h2><ul>{data.now.currentlyReading.map((item) => <li>{item}</li>)}</ul></section>
  <section class="section"><h2>{translate(locale, freshness.isFresh ? "now.building" : "now.staleBuilding")}</h2><ul>{data.now.currentlyBuilding.map((item) => <li>{item}</li>)}</ul></section>
  <section class="section"><h2>{translate(locale, freshness.isFresh ? "now.questions" : "now.staleQuestions")}</h2><ul>{data.now.currentQuestions.map((item) => <li>{item}</li>)}</ul></section>
</BaseLayout>

<style>
  .now-freshness-notice { display:grid; gap:var(--space-3); padding:var(--space-5) 0; border-block:1px solid var(--color-border); }
  .now-freshness-notice h2 { font-size:var(--text-lg); }
  .now-freshness-notice p { max-width:62ch; color:var(--color-text-secondary); }
  .now-freshness-notice .text-link { width:fit-content; }
</style>

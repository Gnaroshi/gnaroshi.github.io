---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExternalLink from "../components/common/ExternalLink.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import PageShell from "../components/layout/PageShell.astro";
import { getLocalizedData } from "../data/locales";
import { profile } from "../data/profile";
import type { Locale } from "../i18n/types";
import { translate } from "../i18n/utils";
interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
const links = [{ label: "GitHub", href: profile.links.github }, profile.links.email ? { label: "Email", href: `mailto:${profile.links.email}` } : null, profile.links.scholar ? { label: "Google Scholar", href: profile.links.scholar } : null, profile.links.linkedin ? { label: "LinkedIn", href: profile.links.linkedin } : null, profile.links.cv ? { label: "CV", href: profile.links.cv } : null].filter(Boolean) as Array<{ label: string; href: string }>;
---

<BaseLayout locale={locale} title={translate(locale, "about.title")} description={data.profile.aboutIntroduction}>
  <PageShell class="about-page">
    <PageHeader eyebrow={profile.displayName} title={translate(locale, "about.title")} description={data.profile.aboutIntroduction} />
    <section class="section" aria-labelledby="about-bio"><h2 id="about-bio">{translate(locale, "about.bio")}</h2><div class="prose-stack">{data.profile.bio.map((paragraph) => <p>{paragraph}</p>)}</div></section>
    <section class="section" aria-labelledby="about-skills"><h2 id="about-skills">{translate(locale, "about.skills")}</h2><div class="plain-groups">{data.skillGroups.map((group) => <div><h3>{group.title}</h3><ul class="about-skill-list">{group.skills.map((skill) => <li>{skill}</li>)}</ul></div>)}</div></section>
    <section class="section" aria-labelledby="about-values"><h2 id="about-values">{translate(locale, "about.values")}</h2><ul>{data.profile.researcherValues.map((value) => <li>{value}</li>)}</ul></section>
    {links.length > 0 && <section class="section" aria-labelledby="about-links"><h2 id="about-links">{translate(locale, "about.links")}</h2><div class="link-row">{links.map((link) => <ExternalLink href={link.href}>{link.label}</ExternalLink>)}</div></section>}
  </PageShell>
</BaseLayout>

<style>
  .about-skill-list { display:flex; flex-wrap:wrap; gap:var(--space-2) var(--space-4); padding:0; margin:0; list-style:none; }
  .about-skill-list li { position:relative; padding-inline-start:var(--space-3); color:var(--color-text-secondary); }
  .about-skill-list li::before { position:absolute; top:.62em; left:0; width:5px; height:5px; background:var(--color-identity-teal); content:""; }
</style>

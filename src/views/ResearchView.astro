---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import PageShell from "../components/layout/PageShell.astro";
import { getLocalizedData } from "../data/locales";
import { mediaManifest } from "../data/mediaManifest";
import type { Locale } from "../i18n/types";
import { translate } from "../i18n/utils";
interface Props { locale: Locale }
const { locale } = Astro.props;
const data = getLocalizedData(locale);
const artwork = [mediaManifest.researchVla, mediaManifest.researchEfficientSystems, mediaManifest.researchWorkflow];
---

<BaseLayout locale={locale} title={translate(locale, "nav.research")} description={translate(locale, "research.intro")} width="wide">
  <PageShell class="research-page">
    <PageHeader eyebrow={translate(locale, "research.eyebrow")} title={translate(locale, "research.title")} description={translate(locale, "research.intro")} />
    <div class="research-themes">
      {data.researchAreas.map((area, index) => <article id={area.slug} class="research-theme">
        <div class="research-theme__media media-frame"><img src={artwork[index].light} alt={artwork[index].alt[locale]} width="800" height="600" loading="lazy" decoding="async" /></div>
        <div class="research-theme__copy"><p class="eyebrow">{String(index + 1).padStart(2, "0")}</p><h2>{area.question}</h2><p>{area.motivation}</p><dl><div><dt>{translate(locale, "research.hypothesis")}</dt><dd>{area.hypothesis}</dd></div><div><dt>{translate(locale, "research.uncertainty")}</dt><dd>{area.uncertainty}</dd></div></dl><div class="link-row">{area.related.map((link) => <a href={link.href}>{link.label}</a>)}</div></div>
      </article>)}
    </div>
  </PageShell>
</BaseLayout>

<style>
  .research-themes { display: grid; }
  .research-theme { display: grid; gap: var(--space-6); padding: var(--space-8) 0; border-top: 1px solid var(--color-border); }
  .research-theme__media { aspect-ratio: 4 / 3; }
  .research-theme__copy { display: grid; gap: var(--space-4); align-content: center; }
  .research-theme__copy > p:not(.eyebrow) { color: var(--color-text-secondary); font-size: var(--editorial-body); line-height: 1.7; }
  .research-theme dl { display: grid; gap: var(--space-4); margin: 0; }
  .research-theme dl div { display: grid; gap: var(--space-1); padding-top: var(--space-3); border-top: 1px solid var(--color-border); }
  .research-theme dt { color: var(--color-text); font-size: var(--text-sm); font-weight: 750; }
  .research-theme dd { margin: 0; color: var(--color-text-secondary); }
  @media (min-width: 768px) {
    .research-theme { grid-template-columns: minmax(0, .88fr) minmax(0, 1.12fr); gap: var(--space-8); align-items: center; }
    .research-theme:nth-child(even) .research-theme__media { order: 2; }
  }
  @media (min-width: 1024px) { .research-theme { gap: var(--space-9); padding-block: var(--space-9); } }
</style>

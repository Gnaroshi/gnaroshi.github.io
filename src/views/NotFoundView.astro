---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";

interface Props {
  locale: Locale;
  detectLocale?: boolean;
}

const { locale, detectLocale = false } = Astro.props;
const links = [
  ["nav.home", "/"],
  ["nav.research", "/research/"],
  ["nav.writing", "/blog/"],
  ["nav.paperLab", "/papers/"]
] as const;
const alternateUrls = locale === "ko"
  ? { en: "/", ko: "/ko/404/", translationAvailable: false }
  : { en: "/404.html", ko: "/ko/", xDefault: "/404.html", translationAvailable: false };
---

<BaseLayout
  locale={locale}
  title={translate(locale, "notFound.title")}
  description={translate(locale, "notFound.body")}
  canonical={locale === "ko" ? "/ko/404/" : "/404.html"}
  alternateUrls={alternateUrls}
  robots="noindex, follow"
  minimalChrome={detectLocale}
>
  {(["en", "ko"] as const).filter((viewLocale) => detectLocale || viewLocale === locale).map((viewLocale) => (
    <article data-not-found-locale={viewLocale} hidden={detectLocale && viewLocale !== "en"}>
      <header class="page-header">
        <p class="eyebrow">{translate(viewLocale, "notFound.eyebrow")}</p>
        {viewLocale === "en" || !detectLocale
          ? <h1>{translate(viewLocale, "notFound.title")}</h1>
          : <p class="not-found-heading" role="heading" aria-level="1">{translate(viewLocale, "notFound.title")}</p>}
        <p class="lede">{translate(viewLocale, "notFound.body")}</p>
        <p class="not-found-path"><span>{viewLocale === "ko" ? "요청한 경로" : "Requested path"}</span> <code data-not-found-path>/404.html</code></p>
      </header>
      <section class="section" aria-labelledby={`not-found-links-${viewLocale}`}>
        <h2 id={`not-found-links-${viewLocale}`}>{translate(viewLocale, "notFound.links")}</h2>
        <div class="not-found-links">{links.map(([key, href]) => <a href={getLocalePath(viewLocale, href)}>{translate(viewLocale, key)}</a>)}</div>
      </section>
    </article>
  ))}

  {detectLocale && <script is:inline>
    (() => {
      const isKorean = location.pathname === "/ko" || location.pathname.startsWith("/ko/");
      const locale = isKorean ? "ko" : "en";
      document.documentElement.lang = locale;
      for (const view of document.querySelectorAll("[data-not-found-locale]")) {
        view.toggleAttribute("hidden", view.getAttribute("data-not-found-locale") !== locale);
      }
      for (const path of document.querySelectorAll("[data-not-found-path]")) path.textContent = location.pathname;
      document.title = isKorean ? "페이지를 찾을 수 없습니다 | Gnaroshi" : "Page not found | Gnaroshi";
      document.querySelector('meta[name="description"]')?.setAttribute("content", isKorean
        ? "주소가 바뀌었거나 페이지가 더 이상 없을 수 있습니다. 연구와 글, 논문 기록에서 계속 둘러볼 수 있습니다."
        : "The address may have changed or the page may no longer exist. You can continue with Research, Writing, or Papers.");
    })();
  </script>}
</BaseLayout>

<style>
  .not-found-path { display: flex; flex-wrap: wrap; gap: var(--space-2); color: var(--color-text-muted); font-size: var(--text-sm); }
  .not-found-heading { margin: 0; font-size: var(--text-3xl); font-weight: 700; line-height: 1.2; }
  .not-found-links { display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .not-found-links a { padding: .65rem .85rem; border: 1px solid var(--color-border); border-radius: var(--radius-sm); color: var(--color-text); text-decoration: none; }
  .not-found-links a:hover, .not-found-links a:focus-visible { border-color: var(--color-accent); color: var(--color-accent); }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import StructuredData from "../components/StructuredData.astro";
import ExternalLink from "../components/common/ExternalLink.astro";
import HeadingPermalinks from "../components/projects/HeadingPermalinks.astro";
import ApplicationProjectDetail from "../components/projects/ApplicationProjectDetail.astro";
import InfrastructureProjectDetail from "../components/projects/InfrastructureProjectDetail.astro";
import ResearchProjectDetail from "../components/projects/ResearchProjectDetail.astro";
import { getProjectMedia } from "../data/approvedMedia";
import { getApprovedProjectShowcase } from "../data/approvedProjectShowcases";
import { techCatalog } from "../data/facts/techCatalog";
import { projectFacts } from "../data/facts/projects";
import { getLocalizedData } from "../data/locales";
import { getProjectUi } from "../data/projectUi";
import { getProjectStory } from "../data/projectStories";
import { profile } from "../data/profile";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getBlogPostHref, getPublishedBlogPosts } from "../utils/content";
import "../styles/project-detail.css";

interface Props { locale: Locale; slug: string }
const { locale, slug } = Astro.props;
const project = projectFacts.find((item) => item.slug === slug);
if (!project) throw new Error(`Unknown project: ${slug}`);
const story = getProjectStory(locale, project.id);
const labels = getProjectUi(locale);
const localizedProject = getLocalizedData(locale).projects.find((item) => item.id === project.id)!;
const posts = await getPublishedBlogPosts(locale);
const relatedKeys = new Set(localizedProject.relatedWriting);
const related = posts.filter((post) => relatedKeys.has(post.data.translationKey));
const canonicalPath = getLocalePath(locale, `/projects/${project.slug}/`);
const repositoryUrl = project.links.find((link) => link.id === "repository")?.href;
const applicationMedia = project.kind === "application" ? getApprovedProjectShowcase(project.primaryShowcaseId) : undefined;
const selectedMedia = project.kind !== "application" ? getProjectMedia(project.id) : undefined;
if (project.kind === "application" && !applicationMedia) throw new Error(`${project.id}: approved application media is missing`);
if (project.kind !== "application" && !selectedMedia) throw new Error(`${project.id}: selected-project evidence is missing`);
---

<BaseLayout locale={locale} title={story.title} description={story.heroSummary} canonical={canonicalPath} type="article" width="wide" modifiedTime={project.updatedAt} articleTags={[...project.tags]} pageProgress>
  <article class:list={["project-detail", `project-detail--${project.kind}`]} data-project-kind={project.kind}>
    <Breadcrumbs label={locale === "ko" ? "현재 위치" : "Breadcrumb"} items={[{name:locale === "ko" ? "홈" : "Home",href:getLocalePath(locale,"/")},{name:locale === "ko" ? "프로젝트" : "Projects",href:getLocalePath(locale,"/projects/")},{name:story.title,href:canonicalPath}]}/>
    <StructuredData data={{
      "@context":"https://schema.org","@type":repositoryUrl ? "SoftwareSourceCode" : "CreativeWork",name:story.title,description:story.heroSummary,
      url:new URL(canonicalPath,profile.domain).toString(),dateModified:project.updatedAt,author:{"@type":"Person",name:profile.publicAlias,url:profile.domain},keywords:project.tags,
      ...(repositoryUrl ? {codeRepository:repositoryUrl,programmingLanguage:project.techStack.map((id) => techCatalog[id].label)} : {})
    }}/>

    {project.kind === "application" && applicationMedia && <ApplicationProjectDetail project={project} story={story} locale={locale} media={applicationMedia} hasPublicRepository={Boolean(repositoryUrl)}/>}
    {project.kind === "research" && selectedMedia && <ResearchProjectDetail project={project} story={story} locale={locale} media={selectedMedia}/>}
    {project.kind === "infrastructure" && selectedMedia && <InfrastructureProjectDetail project={project} story={story} locale={locale} media={selectedMedia}/>}

    {related.length > 0 && <section class="prose-section"><h2 id="related-writing">{translate(locale,"projects.relatedWriting")}</h2><ul>{related.map((post) => <li><a href={getBlogPostHref(post)}>{post.data.title}</a></li>)}</ul></section>}
    {project.links.length > 0 && <footer class="project-links" aria-label={labels.links}>{project.links.map((link) => <ExternalLink href={link.href}>{story.linkLabels[link.id] ?? link.id}</ExternalLink>)}</footer>}
    <HeadingPermalinks locale={locale}/>
  </article>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import StructuredData from "../components/StructuredData.astro";
import ExternalLink from "../components/common/ExternalLink.astro";
import SystemWorkflow from "../components/system/SystemWorkflow.astro";
import ResponsiveImage from "../components/media/ResponsiveImage.astro";
import { getProjectMedia } from "../data/approvedMedia";
import { getLocalizedData } from "../data/locales";
import { formatLocalizedDate } from "../i18n/date";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getPublishedBlogPosts, getBlogPostHref } from "../utils/content";
import { profile } from "../data/profile";
interface Props { locale: Locale; slug: string }
const { locale, slug } = Astro.props;
const data = getLocalizedData(locale);
const project = data.projects.find((item) => item.slug === slug);
if (!project) throw new Error(`Unknown localized project: ${slug}`);
const posts = await getPublishedBlogPosts(locale);
const relatedKeys = new Set<string>(project.relatedWriting);
const related = posts.filter((post) => relatedKeys.has(post.data.translationKey));
const canonicalPath = getLocalePath(locale, `/projects/${project.slug}/`);
const repositoryUrl = project.links.find((link) => link.id === "repository")?.href;
const projectMedia = getProjectMedia(project.id);
---

<BaseLayout locale={locale} title={project.title} description={project.summary} canonical={canonicalPath} type="article" width="wide" modifiedTime={project.updatedAt} articleTags={[...project.tags]}>
  <article class="project-case">
    <Breadcrumbs label={locale === "ko" ? "현재 위치" : "Breadcrumb"} items={[
      { name: locale === "ko" ? "홈" : "Home", href: getLocalePath(locale, "/") },
      { name: locale === "ko" ? "프로젝트" : "Projects", href: getLocalePath(locale, "/projects/") },
      { name: project.title, href: canonicalPath }
    ]} />
    <StructuredData data={{
      "@context": "https://schema.org",
      "@type": repositoryUrl ? "SoftwareSourceCode" : "CreativeWork",
      name: project.title,
      description: project.summary,
      url: new URL(canonicalPath, profile.domain).toString(),
      dateModified: project.updatedAt,
      author: { "@type": "Person", name: profile.publicAlias, url: profile.domain },
      keywords: project.tags,
      ...(repositoryUrl ? { codeRepository: repositoryUrl, programmingLanguage: project.codeLanguages } : {})
    }} />
    <header class="page-header"><a href={getLocalePath(locale, "/projects/")}>{translate(locale, "common.back")}</a><p class="eyebrow">{translate(locale, "nav.projects")}</p><h1>{project.title}</h1><p class="lede">{project.summary}</p><p class="metadata">{project.statusLabel} · {translate(locale, "common.updated")} {formatLocalizedDate(project.updatedAt, locale)}</p></header>
    <figure class="project-case__evidence"><ResponsiveImage asset={projectMedia} locale={locale} sizes="(min-width: 1200px) 1040px, 100vw" /></figure>
    <section><h2>{translate(locale, "projects.problem")}</h2><p>{project.problem}</p></section>
    {project.slug === "gnaroshi-dev" && <SystemWorkflow locale={locale} variant="full" showBuildDetails />}
    <section><h2>{translate(locale, "projects.designGoals")}</h2><ul>{project.designGoals.map((item) => <li>{item}</li>)}</ul></section>
    <section><h2>{translate(locale, "projects.architecture")}</h2><ul>{project.architecture.map((item) => <li>{item}</li>)}</ul></section>
    {project.supportedAdapters.length > 0 && <section><h2>{translate(locale, "projects.supportedAdapters")}</h2><ul>{project.supportedAdapters.map((item) => <li>{item}</li>)}</ul></section>}
    <section><h2>{translate(locale, "projects.reproducibility")}</h2><ul>{project.reproducibility.map((item) => <li>{item}</li>)}</ul></section>
    <section><h2>{translate(locale, "projects.currentState")}</h2><p>{project.currentState}</p></section>
    <section><h2>{translate(locale, "projects.openProblems")}</h2><ul>{project.openProblems.map((item) => <li>{item}</li>)}</ul></section>
    {related.length > 0 && <section><h2>{translate(locale, "projects.relatedWriting")}</h2><ul>{related.map((post) => <li><a href={getBlogPostHref(post)}>{post.data.title}</a></li>)}</ul></section>}
    <footer class="link-row">{project.links.map((link) => <ExternalLink href={link.href}>{link.label}</ExternalLink>)}</footer>
  </article>
</BaseLayout>

<style>
  .project-case { display:grid; gap:var(--space-7); }
  .project-case__evidence { aspect-ratio:16/10; margin:0; overflow:hidden; border:1px solid var(--color-border); background:var(--color-surface); }
  .project-case__evidence :global(.responsive-media) { width:100%; height:100%; }
  .project-case__evidence :global(img) { object-fit:contain; }
  .project-case > section { display:grid; gap:var(--space-3); padding-top:var(--space-5); border-top:1px solid var(--color-border); }
  .project-case > section p, .project-case > section li { max-width:72ch; color:var(--color-text-secondary); line-height:1.75; }
</style>

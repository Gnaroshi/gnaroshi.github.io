---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppShell from "../components/layout/AppShell.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import ActivityIcon from "../components/icons/ActivityIcon.astro";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getPublicGrowthSnapshot } from "../utils/feedData";
import "../styles/application.css";
import "../styles/insights.css";

interface Props { locale: Locale }
const { locale } = Astro.props;
const snapshot = getPublicGrowthSnapshot();
const eligible = Boolean(snapshot?.metricEligible && snapshot.score !== null);
const componentLabels: Record<string, { en: string; ko: string }> = {
  consistency: { en: "Consistency", ko: "꾸준함" }, depth: { en: "Reading depth", ko: "읽기 깊이" }, retrieval: { en: "Retrieval", ko: "회상" }, output: { en: "Research output", ko: "연구 결과물" }
};
const components = Object.entries(snapshot?.components ?? {}).filter((entry): entry is [string, number] => typeof entry[1] === "number");
---

<BaseLayout locale={locale} title={translate(locale, "growth.title")} description={translate(locale, "growth.intro")} width="dashboard" mode="application">
  <AppShell class="momentum-page">
    <PageHeader eyebrow={translate(locale, "growth.eyebrow")} title={translate(locale, "growth.title")} description={translate(locale, "growth.intro")} />

    {eligible && snapshot ? (
      <section class="momentum-score" aria-labelledby="growth-score-heading"><div><p class="eyebrow">{locale === "ko" ? "활동 요약" : "Activity overview"}</p><h2 id="growth-score-heading">{snapshot.score}</h2><p>{locale === "ko" ? `신뢰도 ${snapshot.confidence}` : `${snapshot.confidence} confidence`}</p></div><dl><div><dt>{locale === "ko" ? "기록" : "Records"}</dt><dd>{snapshot.evidenceCount}</dd></div><div><dt>{locale === "ko" ? "활동일" : "Active days"}</dt><dd>{snapshot.activeDays}</dd></div></dl></section>
    ) : (
      <section class="growth-onboarding" aria-labelledby="growth-collecting-heading"><div class="app-empty-state"><ActivityIcon class="empty-state-icon" /><p class="eyebrow">{translate(locale, "growth.eyebrow")}</p><h2 id="growth-collecting-heading">{locale === "ko" ? "아직 보여 줄 활동 기록이 충분하지 않습니다." : "There is not enough activity to show a meaningful overview yet."}</h2><a class="button button--primary" href={getLocalePath(locale, "/papers/")}>{translate(locale, "nav.paperLab")}</a></div></section>
    )}

    {components.length > 0 && <section class="section" aria-labelledby="growth-components-heading"><SectionHeader id="growth-components-heading" title={locale === "ko" ? "구성 요소" : "Components"} /><div class="growth-feed-components">{components.map(([key, value]) => <article><h3>{componentLabels[key]?.[locale] ?? key}</h3><strong>{Math.round(value)}</strong></article>)}</div></section>}
    <details class="momentum-methodology"><summary>{locale === "ko" ? "기술 정보" : "Technical details"}</summary><p>{locale === "ko" ? "이 페이지는 공개하기로 한 활동 기록의 합계와 구성 요소를 그대로 표시합니다." : "This page displays the published activity totals and score components without recalculating them in the browser."}</p></details>
  </AppShell>
</BaseLayout>

<style>
  .growth-onboarding { display: grid; gap: var(--space-5); align-items: stretch; }
  .growth-onboarding .app-empty-state { max-width: none; align-content: center; }
  .empty-state-icon { color:var(--color-accent); }
  .momentum-score { display:flex; justify-content:space-between; gap:var(--space-6); padding:var(--space-6); border:1px solid var(--color-border); background:var(--color-surface-raised); }
  .momentum-score h2 { font-size:var(--text-4xl); }
  .momentum-score dl { display:flex; gap:var(--space-6); }
  .momentum-score dl div { display:grid; gap:var(--space-1); }
  .momentum-score dt { color:var(--color-text-muted); font-size:var(--text-sm); }
  .momentum-score dd { font-size:var(--text-xl); font-weight:700; }
  .growth-feed-components { display:grid; grid-template-columns:repeat(auto-fit,minmax(10rem,1fr)); gap:var(--space-4); }
  .growth-feed-components article { padding:var(--space-4); border-top:2px solid var(--color-border-strong); }
  @media (max-width: 479px) { .momentum-score { display:grid; } .momentum-score dl { justify-content:space-between; } }
</style>

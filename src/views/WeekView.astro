---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";
import { getAllWeeklyReviews } from "../utils/weeklyReviews";
interface Props { locale: Locale }
const { locale } = Astro.props;
const reviews = getAllWeeklyReviews();
const current = reviews[0];
const complete = reviews.filter((review) => review.status === "complete" && (review.meaningfulEventCount ?? 0) >= 2);
---
<BaseLayout locale={locale} title={translate(locale, "paperLab.weeklyReviews")} description={translate(locale, "week.subtitle")} width="wide" mode="application"><header class="page-header"><p class="eyebrow">{translate(locale, "paperLab.weeklyReviews")}</p><h1>{translate(locale, "week.title")}</h1><p class="lede">{translate(locale, "week.subtitle")}</p></header>{current?.status === "in-progress" && <section class="weekly-progress-state" aria-labelledby="current-week"><p class="eyebrow">{current.weekId}</p><h2 id="current-week">{translate(locale, "common.inProgress")}</h2><p>{locale === "ko" ? "이번 주에는 의미 있는 연구 활동을 아직 기록하지 않았습니다." : current.summary}</p><a href={getLocalePath(locale, "/papers/#new-paper-template")}>{translate(locale, "home.addFirstPaper")}</a></section>}<section class="section" aria-labelledby="week-archive"><h2 id="week-archive">{translate(locale, "week.archive")}</h2><p>{translate(locale, "week.archiveDescription")}</p>{complete.length ? <div class="weekly-review-list">{complete.map((review) => <article class="weekly-review-card"><h3><a href={getLocalePath(locale, `/week/${review.weekId}/`)}>{review.weekId}</a></h3></article>)}</div> : <div class="app-empty-state"><h2>{translate(locale, "week.empty")}</h2><p>{translate(locale, "week.emptyBody")}</p></div>}</section></BaseLayout>

---
import "katex/dist/katex.min.css";
import "../styles/tokens.css";
import "../styles/global.css";
import "../styles/blog.css";
import "../styles/papers.css";
import "../styles/insights.css";
import "../styles/exams.css";
import "../styles/responsive.css";
import "../styles/navigation.css";
import "../styles/application.css";
import SEO from "../components/SEO.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PaperLabNav from "../components/navigation/PaperLabNav.astro";
import { ogLocales } from "../i18n/config";
import type { AlternateUrls, Locale } from "../i18n/types";
import { getLocaleFromUrl, getLocalePath, translate } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  absoluteTitle?: boolean;
  type?: "website" | "article";
  width?: "prose" | "wide" | "dashboard";
  mode?: "editorial" | "application";
  paperLab?: boolean;
  locale?: Locale;
  alternateUrls?: AlternateUrls;
  ogLocale?: string;
  ogLocaleAlternate?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogTitle,
  ogDescription,
  absoluteTitle,
  type,
  width = "prose",
  mode = "editorial",
  paperLab = mode === "application",
  locale = getLocaleFromUrl(Astro.url),
  alternateUrls,
  ogLocale = ogLocales[locale],
  ogLocaleAlternate = ogLocales[locale === "en" ? "ko" : "en"]
} = Astro.props;
const rssPath = getLocalePath(locale, "/rss.xml");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f7f7f4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101211" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" href={rssPath} type="application/rss+xml" title={translate(locale, "site.rssTitle")} />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      absoluteTitle={absoluteTitle}
      type={type}
      locale={locale}
      alternateUrls={alternateUrls}
      ogLocale={ogLocale}
      ogLocaleAlternate={ogLocaleAlternate}
    />
    <script is:inline>
      (() => {
        try {
          const stored = window.localStorage.getItem("theme");
          const system = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          document.documentElement.dataset.theme = stored === "light" || stored === "dark" ? stored : system;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>
  <body data-mode={mode}>
    <a class="skip-link" href="#content">{translate(locale, "a11y.skipToContent")}</a>
    <SiteHeader locale={locale} alternateUrls={alternateUrls} />
    {paperLab && <PaperLabNav currentPath={Astro.url.pathname} locale={locale} />}
    <main id="content" class:list={["site-main", `site-main--${width}`]}>
      <slot />
    </main>
    <SiteFooter locale={locale} />
  </body>
</html>

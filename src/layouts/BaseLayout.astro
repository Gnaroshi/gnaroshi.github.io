---
import "../styles/tokens.css";
import "../styles/global.css";
import "../styles/navigation.css";
import SEO from "../components/SEO.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PaperLabNav from "../components/navigation/PaperLabNav.astro";
import InPageAnchorBehavior from "../components/InPageAnchorBehavior.astro";
import { ogLocales } from "../i18n/config";
import type { AlternateUrls, Locale } from "../i18n/types";
import { getLocaleFromUrl, getLocalePath, translate } from "../i18n/utils";
import { getContentFeedBuildInfo, getWebsiteBuildInfo } from "../utils/contentFeed";
import { getDefaultRobots } from "../utils/indexing";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  absoluteTitle?: boolean;
  type?: "website" | "article";
  width?: "prose" | "wide" | "dashboard";
  mode?: "editorial" | "application";
  paperLab?: boolean;
  flush?: boolean;
  locale?: Locale;
  alternateUrls?: AlternateUrls;
  ogLocale?: string;
  ogLocaleAlternate?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageAlt?: string;
  robots?: "index, follow" | "noindex, follow";
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  articleTags?: string[];
  author?: string;
  minimalChrome?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogTitle,
  ogDescription,
  absoluteTitle,
  type,
  width = "prose",
  mode = "editorial",
  paperLab = mode === "application",
  flush = false,
  locale = getLocaleFromUrl(Astro.url),
  alternateUrls,
  ogLocale = ogLocales[locale],
  ogLocaleAlternate = ogLocales[locale === "en" ? "ko" : "en"],
  ogImageWidth,
  ogImageHeight,
  ogImageAlt,
  robots = getDefaultRobots(Astro.url.pathname),
  publishedTime,
  modifiedTime,
  articleTags,
  author,
  minimalChrome = false
} = Astro.props;
const rssPath = getLocalePath(locale, "/rss.xml");
const contentFeedBuildInfo = getContentFeedBuildInfo();
const websiteBuildInfo = getWebsiteBuildInfo();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4f5f2" data-theme-color />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="content-feed-commit" content={contentFeedBuildInfo.contentFeedCommit ?? "unavailable"} />
    <meta name="website-commit" content={websiteBuildInfo.websiteCommit ?? "unavailable"} />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" href={rssPath} type="application/rss+xml" title={translate(locale, "site.rssTitle")} />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      absoluteTitle={absoluteTitle}
      type={type}
      locale={locale}
      alternateUrls={alternateUrls}
      ogLocale={ogLocale}
      ogLocaleAlternate={ogLocaleAlternate}
      ogImageWidth={ogImageWidth}
      ogImageHeight={ogImageHeight}
      ogImageAlt={ogImageAlt}
      robots={robots}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      articleTags={articleTags}
      author={author}
    />
    <slot name="head" />
    <script is:inline>
      (() => {
        const colors = { light: "#f4f5f2", dark: "#0f1311" };
        const setTheme = (theme) => {
          document.documentElement.dataset.theme = theme;
          document.querySelector('meta[data-theme-color]')?.setAttribute("content", colors[theme]);
        };
        try {
          const stored = window.localStorage.getItem("theme");
          const system = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          setTheme(stored === "light" || stored === "dark" ? stored : system);
        } catch {
          setTheme("light");
        }
      })();
    </script>
    <script is:inline>
      document.addEventListener("keydown", (event) => {
        if (event.key === "Tab") document.documentElement.dataset.keyboardNavigation = "true";
      });
      document.addEventListener("pointerdown", () => {
        delete document.documentElement.dataset.keyboardNavigation;
      });
    </script>
  </head>
  <body data-mode={mode}>
    <a class="skip-link" href="#content">{translate(locale, "a11y.skipToContent")}</a>
    {!minimalChrome && <SiteHeader locale={locale} alternateUrls={alternateUrls} />}
    {!minimalChrome && paperLab && <PaperLabNav currentPath={Astro.url.pathname} locale={locale} />}
    <main id="content" class:list={["site-main", `site-main--${width}`, flush && "site-main--flush"]}>
      <slot />
    </main>
    {!minimalChrome && <SiteFooter locale={locale} currentPath={Astro.url.pathname} />}
    <InPageAnchorBehavior />
  </body>
</html>

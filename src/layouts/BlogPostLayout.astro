---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import FeatureStyles from "../components/FeatureStyles.astro";
import StructuredData from "../components/StructuredData.astro";
import BlogMeta from "../components/blog/BlogMeta.astro";
import SeriesNav from "../components/blog/SeriesNav.astro";
import TableOfContents from "../components/blog/TableOfContents.astro";
import TagList from "../components/blog/TagList.astro";
import type { BlogPost } from "../utils/content";
import { getBlogPostHref } from "../utils/content";
import type { AlternateUrls, Locale } from "../i18n/types";
import { translate } from "../i18n/utils";
import { profile } from "../data/profile";
import { hasMathSyntax } from "../utils/math";
import { getPublicAssetMetadata } from "../utils/contentFeed";
import "../styles/blog.css";
import "../styles/code.css";
import "../styles/prose.css";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: BlogPost;
  headings: Heading[];
  seriesPosts: BlogPost[];
  previous?: BlogPost;
  next?: BlogPost;
  locale: Locale;
  alternateUrls: AlternateUrls;
}

const { post, headings, seriesPosts, previous, next, locale, alternateUrls } = Astro.props;
const canonicalPath = getBlogPostHref(post);
const hasMath = hasMathSyntax(post.body);
const requestedSocialImage = post.data.ogImage ?? post.data.heroImage;
const socialAsset = getPublicAssetMetadata(requestedSocialImage);
const socialImage = socialAsset && socialAsset.mediaType !== "image/svg+xml" ? requestedSocialImage : undefined;
const blogPosting = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { "@type": "Person", name: profile.publicAlias, url: profile.domain },
  mainEntityOfPage: new URL(canonicalPath, profile.domain).toString(),
  inLanguage: locale === "ko" ? "ko-KR" : "en-US",
  keywords: post.data.tags
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonicalPath}
  ogImage={socialImage}
  ogImageWidth={socialImage ? socialAsset?.width : undefined}
  ogImageHeight={socialImage ? socialAsset?.height : undefined}
  ogImageAlt={socialImage ? socialAsset?.alt : undefined}
  type="article"
  locale={locale}
  alternateUrls={alternateUrls}
  robots={post.data.visibility === "unlisted" ? "noindex, follow" : "index, follow"}
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate ?? post.data.pubDate}
  articleTags={post.data.tags}
  author={profile.publicAlias}
>
  <FeatureStyles slot="head" styles={hasMath ? ["katex"] : []} />
  <article class="blog-post">
    <Breadcrumbs label={locale === "ko" ? "현재 위치" : "Breadcrumb"} items={[
      { name: locale === "ko" ? "홈" : "Home", href: locale === "ko" ? "/ko/" : "/" },
      { name: locale === "ko" ? "글" : "Writing", href: locale === "ko" ? "/ko/blog/" : "/blog/" },
      { name: post.data.title, href: canonicalPath }
    ]} />
    <StructuredData data={blogPosting} />
    {!alternateUrls.translationAvailable && <p class="content-language-badge"><span class="paper-badge paper-badge--muted">{locale === "ko" ? "한국어 콘텐츠" : "English content"}</span> {locale === "ko" ? "영어 번역 없음" : "Korean translation unavailable"}</p>}
    <header class="blog-post__header">
      <p class="eyebrow">{translate(locale, "nav.writing")}</p>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
      <BlogMeta post={post} locale={locale} />
      <TagList tags={post.data.tags} locale={locale} />
    </header>

    <SeriesNav posts={seriesPosts} currentId={post.id} locale={locale} />
    <TableOfContents headings={headings} locale={locale} />

    <div class="prose">
      <slot />
    </div>

    <nav class="post-nav" aria-label={translate(locale, "nav.writing")}>
      <div>
        {previous && (
          <>
            <span>{translate(locale, "common.previous")}</span>
            <a href={getBlogPostHref(previous)}>{previous.data.title}</a>
          </>
        )}
      </div>
      <div>
        {next && (
          <>
            <span>{translate(locale, "common.next")}</span>
            <a href={getBlogPostHref(next)}>{next.data.title}</a>
          </>
        )}
      </div>
    </nav>
  </article>

  <script is:inline define:vars={{ linkLabel: locale === "ko" ? "제목 링크" : "Link to heading" }}>
    for (const heading of document.querySelectorAll(".prose :is(h2, h3, h4)[id]")) {
      if (heading.querySelector(".heading-anchor")) continue;
      const anchor = document.createElement("a");
      anchor.className = "heading-anchor";
      anchor.href = `#${heading.id}`;
      anchor.setAttribute("aria-label", `${linkLabel}: ${heading.textContent}`);
      anchor.textContent = "#";
      heading.append(anchor);
    }
  </script>
</BaseLayout>

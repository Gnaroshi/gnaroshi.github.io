---
import type { Locale } from "../i18n/types";
import { translate } from "../i18n/utils";
import MoonIcon from "./icons/MoonIcon.astro";
import SunIcon from "./icons/SunIcon.astro";
interface Props { locale: Locale }
const { locale } = Astro.props;
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-label={translate(locale, "theme.switchToDark")}
  title={translate(locale, "theme.switchToDark")}
  data-light-label={translate(locale, "theme.switchToLight")}
  data-dark-label={translate(locale, "theme.switchToDark")}
>
  <span class="theme-toggle__icon theme-toggle__icon--moon"><MoonIcon /></span>
  <span class="theme-toggle__icon theme-toggle__icon--sun"><SunIcon /></span>
</button>

<script>
  const getSystemTheme = () =>
    window.matchMedia?.("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  const getStoredTheme = () => {
    try {
      const stored = window.localStorage.getItem("theme");
      return stored === "light" || stored === "dark" ? stored : null;
    } catch {
      return null;
    }
  };
  const storeTheme = (theme: "light" | "dark") => {
    try {
      window.localStorage.setItem("theme", theme);
    } catch {
      // Theme preference is optional; the UI still works without storage.
    }
  };
  const themeColors = { light: "#f4f5f2", dark: "#0f1311" } as const;
  const applyTheme = (theme: "light" | "dark") => {
    document.documentElement.dataset.theme = theme;
    document.querySelector('meta[data-theme-color]')?.setAttribute("content", themeColors[theme]);
  };
  const applyThemeToggleState = (button: Element) => {
    const theme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
    const nextTheme = theme === "dark" ? "light" : "dark";
    const label = nextTheme === "dark"
      ? button.getAttribute("data-dark-label")
      : button.getAttribute("data-light-label");
    if (label) {
      button.setAttribute("aria-label", label);
      button.setAttribute("title", label);
    }
  };

  for (const button of document.querySelectorAll("[data-theme-toggle]")) {
    const initialTheme = getStoredTheme() ?? getSystemTheme();
    applyTheme(initialTheme);
    applyThemeToggleState(button);
    button.addEventListener("click", () => {
      const theme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      const nextTheme = theme === "dark" ? "light" : "dark";
      applyTheme(nextTheme);
      storeTheme(nextTheme);
      applyThemeToggleState(button);
    });
  }

  const media = window.matchMedia?.("(prefers-color-scheme: dark)");
  media?.addEventListener("change", (event) => {
    if (getStoredTheme()) return;
    applyTheme(event.matches ? "dark" : "light");
    for (const button of document.querySelectorAll("[data-theme-toggle]")) applyThemeToggleState(button);
  });
</script>

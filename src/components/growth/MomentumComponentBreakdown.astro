---
import type { MomentumResult } from "../../types/momentum";
import type { Locale } from "../../i18n/types";

interface Props {
  components: MomentumResult["components"];
  locale: Locale;
}

const { components, locale } = Astro.props;
const entries = Object.entries(components) as Array<[keyof typeof components, (typeof components)[keyof typeof components]]>;
const koLabels: Record<string, string> = { consistency: "꾸준함", understanding: "이해", retrieval: "회상", output: "연구 결과물", revisit: "다시 보기", balance: "균형" };
---

<div class="momentum-component-grid">
  {entries.map(([key, item]) => (
    <article class:list={["momentum-component", !item.available && "momentum-component--unavailable"]}>
      <header>
        <div>
          <h3>{locale === "ko" ? (koLabels[key] ?? item.label) : item.label}</h3>
          <span>{locale === "ko" ? `가중치 ${item.weight}%` : `${item.weight}% weight`}</span>
        </div>
        <strong aria-label={item.available ? (locale === "ko" ? `100점 만점에 ${item.score}점` : `${item.score} out of 100`) : (locale === "ko" ? "근거 없음" : `${item.label} unavailable`)}>
          {item.available ? item.score : "N/A"}
        </strong>
      </header>
      {item.available ? (
        <div class="momentum-meter" aria-hidden="true">
          <span style={`width: ${item.score}%`}></span>
        </div>
      ) : (
        <p class="momentum-component__status">{locale === "ko" ? "근거 없음" : "Evidence unavailable"}</p>
      )}
      <p>{locale === "ko" ? "공개 기록에서 이 요소를 뒷받침하는 활동을 집계합니다." : item.explanation}</p>
      {locale === "en" && item.evidence.length > 0 && (
        <ul aria-label={`${item.label} evidence`}>
          {item.evidence.map((evidence) => <li>{evidence}</li>)}
        </ul>
      )}
      {item.available && <span class="momentum-component__confidence">{locale === "ko" ? `요소 신뢰도 ${item.confidence}%` : `Component confidence ${item.confidence}%`}</span>}
    </article>
  ))}
</div>

---
import type { MomentumResult } from "../../types/momentum";
import type { Locale } from "../../i18n/types";

interface Props {
  confidence: MomentumResult["confidence"];
  locale: Locale;
}

const { confidence, locale } = Astro.props;
const koLabel = confidence.score >= 75 ? "높은 신뢰도" : confidence.score >= 45 ? "보통 신뢰도" : "낮은 신뢰도";
---

<section class="momentum-confidence" aria-labelledby="momentum-confidence-heading">
  <div class="momentum-confidence__header">
    <div>
      <p class="eyebrow">{locale === "ko" ? "근거 신뢰도" : "Evidence confidence"}</p>
      <h2 id="momentum-confidence-heading">{locale === "ko" ? koLabel : confidence.label}</h2>
    </div>
    <strong aria-label={locale === "ko" ? `신뢰도 100점 만점에 ${confidence.score}점` : `${confidence.score} out of 100 confidence`}>{confidence.score}</strong>
  </div>
  <div class="momentum-meter" aria-hidden="true">
    <span style={`width: ${confidence.score}%`}></span>
  </div>
  <ul>
    {locale === "ko" ? <li>공개 기록의 양, 활동 날짜, 연구 활동의 다양성을 바탕으로 계산합니다.</li> : confidence.reasons.map((reason) => <li>{reason}</li>)}
  </ul>
</section>

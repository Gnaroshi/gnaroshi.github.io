---
import Badge from "../common/Badge.astro";
import Card from "../common/Card.astro";
import SectionHeader from "../common/SectionHeader.astro";
import { getPaperActivityDate, getPublishedPapers } from "../../utils/papers";

const papers = (await getPublishedPapers()).slice(0, 3);
---

<section class="section" aria-labelledby="recent-papers-heading">
  <SectionHeader
    id="recent-papers-heading"
    eyebrow="Reading"
    title="Recent paper reading"
    description="Reading notes use the three-pass method and leave room for partial progress, questions, and revisits."
  >
    <a slot="action" href="/papers">Browse reading notes</a>
  </SectionHeader>

  {papers.length > 0 ? (
    <div class="preview-list">
      {papers.map((paper) => (
        <Card title={paper.data.title} href={`/papers/${paper.id}/`} description={paper.data.oneLineSummary}>
          <div class="badge-row">
            <Badge tone="accent">{paper.data.status}</Badge>
            <Badge tone="muted">{paper.data.depth}</Badge>
            {getPaperActivityDate(paper) && <Badge>{getPaperActivityDate(paper)}</Badge>}
            {paper.data.tags.slice(0, 3).map((tag) => <Badge>{tag}</Badge>)}
          </div>
        </Card>
      ))}
    </div>
  ) : (
    <p class="empty-state">
      No public paper logs yet. Recent reading activity will appear here.
    </p>
  )}
</section>

<style>
  .preview-list {
    display: grid;
    gap: var(--space-3);
  }
</style>

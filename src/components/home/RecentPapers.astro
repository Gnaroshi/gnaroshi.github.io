---
import { getCollection } from "astro:content";
import Badge from "../common/Badge.astro";
import Card from "../common/Card.astro";
import SectionHeader from "../common/SectionHeader.astro";

const papers = (await getCollection("papers"))
  .sort((a, b) => b.data.lastReadAt.getTime() - a.data.lastReadAt.getTime())
  .slice(0, 3);
---

<section class="section" aria-labelledby="recent-papers-heading">
  <SectionHeader
    id="recent-papers-heading"
    eyebrow="Paper log"
    title="Recent paper reading"
    description="Paper notes will use the three-pass method and reward partial progress, questions, and revisits."
  >
    <a slot="action" href="/papers">Paper dashboard</a>
  </SectionHeader>

  {papers.length > 0 ? (
    <div class="preview-list">
      {papers.map((paper) => (
        <Card title={paper.data.title} href={`/papers/${paper.id}/`} description={paper.data.summary}>
          <div class="badge-row">
            <Badge tone="accent">{paper.data.status}</Badge>
            <Badge tone="muted">depth {paper.data.depth}</Badge>
            {paper.data.tags.slice(0, 3).map((tag) => <Badge>{tag}</Badge>)}
          </div>
        </Card>
      ))}
    </div>
  ) : (
    <p class="empty-state">
      No public paper logs yet. When paper MDX files are added, this section will show recent reading activity.
    </p>
  )}
</section>

<style>
  .preview-list {
    display: grid;
    gap: var(--space-3);
  }

  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>

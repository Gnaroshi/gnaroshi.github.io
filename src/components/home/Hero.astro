---
import ExternalLink from "../common/ExternalLink.astro";
import { homeCopy } from "../../data/homeCopy";

const cockpitLinks = [
  { label: homeCopy.paperLog.title, href: "/papers", index: "01" },
  { label: homeCopy.oralExam.title, href: "/papers", index: "02" },
  { label: homeCopy.projects.title, href: "/projects", index: "03" },
  { label: homeCopy.growth.title, href: "/growth", index: "04" }
] as const;
---

<section class="hero" aria-labelledby="home-title">
  <div class="hero__copy">
    <p class="hero__eyebrow">{homeCopy.hero.eyebrow}</p>
    <h1 id="home-title">{homeCopy.hero.title}</h1>
    <p class="hero__headline">{homeCopy.hero.subtitle}</p>
    <p class="hero__bio">{homeCopy.hero.description}</p>
    <div class="hero__actions" aria-label="Primary actions">
      <a class="button button--primary" href="/papers">{homeCopy.hero.primaryCta}</a>
      <a class="button" href="/growth">{homeCopy.hero.secondaryCta}</a>
    </div>
    <div class="hero__links" aria-label="More destinations">
      {homeCopy.hero.links.map((link) => (
        link.href.startsWith("http")
          ? <ExternalLink href={link.href}>{link.label}</ExternalLink>
          : <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>

  <aside class="hero__map" aria-label="Research cockpit map">
    {cockpitLinks.map((item) => (
      <a href={item.href}>
        <span>{item.index}</span>
        <strong>{item.label}</strong>
      </a>
    ))}
  </aside>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(250px, 0.45fr);
    gap: var(--space-7);
    align-items: end;
    padding: var(--space-7) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__copy {
    display: grid;
    gap: var(--space-3);
  }

  .hero__eyebrow {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .hero h1 {
    max-width: 22ch;
    font-size: var(--text-3xl);
    line-height: 1.08;
  }

  .hero__headline {
    margin: 0;
    color: var(--color-text);
    font-size: var(--text-xl);
    font-weight: 650;
  }

  .hero__bio {
    max-width: 62ch;
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    margin-top: var(--space-3);
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }

  .hero__links > a {
    font-size: var(--text-sm);
    font-weight: 650;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
  }

  .button:hover {
    border-color: var(--color-border-strong);
    color: var(--color-accent);
  }

  .button--primary {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .button--primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
  }

  .hero__map {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .hero__map a {
    display: grid;
    gap: var(--space-2);
    min-height: 7rem;
    align-content: space-between;
    padding: var(--space-4);
    color: var(--color-text);
    text-decoration: none;
  }

  .hero__map a:nth-child(odd) {
    border-right: 1px solid var(--color-border);
  }

  .hero__map a:nth-child(-n + 2) {
    border-bottom: 1px solid var(--color-border);
  }

  .hero__map a:hover strong {
    color: var(--color-accent);
  }

  .hero__map span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .hero__map strong {
    font-size: var(--text-sm);
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      padding: var(--space-6) 0 var(--space-7);
    }
  }

  @media (max-width: 420px) {
    .hero {
      gap: var(--space-4);
      padding: var(--space-5) 0 var(--space-5);
    }

    .hero__copy {
      gap: var(--space-2);
    }

    .hero h1 {
      font-size: 1.6rem;
    }

    .hero__headline {
      font-size: var(--text-lg);
    }

    .hero__bio {
      font-size: var(--text-base);
    }

    .hero__actions {
      gap: var(--space-2);
      margin-top: var(--space-2);
    }

    .hero__links {
      gap: var(--space-3);
    }

    .hero__map {
      display: none;
    }
  }
</style>

---
import { now } from "../../data/now";
import { profile } from "../../data/profile";
---

<section class="identity-hero" aria-labelledby="home-title">
  <div class="identity-hero__copy">
    <p class="eyebrow">{profile.location}</p>
    <h1 id="home-title">{profile.displayName}</h1>
    <p class="identity-hero__headline">{profile.headline}</p>
    <p class="identity-hero__bio">{profile.shortBio}</p>
    <div class="identity-hero__actions" aria-label="Primary actions">
      <a class="button button--primary" href="/blog">Read writing</a>
      <a class="button" href="/research">View research</a>
    </div>
  </div>
  <aside class="identity-hero__current" aria-label="Current research focus">
    <span>Currently exploring</span>
    <strong>{now.currentQuestions[0]}</strong>
    <a href="/now">Current focus</a>
  </aside>
</section>

<style>
  .identity-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.5fr);
    gap: var(--space-8);
    align-items: end;
    min-height: min(68vh, 42rem);
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .identity-hero__copy {
    display: grid;
    gap: var(--space-4);
  }

  .identity-hero h1 {
    max-width: none;
    font-size: var(--display-md);
    line-height: 1;
  }

  .identity-hero__headline {
    color: var(--color-text);
    font-size: var(--text-xl);
    font-weight: 720;
  }

  .identity-hero__bio {
    max-width: 56ch;
    color: var(--color-text-secondary);
    font-size: var(--editorial-body);
    line-height: 1.75;
  }

  .identity-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .identity-hero__current {
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 3px solid var(--color-reading);
  }

  .identity-hero__current span {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
  }

  .identity-hero__current strong {
    font-size: var(--text-lg);
    line-height: 1.45;
  }

  .identity-hero__current a {
    width: fit-content;
    font-size: var(--text-sm);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .identity-hero {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      min-height: auto;
      padding: var(--space-7) 0;
    }
  }

  @media (max-width: 420px) {
    .identity-hero h1 { font-size: var(--display-sm); }
  }
</style>

---
import Card from "../common/Card.astro";
import Badge from "../common/Badge.astro";
import SectionHeader from "../common/SectionHeader.astro";
import { readingMap } from "../../data/research";
---

<section class="section" aria-labelledby="interest-grid-heading">
  <SectionHeader
    id="interest-grid-heading"
    eyebrow="Research interests"
    title="Areas I keep returning to"
    description="The public site is organized around questions, notes, papers, and tools in these areas."
  />
  <div class="interest-grid">
    {readingMap.map((item) => (
      <Card title={item.area} description={item.notes}>
        <Badge tone="muted">editable in src/data/research.ts</Badge>
      </Card>
    ))}
  </div>
</section>

<style>
  .interest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 230px), 1fr));
    gap: var(--space-4);
  }
</style>

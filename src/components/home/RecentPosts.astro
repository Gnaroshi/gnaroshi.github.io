---
import Card from "../common/Card.astro";
import SectionHeader from "../common/SectionHeader.astro";
import { formatDate } from "../../utils/date";
import { getPostReadingTime, getPublishedBlogPosts } from "../../utils/content";

const posts = (await getPublishedBlogPosts()).slice(0, 3);
---

<section class="section" aria-labelledby="recent-posts-heading">
  <SectionHeader
    id="recent-posts-heading"
    eyebrow="Blog"
    title="Recent technical notes"
    description="Recent writing on research workflows, paper reading, and implementation notes."
  >
    <a slot="action" href="/blog">Blog index</a>
  </SectionHeader>

  {posts.length > 0 ? (
    <div class="preview-list">
      {posts.map((post) => (
        <Card title={post.data.title} href={`/blog/${post.id}/`} description={post.data.description}>
          <p class="metadata">
            {formatDate(post.data.pubDate)} · {getPostReadingTime(post)} · {post.data.tags.join(", ")}
          </p>
        </Card>
      ))}
    </div>
  ) : (
    <p class="empty-state">No public blog posts yet. The first technical notes will appear here.</p>
  )}
</section>

<style>
  .preview-list {
    display: grid;
    gap: var(--space-3);
  }
</style>

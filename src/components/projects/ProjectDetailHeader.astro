---
import { platformLabels } from "../../data/facts/techCatalog";
import type { ProjectFact } from "../../data/facts/projects";
import { getProjectUi } from "../../data/projectUi";
import type { ProjectStory } from "../../data/projectStories";
import { productStatusLabels } from "../../data/projectStories";
import type { Locale } from "../../i18n/types";
import { getLocalePath } from "../../i18n/utils";
import ProjectKindLabel from "./ProjectKindLabel.astro";
interface Props { project: ProjectFact; story: ProjectStory; locale: Locale }
const { project, story, locale } = Astro.props;
const labels = getProjectUi(locale);
---
<header class="project-hero">
  <a class="back-link" href={getLocalePath(locale,"/projects/")}>← {labels.back}</a>
  <div class="project-hero__identity">
    <ProjectKindLabel project={project} locale={locale} size="large" />
    <div><h1>{story.title}</h1></div>
  </div>
  <p class="lede">{story.heroSummary}</p>
  <div class="status-row"><strong data-product-status={project.productStatus}>{productStatusLabels[locale][project.productStatus]}</strong><span>{project.platforms.map((id) => platformLabels[id][locale]).join(" · ")}</span></div>
</header>

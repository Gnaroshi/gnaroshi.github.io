---
type Role = "research-workflow" | "system-utilities" | "learning-tools";
interface Props { role: Role; projectId?: string; label: string; size?: "small" | "large" }
const { role, projectId, label, size = "small" } = Astro.props;
const imageSize = size === "large" ? 128 : 64;
---
<span class:list={["role-icon", `role-icon--${role}`, `role-icon--${size}`]} data-app-id={projectId} title={label}>
  {projectId ? (
    <img src={`/media/identity/apps/${projectId}-${imageSize}.png`} width={imageSize} height={imageSize} alt={label} decoding="async" />
  ) : (
    <svg viewBox="0 0 24 24" role="img" aria-label={label} shape-rendering="crispEdges">
      {role === "research-workflow" && <><path d="M5 5h14v4H5zM5 15h14v4H5z"/><path d="M8 9v6M16 9v6"/></>}
      {role === "system-utilities" && <><path d="M4 17h16M6 14l3-4 3 2 5-7 2 2"/><rect x="5" y="13" width="2" height="2"/><rect x="8" y="9" width="2" height="2"/><rect x="11" y="11" width="2" height="2"/><rect x="16" y="4" width="2" height="2"/></>}
      {role === "learning-tools" && <><path d="M5 4h14v16H5z"/><path class="role-fill" d="M9 8l6 4-6 4z"/></>}
    </svg>
  )}
</span>
<style>
  .role-icon { display:inline-grid; place-items:center; flex:0 0 auto; width:2.75rem; height:2.75rem; overflow:hidden; color:var(--color-text); background:color-mix(in srgb,var(--app-key,var(--color-accent)) 18%,var(--color-surface)); border:var(--pixel-border) solid var(--app-key,var(--color-accent)); box-shadow:2px 2px 0 color-mix(in srgb,var(--app-key,var(--color-accent)) 38%,transparent); }
  .role-icon--large { width:3.5rem; height:3.5rem; }
  img { width:100%; height:100%; object-fit:cover; image-rendering:pixelated; }
  svg { width:68%; height:68%; fill:none; stroke:currentColor; stroke-width:1.8; stroke-linecap:square; stroke-linejoin:miter; }
  .role-fill { fill:var(--app-key,var(--color-accent)); fill-opacity:.72; }
</style>

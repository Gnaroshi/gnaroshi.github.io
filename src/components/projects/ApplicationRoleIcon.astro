---
type Role = "research-workflow" | "system-utilities" | "learning-tools";
interface Props { role: Role; label: string; size?: "small" | "large" }
const { role, label, size = "small" } = Astro.props;
---
<span class:list={["role-icon", `role-icon--${role}`, `role-icon--${size}`]} title={label}>
  <svg viewBox="0 0 24 24" role="img" aria-label={label}>
    {role === "research-workflow" && <><path d="M5 5h14v4H5zM5 15h14v4H5z"/><path d="M8 9v6M16 9v6"/></>}
    {role === "system-utilities" && <><path d="M4 17h16M6 14l3-4 3 2 5-7 2 2"/><circle cx="6" cy="14" r="1"/><circle cx="9" cy="10" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="17" cy="5" r="1"/></>}
    {role === "learning-tools" && <><path d="M5 4h14v16H5zM9 8l6 4-6 4z"/></>}
  </svg>
</span>
<style>
  .role-icon { display:inline-grid; place-items:center; flex:0 0 auto; width:2.25rem; height:2.25rem; color:var(--color-accent); background:color-mix(in srgb,var(--color-accent) 10%,var(--color-surface)); border:1px solid color-mix(in srgb,var(--color-accent) 35%,var(--color-border)); }
  .role-icon--large { width:3.25rem; height:3.25rem; }
  svg { width:60%; height:60%; fill:none; stroke:currentColor; stroke-width:1.7; stroke-linecap:round; stroke-linejoin:round; }
  .role-icon--research-workflow svg path:first-child { fill:currentColor; fill-opacity:.08; }
</style>

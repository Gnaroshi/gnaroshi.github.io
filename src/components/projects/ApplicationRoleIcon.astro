---
type Role = "research-workflow" | "system-utilities" | "learning-tools";
interface Props { role: Role; projectId?: string; label: string; size?: "small" | "large" }
const { role, projectId, label, size = "small" } = Astro.props;
---
<span class:list={["role-icon", `role-icon--${role}`, `role-icon--${size}`]} data-app-id={projectId} title={label}>
  <svg viewBox="0 0 24 24" role="img" aria-label={label} shape-rendering="crispEdges">
    {projectId === "gnaroshi-studio" && <><path d="M4 3h11l4 4v14H4zM15 3v4h4"/><path class="role-fill" d="m7 18 9-9 3 3-9 9H7z"/></>}
    {projectId === "paperflow" && <><path d="M3 4h9v7H3zM5 7h9v7H5zM7 10h8v7H7z"/><path class="role-fill" d="M11 14h6v-3l5 5-5 5v-3h-6z"/></>}
    {projectId === "arxiv-discovery" && <><path d="M3 3h11l4 4v8M14 3v4h4M7 9h6M7 13h3"/><path class="role-fill" d="M11 12h7v7h-7z"/><path d="m17 18 4 4"/></>}
    {projectId === "tr-gpu-monitor" && <><path class="role-fill" d="M5 5h14v14H5z"/><path d="M8 2v3m4-3v3m4-3v3M8 19v3m4-3v3m4-3v3M2 8h3m-3 4h3m-3 4h3m14-8h3m-3 4h3m-3 4h3M7 13h3l2-5 2 9 2-4h2"/></>}
    {projectId === "runshelf" && <><path class="role-fill" d="M3 18h18v3H3zM3 7h5v8H3zM9 7h5v8H9zM15 7h6v8h-6z"/><path d="M4 11h3m3 0h3m3 0h4"/><rect x="18" y="8" width="2" height="2"/></>}
    {projectId === "contentdeck" && <><path d="M7 4h10v2h3v4h-3V8H7v2H4v6h3v2h10v-2h3v4h-3v2H7v-2H4v-3H2V9h2V6h3z"/><path class="role-fill" d="m9 9 7 4-7 4z"/><rect x="6" y="19" width="12" height="3"/></>}
    {!projectId && role === "research-workflow" && <><path d="M5 5h14v4H5zM5 15h14v4H5z"/><path d="M8 9v6M16 9v6"/></>}
    {!projectId && role === "system-utilities" && <><path d="M4 17h16M6 14l3-4 3 2 5-7 2 2"/><rect x="5" y="13" width="2" height="2"/><rect x="8" y="9" width="2" height="2"/><rect x="11" y="11" width="2" height="2"/><rect x="16" y="4" width="2" height="2"/></>}
    {!projectId && role === "learning-tools" && <><path d="M5 4h14v16H5z"/><path class="role-fill" d="M9 8l6 4-6 4z"/></>}
  </svg>
</span>
<style>
  .role-icon { display:inline-grid; place-items:center; flex:0 0 auto; width:2.75rem; height:2.75rem; color:var(--color-text); background:color-mix(in srgb,var(--app-key,var(--color-accent)) 18%,var(--color-surface)); border:var(--pixel-border) solid var(--app-key,var(--color-accent)); box-shadow:2px 2px 0 color-mix(in srgb,var(--app-key,var(--color-accent)) 38%,transparent); }
  .role-icon--large { width:3.5rem; height:3.5rem; }
  svg { width:68%; height:68%; fill:none; stroke:currentColor; stroke-width:1.8; stroke-linecap:square; stroke-linejoin:miter; }
  .role-fill { fill:var(--app-key,var(--color-accent)); fill-opacity:.72; }
</style>

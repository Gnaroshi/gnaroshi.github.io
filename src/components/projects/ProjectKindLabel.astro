---
import type { ProjectFact } from "../../data/facts/projects";
import type { Locale } from "../../i18n/types";

interface Props {
  project: ProjectFact;
  locale: Locale;
  size?: "small" | "large";
}

const { project, locale, size = "small" } = Astro.props;
const labels = {
  en: { research: "Research", application: "Application", infrastructure: "Infrastructure" },
  ko: { research: "연구 프로젝트", application: "애플리케이션", infrastructure: "웹 인프라" }
} as const;
const label = labels[locale][project.kind];
---

<span class:list={["project-kind-label", `project-kind-label--${project.kind}`, `project-kind-label--${size}`]} data-project-kind={project.kind} data-project-kind-label>
  {project.kind !== "application" && (
    <span class="project-kind-icon" aria-hidden="true">
      {project.kind === "research" ? (
        <svg viewBox="0 0 24 24"><circle cx="8" cy="8" r="3"/><circle cx="16" cy="16" r="3"/><path d="m10.2 10.2 3.6 3.6M15.5 5.5l3 3M5.5 15.5l3 3"/></svg>
      ) : (
        <svg viewBox="0 0 24 24"><path d="M5 5h14v4H5zM5 15h14v4H5zM8 9v6M16 9v6"/></svg>
      )}
    </span>
  )}
  <span>{label}</span>
</span>

<style>
  .project-kind-label { --kind-accent:var(--color-accent); display:inline-flex; width:fit-content; align-items:center; gap:var(--space-2); color:var(--kind-accent); font-size:var(--text-xs); font-weight:750; }
  .project-kind-label--research { --kind-accent:var(--project-research-accent); }
  .project-kind-label--application { --kind-accent:var(--project-application-accent); }
  .project-kind-label--infrastructure { --kind-accent:var(--project-infrastructure-accent); }
  .project-kind-icon { display:grid; width:1.75rem; height:1.75rem; place-items:center; border:1px solid color-mix(in srgb,var(--kind-accent) 38%,var(--color-border)); background:color-mix(in srgb,var(--kind-accent) 10%,var(--color-surface)); }
  .project-kind-label--large .project-kind-icon { width:3.25rem; height:3.25rem; }
  .project-kind-icon svg { width:62%; height:62%; fill:none; stroke:currentColor; stroke-width:1.7; stroke-linecap:round; stroke-linejoin:round; }
</style>

---
import { getPaperLabNavigation, isNavigationActive } from "../../i18n/routes";
import type { Locale } from "../../i18n/types";
import { getLocalePath, translate } from "../../i18n/utils";

interface Props { currentPath: string; locale: Locale }
const { currentPath, locale } = Astro.props;
const paperLabNavigation = getPaperLabNavigation(locale);
---

<nav class="paper-lab-nav" aria-label={translate(locale, "a11y.paperLabNavigation")}>
  <a class="paper-lab-nav__brand" href={getLocalePath(locale, "/papers/")}>{translate(locale, "nav.paperLab")}</a>
  <div class="paper-lab-nav__groups">
    {paperLabNavigation.map((group) => (
      <details data-capability-group={group.id}>
        <summary>{group.label}</summary>
        <div>
          {group.items.map((item) => (
            <a href={item.href} data-navigation-id={item.id} aria-current={isNavigationActive(currentPath, item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </div>
      </details>
    ))}
  </div>
</nav>

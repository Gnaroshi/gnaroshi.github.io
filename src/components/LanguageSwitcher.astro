---
import { localeLabels } from "../i18n/config";
import type { AlternateUrls, Locale } from "../i18n/types";
import { getCounterpartUrl, getLocalizedCollectionIndex, translate } from "../i18n/utils";

interface Props {
  locale: Locale;
  currentPath: string;
  alternateUrls?: AlternateUrls;
  mobile?: boolean;
}

const { locale, currentPath, alternateUrls, mobile = false } = Astro.props;
const otherLocale: Locale = locale === "en" ? "ko" : "en";
const translated = alternateUrls?.translationAvailable !== false;
const directTarget = alternateUrls?.[otherLocale] ?? getCounterpartUrl(locale, currentPath);
const target = translated ? directTarget : getLocalizedCollectionIndex(otherLocale, currentPath);
const englishTarget = alternateUrls?.en ?? (locale === "en" ? currentPath : getCounterpartUrl(locale, currentPath));
const koreanTarget = locale === "ko" ? (alternateUrls?.ko ?? currentPath) : target;
const noticeId = `translation-status-${mobile ? "mobile" : "desktop"}`;
---

<div class:list={["language-switcher", mobile && "language-switcher--mobile"]} role="group" aria-label={translate(locale, "nav.language")} data-translation-available={String(translated)}>
  {mobile && <span>{translate(locale, "nav.language")}</span>}
  {locale === "en"
    ? <span class="language-switcher__current" lang="en" aria-current="page">EN</span>
    : <a href={englishTarget} lang="en" aria-describedby={!translated ? noticeId : undefined}>EN</a>}
  <span aria-hidden="true">|</span>
  {locale === "ko"
    ? <span class="language-switcher__current" lang="ko" aria-current="page">{localeLabels.ko}</span>
    : <a href={koreanTarget} lang="ko" aria-describedby={!translated ? noticeId : undefined}>{localeLabels.ko}</a>}
  {!translated && <small class="language-switcher__notice" id={noticeId}>{translate(locale, "language.translationUnavailableTarget")}</small>}
</div>

<script>
  for (const switcher of document.querySelectorAll<HTMLElement>(".language-switcher")) {
    for (const link of switcher.querySelectorAll<HTMLAnchorElement>("a[lang]")) {
      const baseTarget = link.href;
      const updateTarget = () => {
        if (switcher.dataset.translationAvailable !== "true") return;
        const target = new URL(baseTarget, window.location.origin);
        target.search = window.location.search;
        target.hash = window.location.hash;
        link.href = `${target.pathname}${target.search}${target.hash}`;
      };
      updateTarget();
      window.addEventListener("gnaroshi:locationchange", updateTarget);
      window.addEventListener("hashchange", updateTarget);
      window.addEventListener("popstate", updateTarget);
      link.addEventListener("click", () => {
        updateTarget();
        try { window.localStorage.setItem("locale", link.lang.startsWith("ko") ? "ko" : "en"); } catch {}
      });
    }
  }
</script>

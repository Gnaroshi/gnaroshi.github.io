---
import { profile } from "../data/profile";
import { getFooterNavigation } from "../i18n/routes";
import type { Locale } from "../i18n/types";
import { getLocalePath, translate } from "../i18n/utils";

interface Props { locale: Locale }
const { locale } = Astro.props;
const footerNavigation = getFooterNavigation(locale);
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div>
      <p class="site-footer__title"><img src="/media/identity/gnaroshi-site-mark-64.png" width="32" height="32" alt="" aria-hidden="true" />{profile.siteName}</p>
      <p class="site-footer__text">{translate(locale, "site.footerTagline")}</p>
    </div>

    <nav class="site-footer__links" aria-label={translate(locale, "a11y.footerNavigation")}>
      {footerNavigation.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
      <a href={getLocalePath(locale, "/rss.xml")}>{translate(locale, "nav.rss")}</a>
      <a href={profile.links.github}>{translate(locale, "nav.github")}</a>
    </nav>
  </div>
</footer>

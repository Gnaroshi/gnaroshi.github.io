---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  id?: string;
}
const { eyebrow, title, description, id } = Astro.props;
---
<header class="page-header">
  <p class="eyebrow">{eyebrow}</p>
  <h1 id={id}>{title}</h1>
  {description && <p class="lede">{description}</p>}
  <slot />
</header>

---
import { profile } from "../data/profile";
import { ogLocales } from "../i18n/config";
import type { AlternateUrls, Locale } from "../i18n/types";
import { getLocalePath } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  absoluteTitle?: boolean;
  type?: "website" | "article";
  locale?: Locale;
  alternateUrls?: AlternateUrls;
  ogLocale?: string;
  ogLocaleAlternate?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageAlt?: string;
  robots?: "index, follow" | "noindex, follow";
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  articleTags?: string[];
  author?: string;
}

const {
  title = profile.siteName,
  description = profile.shortBio,
  canonical,
  ogImage,
  ogTitle,
  ogDescription,
  absoluteTitle = false,
  type = "website",
  locale = "en",
  alternateUrls,
  ogLocale = ogLocales[locale],
  ogLocaleAlternate = ogLocales[locale === "en" ? "ko" : "en"],
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogImageAlt = locale === "ko" ? "Gnaroshi 연구 홈페이지" : "Gnaroshi research homepage",
  robots = "index, follow",
  publishedTime,
  modifiedTime,
  articleTags = [],
  author = profile.publicAlias
} = Astro.props;

const pageTitle = absoluteTitle || title === profile.siteName ? title : `${title} | ${profile.siteName}`;
const socialTitle = ogTitle ?? pageTitle;
const socialDescription = ogDescription ?? description;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, profile.domain).toString();
const imageUrl = new URL(ogImage ?? (locale === "ko" ? "/og/default-ko.png" : "/og/default-en.png"), profile.domain).toString();
const englishAlternate = new URL(alternateUrls?.en ?? getLocalePath("en", Astro.url.pathname), profile.domain).toString();
const koreanAlternate = new URL(alternateUrls?.ko ?? getLocalePath("ko", Astro.url.pathname), profile.domain).toString();
const xDefaultAlternate = new URL(alternateUrls?.xDefault ?? englishAlternate, profile.domain).toString();
const translationAvailable = alternateUrls?.translationAvailable ?? true;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<meta name="author" content={author} />
<link rel="canonical" href={canonicalUrl} />
{(!alternateUrls || translationAvailable || locale === "en") && <link rel="alternate" hreflang="en" href={englishAlternate} />}
{(!alternateUrls || translationAvailable || locale === "ko") && <link rel="alternate" hreflang="ko" href={koreanAlternate} />}
{(!alternateUrls || translationAvailable || locale === "en") && <link rel="alternate" hreflang="x-default" href={xDefaultAlternate} />}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={profile.siteName} />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={socialDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content={ogLocale} />
{translationAvailable && <meta property="og:locale:alternate" content={ogLocaleAlternate} />}
{type === "article" && publishedTime && <meta property="article:published_time" content={new Date(publishedTime).toISOString()} />}
{type === "article" && modifiedTime && <meta property="article:modified_time" content={new Date(modifiedTime).toISOString()} />}
{type === "article" && articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
{type === "article" && <meta property="article:author" content={author} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={socialDescription} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />

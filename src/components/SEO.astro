---
import { profile } from "../data/profile";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  absoluteTitle?: boolean;
  type?: "website" | "article";
}

const {
  title = profile.siteName,
  description = profile.shortBio,
  canonical,
  ogImage,
  ogTitle,
  ogDescription,
  absoluteTitle = false,
  type = "website"
} = Astro.props;

const pageTitle = absoluteTitle || title === profile.siteName ? title : `${title} | ${profile.siteName}`;
const socialTitle = ogTitle ?? pageTitle;
const socialDescription = ogDescription ?? description;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, profile.domain).toString();
const imageUrl = new URL(ogImage ?? "/og/default.svg", profile.domain).toString();
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={profile.siteName} />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={socialDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={socialDescription} />
<meta name="twitter:image" content={imageUrl} />

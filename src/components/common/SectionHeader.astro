---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<header class="section-header">
  <div>
    {eyebrow && <p class="section-header__eyebrow">{eyebrow}</p>}
    <h2 id={id}>{title}</h2>
    {description && <p>{description}</p>}
  </div>
  <slot name="action" />
</header>

<style>
  .section-header {
    display: flex;
    gap: var(--space-4);
    align-items: end;
    justify-content: space-between;
  }

  .section-header div {
    display: grid;
    gap: var(--space-2);
  }

  .section-header__eyebrow {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .section-header p:not(.section-header__eyebrow) {
    max-width: 68ch;
    margin: 0;
    color: var(--color-text-secondary);
  }

  @media (max-width: 479px) {
    .section-header {
      display: grid;
      align-items: start;
    }
  }
</style>

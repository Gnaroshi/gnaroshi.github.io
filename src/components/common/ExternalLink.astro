---
interface Props {
  href: string;
  label?: string;
}

const { href, label } = Astro.props;
const isExternal = /^https?:\/\//.test(href);
---

<a
  class="external-link"
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noreferrer" : undefined}
>
  <slot>{label}</slot>
  {isExternal && <span aria-hidden="true">↗</span>}
</a>

<style>
  .external-link {
    display: inline-flex;
    gap: 0.25rem;
    align-items: center;
    width: fit-content;
    font-weight: 600;
  }
</style>


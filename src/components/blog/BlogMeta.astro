---
import type { BlogPost } from "../../utils/content";
import { formatLocalizedDate } from "../../i18n/date";
import type { Locale } from "../../i18n/types";
import { translate } from "../../i18n/utils";
import { getPostReadingTime } from "../../utils/content";

interface Props {
  post: BlogPost;
  locale?: Locale;
}

const { post, locale = post.data.locale } = Astro.props;
const readingTime = getPostReadingTime(post);
const readingMinutes = Number.parseInt(readingTime, 10) || 1;
---

<p class="blog-meta">
  <time datetime={post.data.pubDate.toISOString()}>{formatLocalizedDate(post.data.pubDate, locale)}</time>
  {post.data.updatedDate && (
    <>
      <span aria-hidden="true">·</span>
      <span>{translate(locale, "writing.updated")} <time datetime={post.data.updatedDate.toISOString()}>{formatLocalizedDate(post.data.updatedDate, locale)}</time></span>
    </>
  )}
  <span aria-hidden="true">·</span>
  <span>{translate(locale, "writing.readingTime", { count: readingMinutes })}</span>
  {post.data.series && (
    <>
      <span aria-hidden="true">·</span>
      <span>{post.data.series}</span>
    </>
  )}
</p>

<style>
  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
</style>

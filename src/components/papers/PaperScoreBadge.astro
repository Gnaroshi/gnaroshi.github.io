---
import { scoreLevelLabel, type ScoreLevel } from "../../utils/paperReviews";

interface Props {
  score: number;
  level: ScoreLevel;
  label?: string;
}

const { score, level, label = "AI review" } = Astro.props;
---

<span class:list={["paper-score-badge", `paper-score-badge--${level}`]}>
  <span>{label}</span>
  <strong>{score}</strong>
  <span>{scoreLevelLabel(level)}</span>
</span>

---
import type { PaperRecord } from "../../utils/papers";

interface Props {
  status: PaperRecord["status"];
}

const { status } = Astro.props;

const labels: Record<PaperRecord["status"], string> = {
  planned: "Planned",
  pass1: "Pass 1",
  pass2: "Pass 2",
  pass3: "Pass 3",
  read: "Read",
  implemented: "Implemented",
  abandoned: "Abandoned"
};
---

<span class:list={["paper-badge", "paper-status-badge", `paper-status-badge--${status}`]}>{labels[status]}</span>


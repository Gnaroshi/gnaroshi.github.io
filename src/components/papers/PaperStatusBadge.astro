---
import type { PaperRecord } from "../../utils/papers";
import type { Locale } from "../../i18n/types";
import { translate } from "../../i18n/utils";

interface Props {
  status: PaperRecord["status"];
  locale?: Locale;
}

const { status, locale = "en" } = Astro.props;
---

<span class:list={["paper-badge", "paper-status-badge", `paper-status-badge--${status}`]}>{translate(locale, `status.${status}`)}</span>

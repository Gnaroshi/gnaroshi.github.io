---
import type { PaperStats as PaperStatsData } from "../../utils/papers";
import type { IslandMessages } from "../../i18n/islands";

interface Props {
  stats: PaperStatsData;
  messages: IslandMessages["paper"];
}

const { stats, messages } = Astro.props;

const items = [
  { label: messages.sessionsToday, value: stats.sessionsToday },
  { label: messages.papersTouchedToday, value: stats.papersTouchedToday },
  { label: messages.minutesToday, value: stats.minutesToday },
  { label: messages.currentStreak, value: stats.currentStreak },
  { label: messages.distinctPapersThisMonth, value: stats.distinctPapersThisMonth },
  { label: messages.deepSessions, value: stats.deepSessions },
  { label: messages.implementations, value: stats.implementations }
];
---

<section class="paper-stats" aria-label={messages.statistics}>
  {items.map((item) => (
    <article class="paper-stat-card">
      <strong>{item.value}</strong>
      <span>{item.label}</span>
    </article>
  ))}
</section>

---
import type { PaperStats as PaperStatsData } from "../../utils/papers";
import type { IslandMessages } from "../../i18n/islands";

interface Props {
  stats: PaperStatsData;
  messages: IslandMessages["paper"];
}

const { stats, messages } = Astro.props;

const items = [
  { label: messages.papersToday, value: stats.today },
  { label: messages.currentStreak, value: stats.currentStreak },
  { label: messages.longestStreak, value: stats.longestStreak },
  { label: messages.thisWeek, value: stats.thisWeek },
  { label: messages.thisMonth, value: stats.thisMonth },
  { label: messages.thisYear, value: stats.thisYear },
  { label: messages.deepReads, value: stats.deepReads },
  { label: messages.implementedReproduced, value: stats.implemented }
];
---

<section class="paper-stats" aria-label={messages.statistics}>
  {items.map((item) => (
    <article class="paper-stat-card">
      <strong>{item.value}</strong>
      <span>{item.label}</span>
    </article>
  ))}
</section>

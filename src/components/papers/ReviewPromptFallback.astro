---
import type { PaperEntry } from "../../utils/papers";
import { buildManualReviewPromptForPaper } from "../../../scripts/lib/paper-review-prompt.mjs";
import ManualReviewPrompt from "./ManualReviewPrompt";

interface Props {
  paper: PaperEntry;
}

const { paper } = Astro.props;
const prompt = buildManualReviewPromptForPaper({
  slug: paper.id,
  frontmatter: paper.data,
  body: paper.body
});
const command = `npm run paper:review -- --slug ${paper.id}`;
---

<section class="paper-review-fallback section" aria-labelledby="paper-review-fallback-heading">
  <div>
    <p class="eyebrow">AI Review</p>
    <h2 id="paper-review-fallback-heading">No AI review yet</h2>
    <p>
      Generate a review after the note has enough evidence of understanding. The prompt can be copied manually
      or reviewed from the local project workflow.
    </p>
  </div>

  <pre><code>{command}</code></pre>

  <ManualReviewPrompt client:load prompt={prompt} command={command} initiallyOpen={true} />
</section>

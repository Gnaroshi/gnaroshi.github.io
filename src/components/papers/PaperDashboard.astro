---
import { evidenceGates } from "../../config/evidenceGates";
import type { PaperEntry, PaperStats as PaperStatsData } from "../../utils/papers";
import { toPaperRecord } from "../../utils/papers";
import type { PaperReview, PaperReviewStats as PaperReviewStatsData } from "../../utils/paperReviews";
import { formatScore, scoreLevelForScore, toPaperReviewSummary } from "../../utils/paperReviews";
import NewPaperTemplate from "./NewPaperTemplate.astro";
import PaperFilters from "./PaperFilters";
import PaperScoreBadge from "./PaperScoreBadge.astro";
import PaperScoreTrend from "./PaperScoreTrend.astro";
import PaperStats from "./PaperStats.astro";
import ReadingMethodPanel from "./ReadingMethodPanel.astro";
import type { Locale } from "../../i18n/types";
import { translate } from "../../i18n/utils";
import { getIslandMessages } from "../../i18n/islands";

interface Props {
  papers: PaperEntry[];
  stats: PaperStatsData;
  countsByDate: Map<string, number>;
  tags: string[];
  today: string;
  reviewStats: PaperReviewStatsData;
  reviewsBySlug: Map<string, PaperReview>;
  locale?: Locale;
}

const { papers, stats, countsByDate, tags, today, reviewStats, reviewsBySlug, locale = "en" } = Astro.props;
const records = papers.map((paper) => {
  const review = reviewsBySlug.get(paper.id);
  return toPaperRecord(paper, review ? toPaperReviewSummary(review) : undefined, today);
});
const years = [...new Set(records.map((paper) => paper.year))].sort((a, b) => b - a);
const countsRecord = Object.fromEntries(countsByDate.entries());
const hasAdvancedNotebook = papers.length >= evidenceGates.paperLab.filtersAt;
const hasReviewSummary = reviewStats.reviewedCount >= evidenceGates.paperLab.aiReviewSummaryAt;
const islandMessages = getIslandMessages(locale);
const messages = islandMessages.paper;
---

<div class="paper-dashboard">
  <header class="paper-hero paper-hero--focused">
    <div class="paper-hero__copy">
      <p class="eyebrow">{translate(locale, "nav.paperLab")}</p>
      <h1>{translate(locale, "papers.title")}</h1>
      <p class="lede">{translate(locale, "papers.subtitle")}</p>
    </div>
    {papers.length > 0 && <a class="button button--primary" href="#new-paper-template">{translate(locale, "papers.add")}</a>}
  </header>

  {papers.length === 0 ? (
    <>
      <section class="paper-onboarding" aria-labelledby="paper-onboarding-heading">
        <div>
          <p class="eyebrow">{translate(locale, "papers.startSmall")}</p>
          <h2 id="paper-onboarding-heading">{translate(locale, "papers.firstEnough")}</h2>
          <p>{translate(locale, "papers.firstDescription")}</p>
        </div>
        <a class="button button--primary" href="#new-paper-template">{translate(locale, "home.addFirstPaper")}</a>
      </section>
      <ReadingMethodPanel locale={locale} />
      <section class="paper-workflow-notes" aria-label={translate(locale, "nav.paperLab")}>
        <article id="ai-review-workflow">
          <h2>{translate(locale, "papers.aiReview")}</h2>
          <p>{translate(locale, "papers.aiReviewBody")}</p>
        </article>
        <article id="oral-exam-entry">
          <h2>{translate(locale, "papers.oralExam")}</h2>
          <p>{translate(locale, "papers.oralExamBody")}</p>
        </article>
        <article id="paper-to-blog">
          <h2>{translate(locale, "papers.paperToBlog")}</h2>
          <p>{translate(locale, "papers.paperToBlogBody")}</p>
        </article>
      </section>
    </>
  ) : (
    <>
      {hasAdvancedNotebook ? <PaperStats stats={stats} messages={messages} /> : (
        <p class="paper-compact-activity">
          {messages.publicNotes.replace("{count}", String(papers.length))}
        </p>
      )}

      {hasReviewSummary && (
        <section id="ai-review-workflow" class="paper-review-summary" aria-labelledby="paper-review-summary-heading">
          <div class="paper-review-summary__header">
            <div>
              <p class="eyebrow">{messages.aiReview}</p>
              <h2 id="paper-review-summary-heading">{messages.readingProcessEvidence}</h2>
              <p>{messages.scoreScope}</p>
            </div>
            {reviewStats.averageScore !== null && (
              <PaperScoreBadge score={reviewStats.averageScore} level={scoreLevelForScore(reviewStats.averageScore)} label={messages.average} messages={messages} />
            )}
          </div>
          <div class="paper-review-summary__grid">
            <article class="paper-stat-card"><strong>{formatScore(reviewStats.averageScore)}</strong><span>{messages.averageAi}</span></article>
            <article class="paper-stat-card"><strong>{formatScore(reviewStats.averageSelfScore)}</strong><span>{messages.averageSelf}</span></article>
            <article class="paper-stat-card"><strong>{formatScore(reviewStats.averageScoreGap)}</strong><span>{messages.averageGap}</span></article>
            <article class="paper-stat-card"><strong>{reviewStats.papersWithNextReviewDue}</strong><span>{messages.reviewsDue}</span></article>
          </div>
          <div class="paper-review-summary__body">
            <div><h3>{messages.scoreTrend}</h3><PaperScoreTrend trend={reviewStats.trend} locale={locale} messages={messages} /></div>
            {reviewStats.weakestDimension && (
              <div><h3>{messages.weakDimension}</h3><p class="metadata">{messages.dimensionAverage.replace("{label}", reviewStats.weakestDimension.label).replace("{score}", String(reviewStats.weakestDimension.averageScore))}</p></div>
            )}
          </div>
        </section>
      )}

      <section id="paper-notes" aria-label={messages.paperNotes}>
        {hasAdvancedNotebook ? (
          <PaperFilters
            client:visible
            papers={records}
            countsByDate={countsRecord}
            tags={tags}
            years={years}
            today={today}
            locale={locale}
            messages={messages}
          />
        ) : (
          <div class="paper-note-list">
            {records.map((paper) => (
              <article>
                <div><span>{messages.statuses[paper.status]}</span><span>{messages.depths[paper.depth]}</span></div>
                <h2><a href={paper.href}>{paper.title}</a></h2>
                <p>{paper.oneLineSummary}</p>
                <small>{paper.venue} · {paper.year}{paper.readDate ? ` · ${paper.readDate}` : ""}</small>
              </article>
            ))}
          </div>
        )}
      </section>
    </>
  )}

  <NewPaperTemplate locale={locale} />
</div>

<style>
  .paper-hero--focused {
    align-items: end;
  }

  .paper-hero--focused > .button {
    width: fit-content;
  }

  .paper-onboarding {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-6);
    align-items: end;
    padding: var(--space-6);
    border-left: 3px solid var(--color-reading);
    background: var(--color-surface-quiet);
  }

  .paper-onboarding > div {
    display: grid;
    max-width: 62ch;
    gap: var(--space-3);
  }

  .paper-onboarding p:last-child,
  .paper-workflow-notes p,
  .paper-note-list p {
    color: var(--color-text-secondary);
  }

  .paper-workflow-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
    padding: var(--space-6) 0;
  }

  .paper-workflow-notes article {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 2px solid var(--color-border-strong);
  }

  .paper-compact-activity {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .paper-note-list {
    display: grid;
  }

  .paper-note-list article {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
  }

  .paper-note-list article > div {
    display: flex;
    gap: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
  }

  .paper-note-list small {
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .paper-onboarding { grid-template-columns: 1fr; padding: var(--space-5); }
    .paper-workflow-notes { grid-template-columns: 1fr; }
  }
</style>

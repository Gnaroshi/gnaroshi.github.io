---

<details id="new-paper-template" class="new-paper-template">
  <summary>
    <span>
      <span class="eyebrow">{translate(locale, "papers.template")}</span>
      <strong>{translate(locale, "papers.pass1")}</strong>
    </span>
    <span>{translate(locale, "papers.showTemplate")}</span>
  </summary>
  <div>
    <p>{translate(locale, "papers.firstDescription")}</p>
    <textarea readonly rows="18" aria-label={translate(locale, "papers.template")}>{snippet}</textarea>
  </div>
</details>

<style>
  .new-paper-template {
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .new-paper-template summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
  }

  .new-paper-template summary::-webkit-details-marker { display: none; }
  .new-paper-template summary > span:first-child { display: grid; gap: var(--space-1); }
  .new-paper-template summary > span:last-child { color: var(--color-accent); font-size: var(--text-sm); font-weight: 700; }
  .new-paper-template > div { display: grid; gap: var(--space-4); padding-top: var(--space-4); }
  .new-paper-template p { color: var(--color-text-secondary); }
  .new-paper-template textarea { width: 100%; min-height: 22rem; resize: vertical; }
</style>

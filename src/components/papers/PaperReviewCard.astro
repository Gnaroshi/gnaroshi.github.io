---
import type { PaperReview } from "../../utils/paperReviews";
import PaperScoreBadge from "./PaperScoreBadge.astro";
import { getIslandMessages } from "../../i18n/islands";

interface Props { review: PaperReview }
const { review } = Astro.props;
const messages = getIslandMessages("en").paper;
---

<section class="paper-review-card section" aria-labelledby="paper-review-heading">
  <div class="paper-review-card__header">
    <div>
      <p class="eyebrow">Published review</p>
      <h2 id="paper-review-heading">What the note shows</h2>
      <p>{review.summary}</p>
      <p class="metadata">{review.reviewedAt.slice(0, 10)} · {review.confidence} confidence</p>
    </div>
    {review.overallScore !== null && review.scoreLevel && <PaperScoreBadge score={review.overallScore} level={review.scoreLevel} label="Reading process score" messages={messages} />}
  </div>

  {review.nextReviewDate && <div class="paper-review-calibration-grid" aria-label="Review schedule"><article><h3>Next review date</h3><p>{review.nextReviewDate}</p></article></div>}

  {(review.strengths.length > 0 || review.gaps.length > 0) && (
    <div class="paper-review-two-col">
      {review.strengths.length > 0 && <section aria-labelledby="review-strengths-heading"><h3 id="review-strengths-heading">Strengths</h3><ul>{review.strengths.map((item) => <li>{item}</li>)}</ul></section>}
      {review.gaps.length > 0 && <section aria-labelledby="review-gaps-heading"><h3 id="review-gaps-heading">Gaps</h3><ul>{review.gaps.map((item) => <li>{item}</li>)}</ul></section>}
    </div>
  )}

  {review.nextActions.length > 0 && (
    <section aria-labelledby="review-next-actions-heading"><h3 id="review-next-actions-heading">Next actions</h3><ol class="paper-review-actions">{review.nextActions.map((item) => <li><span>{item}</span></li>)}</ol></section>
  )}
</section>

---
import type { Locale } from "../../i18n/types";
import { translate } from "../../i18n/utils";
import ReadingPassChecklist from "./ReadingPassChecklist.astro";
interface Props { locale?: Locale }
const { locale = "en" } = Astro.props;
const passes = [
  {
    title: translate(locale, "papers.pass1"),
    description: translate(locale, "papers.pass1Body")
  },
  {
    title: translate(locale, "papers.pass2"),
    description: translate(locale, "papers.pass2Body")
  },
  {
    title: translate(locale, "papers.pass3"),
    description: translate(locale, "papers.pass3Body")
  }
];

const principles = [
  translate(locale, "papers.principleDepth"),
  translate(locale, "papers.principleQuestions"),
  translate(locale, "papers.principleConsistency"),
  translate(locale, "papers.principleRevisit")
];
---

<section id="reading-method" class="paper-method-panel" aria-labelledby="reading-method-heading" tabindex="-1">
  <div class="paper-method-panel__header">
    <p class="eyebrow">{translate(locale, "papers.method")}</p>
    <h2 id="reading-method-heading">{translate(locale, "papers.threePass")}</h2>
  </div>
  <ol class="paper-method-panel__passes">
    {passes.map((pass, index) => (
      <li>
        <span aria-hidden="true">{index + 1}</span>
        <h3>{pass.title}</h3>
        <p>{pass.description}</p>
      </li>
    ))}
  </ol>
  <ReadingPassChecklist locale={locale} passes={passes} />
  <ul class="paper-method-panel__principles">
    {principles.map((principle) => <li>{principle}</li>)}
  </ul>
</section>

---
import SystemBuildDetails from "./SystemBuildDetails.astro";
import SystemFlowDiagram from "./SystemFlowDiagram.astro";
import SystemRepositoryCard from "./SystemRepositoryCard.astro";
import { getSystemRepository } from "../../data/facts/systemArchitecture";
import { getLocalizedData } from "../../data/locales";
import type { Locale } from "../../i18n/types";
import { getLocalePath } from "../../i18n/utils";
import { getWebsiteBuildInfo } from "../../utils/contentFeed";
import "../../styles/system-workflow.css";

interface Props {
  locale: Locale;
  variant: "compact" | "full";
  showBuildDetails?: boolean;
}

const { locale, variant, showBuildDetails = false } = Astro.props;
const copy = getLocalizedData(locale).systemArchitecture;
const presentationCopy = variant === "full" ? { ...copy, title: copy.fullTitle } : copy;
const repositories = {
  paperLab: getSystemRepository("paper-lab"),
  writing: getSystemRepository("writing"),
  studio: getSystemRepository("studio"),
  api: getSystemRepository("api"),
  contentFeed: getSystemRepository("content-feed"),
  website: getSystemRepository("website")
};
const labels = {
  badges: copy.badges,
  responsibilityLabel: copy.responsibilityLabel,
  exclusionsLabel: copy.exclusionsLabel,
  repositoryLinkLabel: copy.repositoryLinkLabel
};
const buildInfo = variant === "full" && showBuildDetails ? getWebsiteBuildInfo() : undefined;
---

<section
  id={variant === "full" ? "repository-workflow" : "repository-workflow-home"}
  class:list={["content-section", "system-workflow", `system-workflow--${variant}`]}
  data-system-workflow={variant}
  aria-labelledby={`system-workflow-title-${variant}`}
>
  <header class="system-workflow__heading">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2 id={`system-workflow-title-${variant}`}>{presentationCopy.title}</h2>
    <p>{copy.description}</p>
  </header>

  <SystemFlowDiagram copy={presentationCopy} />

  {variant === "full" && (
    <details class="system-workflow__boundaries">
      <summary>{copy.boundariesTitle}</summary>
      <div class="system-workflow__repository-grid">
        <SystemRepositoryCard repository={repositories.paperLab} copy={copy.repositories["paper-lab"]} labels={labels} variant="full" />
        <SystemRepositoryCard repository={repositories.writing} copy={copy.repositories.writing} labels={labels} variant="full" />
        <SystemRepositoryCard repository={repositories.studio} copy={copy.repositories.studio} labels={labels} variant="full" />
        <SystemRepositoryCard repository={repositories.api} copy={copy.repositories.api} labels={labels} variant="full" optional />
        <SystemRepositoryCard repository={repositories.contentFeed} copy={copy.repositories["content-feed"]} labels={labels} variant="full" />
        <SystemRepositoryCard repository={repositories.website} copy={copy.repositories.website} labels={labels} variant="full" />
      </div>
    </details>
  )}

  {variant === "compact" && (
    <a class="button button--primary system-workflow__cta" href={getLocalePath(locale, "/projects/gnaroshi-dev/#repository-workflow")}>{copy.cta}</a>
  )}
  {buildInfo && <SystemBuildDetails locale={locale} info={buildInfo} copy={copy.buildDetails} />}
</section>

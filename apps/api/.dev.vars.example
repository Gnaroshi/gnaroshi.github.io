# Copy to .dev.vars for local Worker development. Never commit .dev.vars.
OPENAI_API_KEY=
API_ENV=development
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_SCORING_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
ALLOWED_ORIGINS=https://gnaroshi.dev,http://localhost:4321,http://localhost:8787
MAX_EXAM_MINUTES=12
MAX_TRANSCRIPT_CHARS=50000

# Optional local/testing guard only. Do not expose this in public frontend code.
ORAL_EXAM_API_SHARED_SECRET=

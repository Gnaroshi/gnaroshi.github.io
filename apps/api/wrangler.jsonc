{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "gnaroshi-research-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "api.gnaroshi.dev",
      "custom_domain": true
    }
  ],
  "vars": {
    "OPENAI_REALTIME_MODEL": "gpt-realtime-2.1",
    "OPENAI_SCORING_MODEL": "gpt-5.4-mini",
    "OPENAI_TRANSCRIBE_MODEL": "gpt-4o-transcribe",
    "OPENAI_TTS_MODEL": "gpt-4o-mini-tts",
    "ALLOWED_ORIGINS": "https://gnaroshi.dev,http://localhost:4321,http://localhost:8787",
    "API_ENV": "production",
    "MAX_EXAM_MINUTES": "12",
    "MAX_TRANSCRIPT_CHARS": "50000"
  },
  "ratelimits": [
    {
      "name": "REALTIME_SESSION_RATE_LIMITER",
      "namespace_id": "41001",
      "simple": { "limit": 10, "period": 60 }
    },
    {
      "name": "EXAM_GENERATE_RATE_LIMITER",
      "namespace_id": "41002",
      "simple": { "limit": 20, "period": 60 }
    },
    {
      "name": "EXAM_SCORE_RATE_LIMITER",
      "namespace_id": "41003",
      "simple": { "limit": 20, "period": 60 }
    },
    {
      "name": "TRANSCRIBE_RATE_LIMITER",
      "namespace_id": "41004",
      "simple": { "limit": 10, "period": 60 }
    },
    {
      "name": "SPEECH_RATE_LIMITER",
      "namespace_id": "41005",
      "simple": { "limit": 20, "period": 60 }
    }
  ],
  "limits": {
    "cpu_ms": 1000,
    "subrequests": 10
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}

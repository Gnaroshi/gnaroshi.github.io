{
  "name": "gnaroshi.github.io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run content:check && ASTRO_TELEMETRY_DISABLED=1 astro dev --force",
    "build": "npm run content:check && ASTRO_TELEMETRY_DISABLED=1 astro build --force",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "npm run content:check && ASTRO_TELEMETRY_DISABLED=1 astro sync --force && ASTRO_TELEMETRY_DISABLED=1 astro check",
    "content:pull": "node scripts/content-feed-pull.mjs",
    "content:check": "node scripts/content-feed-check.mjs",
    "test:e2e": "playwright test --grep-invert \"@a11y|@visual\"",
    "test:a11y": "playwright test --grep \"@a11y\"",
    "test:smoke": "playwright test --grep \"@smoke\"",
    "test:visual": "playwright test --grep \"@visual-v3\"",
    "test:feed-contract": "node scripts/test-content-feed-fixtures.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:i18n": "node scripts/check-i18n.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7",
    "katex": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "typescript": "^6.0.3"
  }
}
